          }
        },
        "text_VmJxKr": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Start or pause</strong></p><p>Tap the soundwave twice quickly to start or pause the metronome.</p>"
          }
        },
        "image_JRGeCQ": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Pulse_Order_6.jpg"
          }
        },
        "text_pD9eRG": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Tap tempo</strong></p><p>Tap the soundwave three times or more at a steady pace. Pulse will set a new tempo that matches the average speed of your taps.</p>"
          }
        },
        "image_mXDBAY": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Pulse_Order_7.jpg"
          }
        },
        "text_yYneXf": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Change the tempo</strong></p><p>Turn the wheel to make fine adjustments to the tempo.</p>"
          }
        },
        "image_FLNrUT": {
