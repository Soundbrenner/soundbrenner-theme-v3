          "settings": {
            "heading": "Inserting it into the band"
          }
        },
        "text_HtN3ri": {
          "type": "text",
          "settings": {
            "text": "<p>Insert one side of the Pulse into the band. Then pull up the opposite side of the band until it snaps into place.</p>"
          }
        },
        "image_AMXGYM": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Pulse_Order_2_1cbbd11a-3ee9-4e41-b390-5fe4e34ea46c.jpg"
          }
        },
        "divider_epqbmW": {
