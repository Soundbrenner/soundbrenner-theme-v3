          "settings": {}
        },
        "subheading_M8C8Qb": {
          "type": "subheading",
          "settings": {
            "heading": "Multi-player sync"
          }
        },
        "text_fPAj8t": {
          "type": "text",
          "settings": {
            "text": "<p>The Pulse can be synced with other wearables by connecting them to the same mobile device. You can sync up to five devices, allowing everyone to feel the beat together.</p><p>Open the Soundbrenner app on the mobile device you want to use for syncing. Then navigate to <strong>Settings → Add a wearable</strong>.</p>"
          }
        },
        "divider_r9CiCP": {
          "type": "divider",
          "settings": {}
        },
        "heading_UbVVPP": {
          "type": "heading",
          "settings": {
            "heading": "Troubleshooting"
          }
        },
        "text_w4eKbN": {
          "type": "text",
          "settings": {
            "text": "<p>If your Pulse is not responding, restarting the device will usually resolve the issue.</p><p>To restart the device, first remove the band. Locate the small round hole in the recessed area normally covered by the band. Insert a pointed object, such as a needle, into the hole. If the restart is successful, the device will briefly light up.</p>"
          }
        },
        "image_fKNeqy": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Pulse_Order_12.jpg"
          }
        },
        "divider_Cf3TTW": {
