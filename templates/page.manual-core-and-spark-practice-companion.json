          }
        },
        "text_6EWjNa": {
          "type": "text",
          "settings": {
            "text": "<p>A: Wheel</p><p>B: Magnetic port</p><p>C: Top button</p><p>D: Touch surface (soundwave)</p><p>E: Bottom button</p>"
          }
        },
        "image_rxgnT8": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Core_2_Order_5_d959743c-400a-49a7-b5f7-26c0c5d3053a.jpg"
