        "chapter_1": {
          "type": "heading",
          "settings": {
            "heading": "Read this first, please"
          }
        },
        "body_1": {
          "type": "text",
          "settings": {
            "text": "<p>At Soundbrenner we firmly believe success is not given, it's earned. This is true for musicians, but also for companies.<br/><br/>We went to great lengths to ensure the product you’re holding was made to the highest standards. We care deeply that it becomes an irreplaceable companion on your musical journey.<br/><br/>If you experience any issues, our team will work hard to put a smile back on your face. We’re just an e-mail away.</p>"
          }
        },
        "button_1": {
          "type": "button",
          "settings": {
            "label": "Contact us",
            "button_size": "large",
            "icon_position": "none",
            "link": "shopify://pages/contact-us"
          }
        },
