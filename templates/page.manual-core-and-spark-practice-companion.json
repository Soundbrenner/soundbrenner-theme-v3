          "settings": {
            "heading": "First steps"
          }
        },
        "subheading_VNBViy": {
          "type": "subheading",
          "settings": {
            "heading": "Video: the best way to get started"
          }
        },
        "body_2": {
          "type": "text",
          "settings": {
            "text": "<p>This video is the ultimate crash course to learn everything you need to know about how to use your Core/Spark in the shortest time possible. It’s the best way to get started, so we highly recommend you to watch this video!</p>"
          }
        },
        "vimeo_video_YefAQq": {
          "type": "vimeo_video",
          "settings": {
            "video_source": "1102069665"
          }
        },
