        },
        "subheading_d3imP4": {
          "type": "subheading",
          "settings": {
            "heading": "Device controls"
          }
        },
        "text_dydTbg": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Top button</strong></p><ul><li>Go backward</li><li>Stop editing selection</li><li>Power on & power off (long press)</li></ul><p><strong>Bottom button</strong></p><ul><li>Go forward</li><li>Start editing selection</li><li>Open app dock</li></ul><p><strong>Wheel</strong></p><ul><li>Navigate the app dock</li><li>Change values while editing a selection</li></ul><p><strong>Touch surface</strong></p><ul><li>Tap the soundwave twice quickly to start or pause a feature while inside an app</li><li>Tap the soundwave three or more times to tap tempo while inside the <strong>Metronome</strong> app</li></ul>"
          }
        },
        "divider_8GrH8j": {
          "type": "divider",
          "settings": {}
        },
        "subheading_iL8Qey": {
          "type": "subheading",
          "settings": {
            "heading": "Power on & power off"
          }
        },
        "text_9cDw6H": {
          "type": "text",
          "settings": {
            "text": "<p><strong>Power on</strong><br/>Hold the top button for 1 second to turn on the device.</p><p><strong>Power off</strong></p><p>1. Hold the top button for 3 seconds until the power off prompt appears.</p><p>2. Select yes by pressing the bottom button.</p>"
          }
        },
        "divider_xrGQeX": {
          "type": "divider",
          "settings": {}
        },
        "subheading_8r8K8r": {
          "type": "subheading",
          "settings": {
            "heading": "Navigation hierarchy"
          }
        },
        "image_bxUAQc": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Core_Order_8.jpg"
          }
        },
        "divider_JgwgWY": {
