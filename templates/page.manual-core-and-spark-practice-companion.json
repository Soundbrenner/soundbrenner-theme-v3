        "body_4": {
          "type": "text",
          "settings": {
            "text": "<p>Upgrade your practice with Plus, our optional premium service that unlocks the full capabilities of the Soundbrenner app. While your Core / Spark provides a complete experience on its own, Plus adds features such as cloud storage for your songs and setlists, along with additional exclusive tools.</p><p>Your subscription directly supports the release of multiple major app updates each year, ensuring a continuous stream of new features and improvements.</p><p>Your Core / Spark includes a free 3-month Plus trial. You can redeem it by following the in-app instructions after connecting your wearable.</p>"
          }
        },
        "divider_4": {
          "type": "divider",
          "settings": {}
        },
        "subheading_zLjb8j": {
          "type": "subheading",
          "settings": {
            "heading": "Charging the device"
          }
        },
        "body_5": {
          "type": "text",
          "settings": {
            "text": "<p>To charge your Core / Spark, attach the cable to the magnetic port located on the side of the device. A full charge takes approximately 1.5 hours.</p><p><strong>Battery life</strong></p><ul><li>4+ days in watch mode, or</li><li>3+ hours metronome playback</li></ul><p><strong>Charging light</strong></p><ul><li>Orange light = charging</li><li>Green light = fully charged</li></ul>"
          }
        },
        "image_hPYJx3": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Product_Core_2_Order_29.jpg"
          }
        },
        "divider_5": {
          "type": "divider",
          "settings": {}
        },
        "subheading_C8GVdi": {
          "type": "subheading",
          "settings": {
            "heading": "App & compatibility"
          }
        },
        "text_HPx7dM": {
          "type": "text",
          "settings": {
            "text": "<p>Download our app on the product page.</p>"
          }
        },
        "button_Q9xDn7": {
          "type": "button",
          "settings": {
            "label": "Download app",
            "button_size": "large",
            "icon_position": "none",
            "link": "shopify://pages/the-metronome-app"
          }
        },
        "text_4MqtCq": {
          "type": "text",
          "settings": {
            "text": "<p>Requires an iPhone, iPad, iPod touch, Android device, or Mac with Apple silicon. See the app manual for details.</p>"
          }
        },
        "button_86rHwW": {
          "type": "button",
          "settings": {
            "label": "View compatibility",
            "button_size": "large",
            "icon_position": "none",
            "link": "shopify://pages/manual-the-metronome-app"
          }
        },
        "divider_6c6AAp": {
