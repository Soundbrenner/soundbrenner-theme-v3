{% liquid
  assign card_title = blank
  assign card_url = blank
  assign card_image = blank
  assign card_text = blank
  assign card_meta = blank

  if block != blank
    assign content_type = block.settings.content_type | default: 'article'

    case content_type
      when 'article'
        assign card_article = block.settings.article
        if card_article != blank
          assign card_title = card_article.title
          assign card_url = card_article.url
          assign card_image = card_article.image
          assign card_text = card_article.excerpt_or_content | strip_html | truncatewords: 20
          assign card_meta = card_article.published_at | date: format: 'abbreviated_date'
        endif
      when 'product'
        assign card_product = block.settings.product
        if card_product != blank
          assign card_title = card_product.title
          assign card_url = card_product.url
          assign card_image = card_product.featured_image
          assign card_text = card_product.price | money
          assign card_meta = card_product.vendor
        endif
      when 'custom'
        assign card_title = block.settings.title
        assign card_url = block.settings.url
        assign card_image = block.settings.image
        assign card_text = block.settings.description
    endcase
  elsif fallback_article != blank
    assign skip_fallback = false
    if current_article_id != blank and fallback_article.id == current_article_id
      assign skip_fallback = true
    endif

    unless skip_fallback
      assign card_title = fallback_article.title
      assign card_url = fallback_article.url
      assign card_image = fallback_article.image
      assign card_text = fallback_article.excerpt_or_content | strip_html | truncatewords: 20
      assign card_meta = fallback_article.published_at | date: format: 'abbreviated_date'
    endunless
  endif
%}

{% if card_title != blank and card_url != blank %}
  <article class="sb-blog-sidebar-card">
    <a class="sb-blog-sidebar-card__media" href="{{ card_url }}">
      {% if card_image != blank %}
        {{
          card_image
          | image_url: width: 720
          | image_tag:
            widths: '240,360,540,720',
            sizes: '(max-width: 989px) calc(100vw - 40px), 360px',
            class: 'sb-blog-sidebar-card__image',
            loading: 'lazy',
            alt: card_title
        }}
      {% else %}
        <div class="sb-blog-sidebar-card__image sb-blog-sidebar-card__image--placeholder" aria-hidden="true"></div>
      {% endif %}
    </a>
    <div class="sb-blog-sidebar-card__content">
      <a class="sb-blog-sidebar-card__title font-caption weight-semibold" href="{{ card_url }}">
        {{ card_title }}
      </a>
      {% if card_meta != blank %}
        <p class="sb-blog-sidebar-card__meta font-caption2 weight-regular">{{ card_meta }}</p>
      {% endif %}
      {% if card_text != blank %}
        <p class="sb-blog-sidebar-card__text font-caption weight-regular">{{ card_text }}</p>
      {% endif %}
    </div>
  </article>
{% endif %}
