{% liquid
  assign sb_cart_list_class = list_class | default: 'sb-cart-line-list'
  assign sb_cart_placeholder_image = placeholder_image
  assign sb_cart_currency_code = cart.currency.iso_code | default: localization.country.currency.iso_code | default: shop.currency | upcase
  if sb_cart_placeholder_image == blank
    assign sb_cart_placeholder_image = 'icon-square-placeholder.svg' | asset_url
  endif
%}

<ul class="{{ sb_cart_list_class }}" data-cart-item-list {% if hidden %}hidden{% endif %}>
  {% for item in cart.items %}
    {% liquid
      assign item_line = forloop.index
      assign item_key = item.key | default: ''
      assign item_title = item.product.title | default: item.title
      assign item_variant = item.variant_title
      if item_variant == 'Default Title'
        assign item_variant = blank
      endif
      assign item_image = item.image | image_url: width: 256
      assign item_hover_image = blank
      capture item_variant_hover_image_url
        render 'sb-hover-image-url', resource: item.variant, width: 256
      endcapture
      assign item_variant_hover_image_url = item_variant_hover_image_url | strip
      if item_variant_hover_image_url != blank
        assign item_hover_image = item_variant_hover_image_url
      endif
      if item_hover_image == blank
        capture item_product_hover_image_url
          render 'sb-hover-image-url', resource: item.product, width: 256
        endcapture
        assign item_product_hover_image_url = item_product_hover_image_url | strip
        if item_product_hover_image_url != blank
          assign item_hover_image = item_product_hover_image_url
        endif
      endif
      assign item_has_discount = false
      if item.original_line_price > item.final_line_price
        assign item_has_discount = true
      endif
      assign item_has_product_discount = false
      assign item_line_discount_title = blank
      assign item_line_discount_percent = 0
      if item_has_discount
        assign item_product_discount_amount = 0
        if item.line_level_discount_allocations != blank
          for item_discount_allocation in item.line_level_discount_allocations
            assign item_discount_title_candidate = item_discount_allocation.discount_application.title | strip
            assign item_discount_type_candidate = item_discount_allocation.discount_application.type | strip | downcase
            assign item_discount_is_cart_level = false
            if cart.cart_level_discount_applications != blank
              for item_cart_level_application in cart.cart_level_discount_applications
                assign item_cart_level_title = item_cart_level_application.title | strip
                assign item_cart_level_type = item_cart_level_application.type | strip | downcase
                if item_discount_title_candidate == item_cart_level_title and item_discount_type_candidate == item_cart_level_type
                  assign item_discount_is_cart_level = true
                  break
                endif
              endfor
            endif
            if item_discount_is_cart_level == false
              assign item_discount_amount_candidate = item_discount_allocation.amount | plus: 0
              if item_discount_amount_candidate > 0
                assign item_product_discount_amount = item_product_discount_amount | plus: item_discount_amount_candidate
              endif
              if item_line_discount_title == blank and item_discount_title_candidate != blank
                assign item_line_discount_title = item_discount_title_candidate | upcase
              endif
            endif
          endfor
        endif
        if item.original_line_price > 0 and item_product_discount_amount > 0
          assign item_line_discount_percent = item_product_discount_amount | times: 100.0 | divided_by: item.original_line_price | round
        endif
        if item_line_discount_title != blank and item_line_discount_percent > 0
          assign item_has_product_discount = true
        endif
      endif
      if item_has_product_discount == false
        assign item_line_discount_title = blank
        assign item_line_discount_percent = 0
      endif
      capture item_original_line_price_formatted
        render 'sb-money-no-decimals', amount: item.original_line_price, currency: sb_cart_currency_code, context: 'cart'
      endcapture
      assign item_original_line_price_formatted = item_original_line_price_formatted | strip
      capture item_final_line_price_formatted
        render 'sb-money-no-decimals', amount: item.final_line_price, currency: sb_cart_currency_code, context: 'cart'
      endcapture
      assign item_final_line_price_formatted = item_final_line_price_formatted | strip
    %}
    <li
      class="sb-cart-line"
      data-cart-line="{{ item_line }}"
      {% if item_key != blank %}
        data-cart-item-key="{{ item_key | escape }}"
      {% endif %}
      {% if item.variant_id != blank %}
        data-cart-variant-id="{{ item.variant_id }}"
      {% endif %}
      {% if item_hover_image != blank %}
        data-cart-hover-image="{{ item_hover_image | escape }}"
      {% endif %}
    >
      <a
        class="sb-cart-line__media{% if item_hover_image != blank %} sb-cart-line__media--has-hover{% endif %}"
        href="{{ item.url }}"
      >
        {% # theme-check-disable RemoteAsset %}
        {% if item_image != blank %}
          <img class="sb-cart-line__image sb-cart-line__image--primary" src="{{ item_image }}" alt="{{ item_title | escape }}" loading="lazy" width="128" height="128">
        {% else %}
          <img
            class="sb-cart-line__image sb-cart-line__image--primary"
            src="{{ sb_cart_placeholder_image }}"
            alt="{{ item_title | escape }}"
            loading="lazy"
            width="128"
            height="128"
          >
        {% endif %}
        {% if item_hover_image != blank %}
          <img
            class="sb-cart-line__image sb-cart-line__image--hover"
            src="{{ item_hover_image }}"
            alt=""
            loading="lazy"
            width="128"
            height="128"
            aria-hidden="true"
          >
        {% endif %}
        {% # theme-check-enable RemoteAsset %}
      </a>
      <div class="sb-cart-line__content">
        <div class="sb-cart-line__meta">
          <a class="sb-cart-line__title font-caption weight-bold" href="{{ item.url }}">{{ item_title }}</a>
          {% if item_has_product_discount %}
            <p class="sb-cart-line__discount-label font-caption weight-regular" data-cart-line-discount-label>
              {{ 'sb.cart.discount_with_percent' | t: code: item_line_discount_title, percent: item_line_discount_percent }}
            </p>
          {% endif %}
          {% if item_variant != blank %}
            <p class="sb-cart-line__variant font-caption weight-regular">{{ item_variant }}</p>
          {% endif %}
          <div class="sb-cart-line__price-group">
            {% if item_has_discount %}
              <p
                class="sb-cart-line__price{% if item_has_product_discount %} sb-cart-line__price--compare{% endif %} sb-cart-shimmer-text font-caption weight-regular"
                data-cart-line-price
                data-shimmer-value="{{ item_original_line_price_formatted | escape }}"
              >
                {{ item_original_line_price_formatted }}
              </p>
              <p
                class="sb-cart-line__discount-price sb-cart-shimmer-text font-caption weight-regular"
                data-cart-line-discount-price
                data-shimmer-value="{{ item_final_line_price_formatted | escape }}"
              >
                {{ item_final_line_price_formatted }}
              </p>
            {% else %}
              <p
                class="sb-cart-line__price sb-cart-shimmer-text font-caption weight-regular"
                data-cart-line-price
                data-shimmer-value="{{ item_final_line_price_formatted | escape }}"
              >
                {{ item_final_line_price_formatted }}
              </p>
            {% endif %}
          </div>
        </div>
        <div class="sb-cart-line__controls">
          <div class="sb-cart-quantity" role="group" aria-label="{{ 'sb.cart.quantity' | t }}">
            <button
              type="button"
              class="sb-cart-quantity__button"
              data-cart-qty-minus
              aria-label="{{ 'sb.cart.decrease_quantity' | t }}"
              {% if item.quantity <= 1 %}
                disabled
                aria-disabled="true"
              {% endif %}
            >
              <span class="sb-cart-quantity__icon sb-cart-quantity__icon--minus" aria-hidden="true">
                {{ 'icon-quantity-remove.svg' | inline_asset_content }}
              </span>
            </button>
            <input
              class="sb-cart-quantity__input font-caption weight-bold"
              data-cart-qty-input
              type="number"
              min="1"
              step="1"
              inputmode="numeric"
              value="{{ item.quantity }}"
              aria-label="{{ 'sb.cart.quantity' | t }}"
            >
            <button type="button" class="sb-cart-quantity__button" data-cart-qty-plus aria-label="{{ 'sb.cart.increase_quantity' | t }}">
              <span class="sb-cart-quantity__icon sb-cart-quantity__icon--plus" aria-hidden="true">
                {{ 'icon-accordion-add.svg' | inline_asset_content }}
              </span>
            </button>
          </div>
          <button type="button" class="sb-cart-line__remove" data-cart-remove aria-label="{{ 'sb.cart.remove_item' | t }}">
            <span class="sb-cart-line__remove-icon" aria-hidden="true">{{ 'icon-cart-delete.svg' | inline_asset_content }}</span>
          </button>
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
