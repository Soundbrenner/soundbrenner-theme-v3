{% liquid
  assign sb_cart_checkout_mode = checkout_mode | default: 'link'
  assign sb_cart_show_clear = show_clear
  if sb_cart_show_clear == blank
    assign sb_cart_show_clear = false
  endif
  assign sb_cart_show_top_divider = show_top_divider | default: false
  assign sb_cart_shipping_text = shipping_text | default: 'Ships worldwide'
  assign sb_cart_taxes_text = taxes_text | default: 'May be due on delivery'
  assign sb_cart_summary_class = summary_class | default: 'sb-cart-summary'
  assign sb_cart_payment_list_class = payment_list_class | default: 'sb-cart-summary__payment-list'
  assign sb_cart_payment_item_class = payment_item_class | default: 'sb-cart-summary__payment-item'

  assign sb_cart_subtotal_cents = cart.items_subtotal_price | default: cart.total_price | default: cart.original_total_price | plus: 0
  assign sb_cart_primary_discount_title = ''
  assign sb_cart_primary_discount_value_type = ''
  assign sb_cart_primary_discount_value = blank
  assign sb_cart_discount_amount_cents = 0

  for discount_application in cart.cart_level_discount_applications
    assign discount_title = discount_application.title | default: '' | strip
    if discount_title == blank
      continue
    endif
    assign discount_title_upcase = discount_title | upcase
    assign discount_type = discount_application.type | default: '' | downcase
    assign discount_amount_cents = 0
    for item in cart.items
      for allocation in item.line_level_discount_allocations
        assign allocation_title = allocation.discount_application.title | default: '' | strip
        assign allocation_title_upcase = allocation_title | upcase
        assign allocation_type = allocation.discount_application.type | default: '' | downcase
        if allocation_title_upcase == discount_title_upcase and allocation_type == discount_type
          assign discount_amount_cents = discount_amount_cents | plus: allocation.amount
        endif
      endfor
    endfor
    if discount_amount_cents <= 0
      assign discount_total_allocated_amount_cents = discount_application.total_allocated_amount | plus: 0
      if discount_total_allocated_amount_cents > 0
        assign discount_amount_cents = discount_total_allocated_amount_cents
      endif
    endif
    if discount_type == 'discount_code' and discount_amount_cents > 0
      assign sb_cart_primary_discount_title = discount_title
      assign sb_cart_primary_discount_value_type = discount_application.value_type | default: '' | downcase
      assign sb_cart_primary_discount_value = discount_application.value
      assign sb_cart_discount_amount_cents = discount_amount_cents | round
      break
    endif
  endfor

  if sb_cart_discount_amount_cents <= 0
    for discount_application in cart.cart_level_discount_applications
      assign discount_title = discount_application.title | default: '' | strip
      if discount_title == blank
        continue
      endif
      assign discount_title_upcase = discount_title | upcase
      assign discount_type = discount_application.type | default: '' | downcase
      assign discount_amount_cents = 0
      for item in cart.items
        for allocation in item.line_level_discount_allocations
          assign allocation_title = allocation.discount_application.title | default: '' | strip
          assign allocation_title_upcase = allocation_title | upcase
          assign allocation_type = allocation.discount_application.type | default: '' | downcase
          if allocation_title_upcase == discount_title_upcase and allocation_type == discount_type
            assign discount_amount_cents = discount_amount_cents | plus: allocation.amount
          endif
        endfor
      endfor
      if discount_amount_cents <= 0
        assign discount_total_allocated_amount_cents = discount_application.total_allocated_amount | plus: 0
        if discount_total_allocated_amount_cents > 0
          assign discount_amount_cents = discount_total_allocated_amount_cents
        endif
      endif
      if discount_amount_cents > 0
        assign sb_cart_primary_discount_title = discount_title
        assign sb_cart_primary_discount_value_type = discount_application.value_type | default: '' | downcase
        assign sb_cart_primary_discount_value = discount_application.value
        assign sb_cart_discount_amount_cents = discount_amount_cents | round
        break
      endif
    endfor
  endif

  assign sb_cart_has_auto_discount = false
  if sb_cart_discount_amount_cents > 0
    assign sb_cart_has_auto_discount = true
  endif

  assign sb_cart_discount_codes = cart.cart_level_discount_applications | where: 'type', 'discount_code' | map: 'title'
  for item in cart.items
    for allocation in item.line_level_discount_allocations
      if allocation.discount_application.type == 'discount_code'
        assign sb_cart_line_discount_code = allocation.discount_application.title | default: '' | strip
        if sb_cart_line_discount_code != blank
          assign sb_cart_discount_codes = sb_cart_line_discount_code | split: '|' | concat: sb_cart_discount_codes
        endif
      endif
    endfor
  endfor
  assign sb_cart_discount_codes = sb_cart_discount_codes | uniq

  assign sb_cart_discount_code = sb_cart_primary_discount_title | default: '' | upcase | strip
  if sb_cart_discount_code == blank
    assign sb_cart_discount_code = sb_cart_discount_codes | first | default: ''
  endif
  if sb_cart_discount_code == blank
    for discount_application in cart.cart_level_discount_applications
      assign discount_title_fallback = discount_application.title | default: '' | strip
      if discount_title_fallback != blank
        assign sb_cart_discount_code = discount_title_fallback
        break
      endif
    endfor
  endif
  if sb_cart_discount_code == blank
    for item in cart.items
      for allocation in item.line_level_discount_allocations
        assign sb_cart_line_discount_title = allocation.discount_application.title | default: '' | strip
        if sb_cart_line_discount_title != blank
          assign sb_cart_discount_code = sb_cart_line_discount_title
          break
        endif
      endfor
      if sb_cart_discount_code != blank
        break
      endif
    endfor
  endif
  assign sb_cart_discount_code = sb_cart_discount_code | upcase | strip
  if sb_cart_discount_code == blank
    assign sb_cart_discount_code = 'DISCOUNT'
  endif

  assign sb_cart_discount_percent = blank
  if sb_cart_primary_discount_value_type == 'percentage'
    assign sb_cart_primary_discount_value_number = sb_cart_primary_discount_value | plus: 0
    if sb_cart_primary_discount_value_number > 0
      assign sb_cart_discount_percent = sb_cart_primary_discount_value_number | round
    endif
  endif
  if sb_cart_discount_percent == blank and sb_cart_discount_amount_cents > 0
    assign sb_cart_discount_percent_base = cart.items_subtotal_price | plus: 0
    if sb_cart_discount_percent_base <= 0
      assign sb_cart_discount_percent_base = sb_cart_subtotal_cents
    endif
    if sb_cart_discount_percent_base > 0
      assign sb_cart_discount_percent = sb_cart_discount_amount_cents | times: 100.0 | divided_by: sb_cart_discount_percent_base | round
    endif
  endif

  assign sb_cart_auto_discount_text = sb_cart_discount_code
  if sb_cart_discount_percent != blank
    assign sb_cart_auto_discount_text = sb_cart_auto_discount_text | append: ' (' | append: sb_cart_discount_percent | append: '% OFF)'
  endif
  assign sb_cart_auto_discount_amount = sb_cart_discount_amount_cents | money
  assign sb_cart_subtotal_display = sb_cart_subtotal_cents | money
%}

<div class="{{ sb_cart_summary_class }}">
  {% if sb_cart_show_top_divider %}
    <div class="sb-cart-summary__divider" aria-hidden="true"></div>
  {% endif %}

  <p class="sb-cart-summary__row sb-cart-summary__row--shipping font-caption weight-regular">
    <span class="sb-cart-summary__row-leading">
      <span class="sb-cart-summary__icon sb-cart-summary__icon--shipping" aria-hidden="true">
        {{ 'icon-purchase-guarantee-shipping-no-padding.svg' | inline_asset_content }}
      </span>
      <span>{{ sb_cart_shipping_text }}</span>
    </span>
  </p>

  <p class="sb-cart-summary__row font-caption weight-regular">
    <span>Subtotal</span>
    <span class="sb-cart-shimmer-text" data-cart-subtotal data-shimmer-value="{{ sb_cart_subtotal_display | escape }}">
      {{ sb_cart_subtotal_display }}
    </span>
  </p>

  <p class="sb-cart-summary__row font-caption weight-regular">
    <span>Taxes and duties</span>
    <span>{{ sb_cart_taxes_text }}</span>
  </p>

  <div
    class="sb-cart-summary__divider"
    data-cart-auto-discount-divider
    aria-hidden="true"
    {% unless sb_cart_has_auto_discount %}
      hidden
    {% endunless %}
  ></div>

  <p
    class="sb-cart-summary__row sb-cart-summary__row--discount-auto font-caption weight-regular"
    data-cart-auto-discount-row
    {% unless sb_cart_has_auto_discount %}
      hidden
    {% endunless %}
  >
    <span class="sb-cart-summary__row-leading">
      <span class="sb-cart-summary__icon sb-cart-summary__icon--discount" aria-hidden="true">
        {{ 'icon-discount-tag-outline.svg' | inline_asset_content }}
      </span>
      <span data-cart-auto-discount-text>{{ sb_cart_auto_discount_text }}</span>
    </span>
    <span class="sb-cart-shimmer-text" data-cart-auto-discount-amount data-shimmer-value="-{{ sb_cart_auto_discount_amount | escape }}">
      -{{ sb_cart_auto_discount_amount }}
    </span>
  </p>

  <div class="sb-cart-summary__divider" aria-hidden="true"></div>

  <details class="sb-cart-summary__discount" data-cart-discount-disclosure>
    <summary class="sb-cart-summary__row sb-cart-summary__row--discount-toggle font-caption weight-regular">
      <span>Discount</span>
      <span class="sb-cart-summary__toggle-icon" aria-hidden="true">
        <span class="sb-cart-summary__toggle-icon-plus">{{ 'icon-accordion-add.svg' | inline_asset_content }}</span>
        <span class="sb-cart-summary__toggle-icon-close">{{ 'icon-accordion-close.svg' | inline_asset_content }}</span>
      </span>
    </summary>
    <div class="sb-cart-summary__discount-body">
      <div class="sb-cart-summary__discount-body-inner">
        <form class="sb-cart-summary__discount-form" data-cart-discount-form>
          <input
            id="{{ discount_input_id }}"
            class="sb-cart-summary__discount-input font-caption weight-regular"
            type="text"
            name="discount"
            aria-label="Discount code"
            placeholder="Discount code"
            autocomplete="off"
            data-cart-discount-input
          >
          <button class="sb-cart-summary__discount-apply sb-button-radiant sb-button-radiant--medium font-caption weight-bold" type="submit">
            <span class="sb-button-radiant__label">Apply</span>
          </button>
        </form>
        <p
          class="sb-cart-summary__discount-error font-caption weight-regular"
          data-cart-discount-error
          data-discount-code-error="{{ 'cart.discount_code_error' | t | escape }}"
          data-shipping-discount-error="{{ 'cart.shipping_discount_error' | t | escape }}"
          hidden
        >
          <span class="sb-cart-summary__discount-error-icon" data-cart-discount-error-icon aria-hidden="true" hidden>
            {{ 'icon-error.svg' | inline_asset_content }}
          </span>
          <span data-cart-discount-error-text></span>
        </p>
        <ul class="sb-cart-discount-list" data-cart-discount-list>
          {% for discount_code in sb_cart_discount_codes %}
            {% assign discount_code_upper = discount_code | upcase %}
            <li class="sb-cart-discount-pill font-caption weight-bold">
              <span>{{ discount_code_upper }}</span>
              <button
                type="button"
                class="sb-cart-discount-pill__remove"
                data-cart-discount-remove="{{ discount_code_upper | escape }}"
                aria-label="Remove {{ discount_code_upper | escape }}"
              >
                <span class="sb-cart-discount-pill__remove-icon" aria-hidden="true">
                  {{ 'icon-cancel.svg' | inline_asset_content }}
                </span>
              </button>
            </li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </details>

  <div class="sb-cart-summary__divider" aria-hidden="true"></div>

  <p class="sb-cart-summary__row sb-cart-summary__row--total font-caption weight-bold">
    <span>Total</span>
    <span class="sb-cart-shimmer-text" data-cart-total data-shimmer-value="{{ cart.total_price | money | escape }}">
      {{ cart.total_price | money }}
    </span>
  </p>

  <div class="sb-cart-summary__checkout-group">
    {% if sb_cart_checkout_mode == 'form' %}
      <form action="{{ routes.cart_url }}" method="post" class="sb-cart-summary__checkout-form">
        <button
          type="submit"
          class="{{ checkout_button_class }} sb-button-radiant sb-button-radiant--large sb-button-radiant--leading-icon font-caption weight-bold sb-cart-summary__checkout-button"
          name="checkout"
          data-cart-checkout-button
        >
          <span class="sb-button-radiant__icon" aria-hidden="true">
            <span class="sb-cart-summary__checkout-icon">{{ 'icon-checkout-lock.svg' | inline_asset_content }}</span>
          </span>
          <span class="sb-button-radiant__label">Secure checkout</span>
        </button>
      </form>
    {% else %}
      {% assign checkout_url = routes.root_url | append: 'checkout' %}
      <a
        class="{{ checkout_button_class }} sb-button-radiant sb-button-radiant--large sb-button-radiant--leading-icon font-caption weight-bold sb-cart-summary__checkout-button"
        href="{{ checkout_url }}"
        data-cart-checkout-button
      >
        <span class="sb-button-radiant__icon" aria-hidden="true">
          <span class="sb-cart-summary__checkout-icon">{{ 'icon-checkout-lock.svg' | inline_asset_content }}</span>
        </span>
        <span class="sb-button-radiant__label">Secure checkout</span>
      </a>
    {% endif %}

    {% render 'sb-cart-payment-icons', list_class: sb_cart_payment_list_class, item_class: sb_cart_payment_item_class %}
  </div>

  {% if sb_cart_show_clear %}
    <button type="button" class="{{ clear_button_class }}" data-cart-clear>Clear cart</button>
  {% endif %}
</div>
