{% javascript %}
  (() => {
    const stacks = Array.from(document.querySelectorAll('[data-sb-blog-sticky-stack]'));
    const stickyNavWraps = Array.from(document.querySelectorAll('.sb-blog-overview__sticky-nav-wrap'));
    const blogFilterDropdowns = Array.from(document.querySelectorAll('[data-sb-blog-filter-dropdown]'));
    const blogFilterBackdrops = Array.from(document.querySelectorAll('[data-sb-blog-filter-backdrop]'));
    const headerElement = document.querySelector('.header');
    if (!stacks.length && !stickyNavWraps.length && !blogFilterDropdowns.length && !blogFilterBackdrops.length) return;

    const parseSpaceVar = (name, fallback) => {
      const rawValue = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      const parsed = Number.parseFloat(rawValue);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const getSidebarStickyTop = (stack) => {
      const defaultTop = 112;
      const menuGap = 36;
      const isDesktopSidebar = window.matchMedia('(min-width: 990px)').matches;
      if (!isDesktopSidebar) return defaultTop;

      const section = stack.closest('.sb-blog-overview');
      const stickyNavWrap = section
        ? Array.from(section.querySelectorAll('.sb-blog-overview__sticky-nav-wrap')).find((wrap) => wrap.getClientRects().length > 0)
        : null;
      const stickyNav = stickyNavWrap?.querySelector('.sb-blog-overview__sticky-nav');
      if (!stickyNavWrap || !stickyNav || stickyNavWrap.getClientRects().length === 0) return defaultTop;

      const navBottom = stickyNav.getBoundingClientRect().bottom;
      return Math.max(defaultTop, Math.round(navBottom + menuGap));
    };

    const syncSidebarStickyTops = () => {
      stacks.forEach((stack) => {
        const nextTopValue = `${getSidebarStickyTop(stack)}px`;
        const currentTopValue = stack.style.getPropertyValue('--sb-sidebar-sticky-top');
        if (currentTopValue !== nextTopValue) {
          stack.style.setProperty('--sb-sidebar-sticky-top', nextTopValue);
        }
      });
    };

    const syncStickyBlogNavTop = () => {
      if (!stickyNavWraps.length) return;
      if (!headerElement) {
        stickyNavWraps.forEach((wrap) => {
          const spacing = Number.parseFloat(getComputedStyle(wrap).getPropertyValue('--sb-blog-sticky-top-gap')) || 16;
          const fallbackTop = `${Math.round(spacing)}px`;
          if (wrap.style.top !== fallbackTop) {
            wrap.style.top = fallbackTop;
          }
        });
        return;
      }

      const headerStyles = getComputedStyle(headerElement);
      const headerBorderBottom = Number.parseFloat(headerStyles.borderBottomWidth) || 0;
      const headerBottom = headerElement.getBoundingClientRect().bottom - headerBorderBottom;
      stickyNavWraps.forEach((wrap) => {
        const spacing = Number.parseFloat(getComputedStyle(wrap).getPropertyValue('--sb-blog-sticky-top-gap')) || 16;
        const nextTop = Math.max(headerBottom + spacing, spacing);
        const nextTopValue = `${Math.floor(nextTop)}px`;
        if (wrap.style.top !== nextTopValue) {
          wrap.style.top = nextTopValue;
        }
      });
    };

    const syncStickyBlogNavMetrics = () => {
      if (!stickyNavWraps.length) return;
      const baseGap = parseSpaceVar('--sb-space-128', 128);
      const isDesktopViewport = window.matchMedia('(min-width: 990px)').matches;

      const sections = Array.from(
        new Set(
          stickyNavWraps
            .map((wrap) => wrap.closest('.sb-blog-overview'))
            .filter(Boolean)
        )
      );

      sections.forEach((section) => {
        const activeWrap = stickyNavWraps.find(
          (wrap) => wrap.closest('.sb-blog-overview') === section && wrap.getClientRects().length > 0
        );
        let nextOffset = baseGap;

        if (isDesktopViewport && activeWrap) {
          const stickyNav = activeWrap.querySelector('.sb-blog-overview__sticky-nav');
          if (stickyNav && stickyNav.getClientRects().length > 0) {
            const stickyNavStyles = getComputedStyle(stickyNav);
            const stickyPaddingTop = Number.parseFloat(stickyNavStyles.paddingTop) || 0;
            const stickyPaddingBottom = Number.parseFloat(stickyNavStyles.paddingBottom) || 0;
            const singleRowHeight = stickyPaddingTop + 36 + stickyPaddingBottom;
            const stickyNavHeight = stickyNav.getBoundingClientRect().height;
            const wrappedRowsOffset = Math.max(0, stickyNavHeight - singleRowHeight);
            nextOffset += wrappedRowsOffset;
          }
        }

        const nextOffsetValue = activeWrap ? `${Math.round(nextOffset)}px` : '0px';
        const currentOffsetValue = section.style.getPropertyValue('--sb-blog-sticky-first-offset');
        if (currentOffsetValue !== nextOffsetValue) {
          section.style.setProperty('--sb-blog-sticky-first-offset', nextOffsetValue);
        }
      });
    };

    const closeBlogFilterDropdown = (dropdown, { returnFocus = false } = {}) => {
      if (!dropdown || dropdown.getAttribute('data-open') !== 'true') return;

      const trigger = dropdown.querySelector('[data-sb-blog-filter-trigger]');
      const panel = dropdown.querySelector('[data-sb-blog-filter-panel]');
      if (!trigger || !panel) return;

      trigger.setAttribute('aria-expanded', 'false');
      dropdown.removeAttribute('data-open');
      panel.classList.add('is-closing');
      panel.classList.remove('is-active');
      updateBlogFilterBackdropState();

      let closeSettled = false;
      const finalizeClose = (event) => {
        if (event && event.target !== panel) return;
        if (event && event.propertyName !== 'grid-template-rows' && event.propertyName !== 'transform') return;
        if (closeSettled || dropdown.getAttribute('data-open') === 'true') return;
        closeSettled = true;
        panel.removeEventListener('transitionend', finalizeClose);
        panel.classList.remove('is-closing');
        if (returnFocus) trigger.focus();
      };

      panel.addEventListener('transitionend', finalizeClose);
      window.setTimeout(finalizeClose, 620);
    };

    const closeAllBlogFilterDropdowns = ({ except = null } = {}) => {
      blogFilterDropdowns.forEach((dropdown) => {
        if (dropdown === except) return;
        closeBlogFilterDropdown(dropdown);
      });
    };

    const updateBlogFilterBackdropState = () => {
      if (!blogFilterBackdrops.length) return;
      const hasOpenDropdown = blogFilterDropdowns.some((dropdown) => dropdown.getAttribute('data-open') === 'true');
      blogFilterBackdrops.forEach((backdrop) => {
        backdrop.classList.toggle('is-active', hasOpenDropdown);
      });
      document.documentElement.classList.toggle('is-blog-filter-open', hasOpenDropdown);
      if (document.body) {
        document.body.classList.toggle('is-blog-filter-open', hasOpenDropdown);
      }
    };

    const openBlogFilterDropdown = (dropdown) => {
      if (!dropdown || dropdown.getAttribute('data-open') === 'true') return;

      const trigger = dropdown.querySelector('[data-sb-blog-filter-trigger]');
      const panel = dropdown.querySelector('[data-sb-blog-filter-panel]');
      if (!trigger || !panel) return;

      closeAllBlogFilterDropdowns({ except: dropdown });
      trigger.setAttribute('aria-expanded', 'true');
      dropdown.setAttribute('data-open', 'true');
      panel.classList.remove('is-closing');
      panel.classList.add('is-active');
      updateBlogFilterBackdropState();
    };

    const handleBlogFilterDropdownDocumentClick = (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (blogFilterDropdowns.some((dropdown) => dropdown.contains(target))) return;
      closeAllBlogFilterDropdowns();
    };

    const handleBlogFilterDropdownKeyUp = (event) => {
      if (event.key !== 'Escape') return;
      const openDropdown = blogFilterDropdowns.find((dropdown) => dropdown.getAttribute('data-open') === 'true');
      if (!openDropdown) return;
      closeBlogFilterDropdown(openDropdown, { returnFocus: true });
    };

    if (blogFilterDropdowns.length) {
      blogFilterDropdowns.forEach((dropdown) => {
        const trigger = dropdown.querySelector('[data-sb-blog-filter-trigger]');
        const panel = dropdown.querySelector('[data-sb-blog-filter-panel]');
        if (!trigger || !panel) return;
        const closeButtons = Array.from(panel.querySelectorAll('[data-sb-blog-filter-close]'));

        dropdown.removeAttribute('data-open');
        panel.classList.remove('is-active');
        panel.classList.remove('is-closing');
        trigger.setAttribute('aria-expanded', 'false');

        closeButtons.forEach((closeButton) => {
          closeButton.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            closeBlogFilterDropdown(dropdown, { returnFocus: true });
          });
        });

        trigger.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          if (dropdown.getAttribute('data-open') === 'true') {
            closeBlogFilterDropdown(dropdown);
            return;
          }
          openBlogFilterDropdown(dropdown);
        });
      });

      document.addEventListener('click', handleBlogFilterDropdownDocumentClick);
      document.addEventListener('keyup', handleBlogFilterDropdownKeyUp);
      blogFilterBackdrops.forEach((backdrop) => {
        backdrop.addEventListener('click', () => {
          closeAllBlogFilterDropdowns();
          updateBlogFilterBackdropState();
        });
      });
      window.addEventListener('resize', () => {
        closeAllBlogFilterDropdowns();
        updateBlogFilterBackdropState();
      });

      updateBlogFilterBackdropState();
    }

    const applyStickyLayout = () => {
      const gap = parseSpaceVar('--sb-space-30', 30);
      const isMobileViewport = window.matchMedia('(max-width: 989px)').matches;
      syncSidebarStickyTops();

      stacks.forEach((stack) => {
        const cards = Array.from(stack.querySelectorAll('[data-sb-sidebar-sticky-card]'));
        const phaseOne = stack.querySelector('[data-sb-sidebar-phase-1]');
        const phaseTwo = stack.querySelector('[data-sb-sidebar-phase-2]');
        const hasHandoff = stack.classList.contains('sb-blog-overview__sidebar-stack--handoff');

        if (phaseOne) phaseOne.style.height = '';
        if (phaseTwo) {
          phaseTwo.style.top = '';
          phaseTwo.style.bottom = '';
        }

        if (!cards.length || isMobileViewport) return;

        // Single-card sidebar: make phase 1 fill the sidebar so sticky has runway.
        if (!hasHandoff) {
          if (phaseOne) phaseOne.style.height = '100%';
          return;
        }

        const firstCard = cards[0] || null;
        const secondCard = cards[1] || null;
        if (!firstCard || !secondCard || !phaseOne || !phaseTwo) return;

        const layout = stack.closest('.sb-blog-overview__layout');
        const thirdRowAnchor = layout?.querySelector('[data-sb-third-row-anchor]');
        let phaseTwoTop = firstCard.offsetHeight + gap;

        if (thirdRowAnchor) {
          const stackTop = stack.getBoundingClientRect().top + window.scrollY;
          const anchorTop = thirdRowAnchor.getBoundingClientRect().top + window.scrollY;
          const anchorOffset = Math.max(0, anchorTop - stackTop);
          phaseTwoTop = Math.max(0, anchorOffset);
        }

        phaseTwo.style.top = `${phaseTwoTop}px`;
        phaseTwo.style.bottom = '0';

        // End phase 1 slightly before phase 2 reaches the same sticky line,
        // so card 1 releases when there is still the desired gap to card 2.
        const phaseOneHeight = phaseTwoTop - gap;
        phaseOne.style.height = `${Math.max(firstCard.offsetHeight, phaseOneHeight)}px`;
      });
    };

    let frameRequested = false;
    const requestStickyLayoutUpdate = () => {
      if (frameRequested) return;
      frameRequested = true;
      window.requestAnimationFrame(() => {
        frameRequested = false;
        syncStickyBlogNavTop();
        applyStickyLayout();
        syncStickyBlogNavMetrics();
      });
    };

    window.addEventListener(
      'scroll',
      () => {
        syncStickyBlogNavTop();
        syncSidebarStickyTops();
      },
      { passive: true }
    );
    window.addEventListener('resize', () => {
      requestStickyLayoutUpdate();
    });
    window.addEventListener('load', () => {
      requestStickyLayoutUpdate();
    });

    if (headerElement) {
      const headerObserver = new MutationObserver(() => {
        requestStickyLayoutUpdate();
      });
      headerObserver.observe(headerElement, { attributes: true, attributeFilter: ['class', 'style'] });
    }

    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(requestStickyLayoutUpdate);
      observer.observe(document.body);
      stacks.forEach((stack) => {
        observer.observe(stack);
      });
      if (headerElement) observer.observe(headerElement);
      stickyNavWraps.forEach((wrap) => {
        observer.observe(wrap);
      });
    }

    requestStickyLayoutUpdate();
  })();
{% endjavascript %}

