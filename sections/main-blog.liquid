{% liquid
  assign posts_per_page = 15
%}

<section class="sb-blog-overview">
  <div class="sb-blog-overview__inner">
    {% paginate blog.articles by posts_per_page %}
      {% liquid
        assign active_tag_handle = ''
        assign blog_page_title = 'Blog'
        assign has_product_tag_filters = false
        assign has_instrument_tag_filters = false
        assign active_tag_is_product_filter = false
        assign active_tag_is_instrument_filter = false
        assign active_product_filter_label = ''
        assign active_instrument_filter_label = ''
        assign active_dropdown_tag_label = ''
        assign popular_heading = 'Most popular'
        if current_tags != blank
          assign active_tag_handle = current_tags.first | handleize
          case active_tag_handle
            when 'company-news'
              assign blog_page_title = 'Company news'
            when 'music-insights'
              assign blog_page_title = 'Music insights'
            when 'product-insights', 'product-tips'
              assign blog_page_title = 'Product tips'
            when 'gift-guides'
              assign blog_page_title = 'Gift guides'
            else
              assign blog_page_title = current_tags.first
          endcase
        endif
      %}

      {% capture product_tag_filter_options %}
        {% for tag in blog.all_tags %}
          {% liquid
            assign tag_value = tag | strip
            assign tag_value_handle = tag_value | handleize
            assign tag_value_downcase = tag_value | downcase
            assign tag_prefix = tag_value_downcase | slice: 0, 10
            assign option_label = ''

            if tag_prefix == 'by_product'
              assign option_label = tag_value | slice: 10, tag_value.size
              assign leading_char = option_label | slice: 0, 1
              if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
                assign option_label = option_label | slice: 1, option_label.size
              endif
              assign option_label = option_label | strip
              if option_label == blank
                assign option_label = tag_value
              endif
            endif
          %}

          {% if option_label != blank %}
            {% liquid
              assign has_product_tag_filters = true
              assign option_is_active = false
              if active_tag_handle == tag_value_handle
                assign option_is_active = true
                assign active_tag_is_product_filter = true
                assign active_product_filter_label = option_label
                assign active_dropdown_tag_label = option_label
              endif
            %}
            <a
              class="sb-blog-overview__sticky-filter-option font-caption weight-semibold{% if option_is_active %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/{{ tag_value_handle }}"
            >
              {{ option_label | escape }}
            </a>
          {% endif %}
        {% endfor %}
      {% endcapture %}

      {% capture instrument_tag_filter_options %}
        {% for tag in blog.all_tags %}
          {% liquid
            assign tag_value = tag | strip
            assign tag_value_handle = tag_value | handleize
            assign tag_value_downcase = tag_value | downcase
            assign tag_prefix = tag_value_downcase | slice: 0, 13
            assign option_label = ''

            if tag_prefix == 'by_instrument'
              assign option_label = tag_value | slice: 13, tag_value.size
              assign leading_char = option_label | slice: 0, 1
              if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
                assign option_label = option_label | slice: 1, option_label.size
              endif
              assign option_label = option_label | strip
              if option_label == blank
                assign option_label = tag_value
              endif
            endif
          %}

          {% if option_label != blank %}
            {% liquid
              assign has_instrument_tag_filters = true
              assign option_is_active = false
              if active_tag_handle == tag_value_handle
                assign option_is_active = true
                assign active_tag_is_instrument_filter = true
                assign active_instrument_filter_label = option_label
                assign active_dropdown_tag_label = option_label
              endif
            %}
            <a
              class="sb-blog-overview__sticky-filter-option font-caption weight-semibold{% if option_is_active %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/{{ tag_value_handle }}"
            >
              {{ option_label | escape }}
            </a>
          {% endif %}
        {% endfor %}
      {% endcapture %}

      {% if active_dropdown_tag_label != blank %}
        {% assign blog_page_title = active_dropdown_tag_label %}
      {% endif %}

      {% liquid
        assign mobile_categories_trigger_label = 'Categories'
        if active_tag_handle != blank
          assign mobile_categories_trigger_label = blog_page_title
        endif
      %}

      <div class="sb-blog-overview__sticky-nav-wrap sb-blog-overview__sticky-nav-wrap--desktop" aria-label="Sticky blog navigation">
        <div class="sb-blog-overview__sticky-nav">
          <div class="sb-blog-overview__sticky-nav-left" aria-label="Blog category filters">
            <a
              class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == blank %} is-active{% endif %}"
              href="{{ blog.url }}"
            >
              All
            </a>
            <a
              class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'company-news' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/company-news"
            >
              Company news
            </a>
            <a
              class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'music-insights' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/music-insights"
            >
              Music insights
            </a>
            <a
              class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'product-insights' or active_tag_handle == 'product-tips' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/product-tips"
            >
              Product tips
            </a>
            <a
              class="sb-blog-overview__sticky-filter font-caption{% if active_tag_handle == 'gift-guides' %} is-active{% endif %}"
              href="{{ blog.url }}/tagged/gift-guides"
            >
              Gift guides
            </a>

            {% if has_product_tag_filters %}
              <div class="sb-blog-overview__sticky-dropdown" data-sb-blog-filter-dropdown>
                <button
                  type="button"
                  class="sb-blog-overview__sticky-filter sb-blog-overview__sticky-filter--dropdown font-caption{% if active_tag_is_product_filter %} is-active{% endif %}"
                  aria-expanded="false"
                  aria-controls="SbBlogByProductPanel-{{ section.id }}"
                  data-sb-blog-filter-trigger
                >
                  <span>{% if active_product_filter_label != blank %}{{ active_product_filter_label | escape }}{% else %}By product{% endif %}</span>
                  <span class="sb-blog-overview__sticky-filter-caret" aria-hidden="true">
                    {{ 'icon-chevron.svg' | inline_asset_content }}
                  </span>
                </button>
                <div
                  id="SbBlogByProductPanel-{{ section.id }}"
                  class="sb-blog-overview__sticky-filter-panel"
                  data-sb-blog-filter-panel
                >
                  <div class="sb-blog-overview__sticky-filter-panel-surface">
                    <div class="sb-blog-overview__sticky-filter-panel-inner">
                      {{ product_tag_filter_options }}
                    </div>
                  </div>
                </div>
              </div>
            {% endif %}

            {% if has_instrument_tag_filters %}
              <div class="sb-blog-overview__sticky-dropdown" data-sb-blog-filter-dropdown>
                <button
                  type="button"
                  class="sb-blog-overview__sticky-filter sb-blog-overview__sticky-filter--dropdown font-caption{% if active_tag_is_instrument_filter %} is-active{% endif %}"
                  aria-expanded="false"
                  aria-controls="SbBlogByInstrumentPanel-{{ section.id }}"
                  data-sb-blog-filter-trigger
                >
                  <span>{% if active_instrument_filter_label != blank %}{{ active_instrument_filter_label | escape }}{% else %}By instrument{% endif %}</span>
                  <span class="sb-blog-overview__sticky-filter-caret" aria-hidden="true">
                    {{ 'icon-chevron.svg' | inline_asset_content }}
                  </span>
                </button>
                <div
                  id="SbBlogByInstrumentPanel-{{ section.id }}"
                  class="sb-blog-overview__sticky-filter-panel"
                  data-sb-blog-filter-panel
                >
                  <div class="sb-blog-overview__sticky-filter-panel-surface">
                    <div class="sb-blog-overview__sticky-filter-panel-inner">
                      {{ instrument_tag_filter_options }}
                    </div>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
          {%
            render 'radiant-button',
            link: routes.all_products_collection_url,
            label: 'Explore our shop',
            size: 'medium',
            extra_class: 'sb-blog-overview__sticky-nav-shop-button font-caption weight-bold'
          %}
        </div>
      </div>
      <div class="sb-blog-overview__sticky-nav-wrap sb-blog-overview__sticky-nav-wrap--mobile" aria-label="Sticky blog navigation">
        <div class="sb-blog-overview__sticky-nav sb-blog-overview__sticky-nav--mobile">
          <div class="sb-blog-overview__sticky-dropdown" data-sb-blog-filter-dropdown>
            <button
              type="button"
              class="sb-blog-overview__sticky-filter sb-blog-overview__sticky-filter--dropdown sb-blog-overview__sticky-filter--mobile font-caption{% if active_tag_handle != blank %} is-active{% endif %}"
              aria-expanded="false"
              aria-controls="SbBlogCategoriesPanel-{{ section.id }}"
              data-sb-blog-filter-trigger
            >
              <span>{{ mobile_categories_trigger_label | escape }}</span>
              <span class="sb-blog-overview__sticky-filter-caret" aria-hidden="true">
                {{ 'icon-chevron.svg' | inline_asset_content }}
              </span>
            </button>
            <div
              id="SbBlogCategoriesPanel-{{ section.id }}"
              class="sb-blog-overview__sticky-filter-panel sb-blog-overview__sticky-filter-panel--mobile"
              data-sb-blog-filter-panel
            >
              <div class="sb-blog-overview__sticky-filter-panel-surface">
                <div class="sb-blog-overview__sticky-filter-panel-inner sb-blog-overview__sticky-filter-panel-inner--mobile">
                  <div class="sb-blog-overview__sticky-filter-panel-header">
                    <button
                      type="button"
                      class="sb-blog-overview__sticky-filter-close"
                      data-sb-blog-filter-close
                      aria-label="Close categories"
                    >
                      <span class="sb-blog-overview__sticky-filter-close-icon" aria-hidden="true">
                        {{ 'icon-cancel.svg' | inline_asset_content }}
                      </span>
                    </button>
                    <p class="sb-blog-overview__sticky-filter-panel-title font-callout weight-bold">Categories</p>
                  </div>

                  <div class="sb-blog-overview__sticky-filter-panel-list">
                    <a
                      class="sb-blog-overview__sticky-filter-option font-caption{% if active_tag_handle == blank %} is-active{% endif %}"
                      href="{{ blog.url }}"
                    >
                      All
                    </a>
                    <a
                      class="sb-blog-overview__sticky-filter-option font-caption{% if active_tag_handle == 'company-news' %} is-active{% endif %}"
                      href="{{ blog.url }}/tagged/company-news"
                    >
                      Company news
                    </a>
                    <a
                      class="sb-blog-overview__sticky-filter-option font-caption{% if active_tag_handle == 'music-insights' %} is-active{% endif %}"
                      href="{{ blog.url }}/tagged/music-insights"
                    >
                      Music insights
                    </a>
                    <a
                      class="sb-blog-overview__sticky-filter-option font-caption{% if active_tag_handle == 'product-insights' or active_tag_handle == 'product-tips' %} is-active{% endif %}"
                      href="{{ blog.url }}/tagged/product-tips"
                    >
                      Product tips
                    </a>
                    <a
                      class="sb-blog-overview__sticky-filter-option font-caption{% if active_tag_handle == 'gift-guides' %} is-active{% endif %}"
                      href="{{ blog.url }}/tagged/gift-guides"
                    >
                      Gift guides
                    </a>

                    {% if has_product_tag_filters %}
                      <span class="sb-blog-overview__sticky-filter-option sb-blog-overview__sticky-filter-option--group font-caption">
                        By product
                      </span>
                      <div class="sb-blog-overview__sticky-filter-option-children">
                        {{ product_tag_filter_options }}
                      </div>
                    {% endif %}

                    {% if has_instrument_tag_filters %}
                      <span class="sb-blog-overview__sticky-filter-option sb-blog-overview__sticky-filter-option--group font-caption">
                        By instrument
                      </span>
                      <div class="sb-blog-overview__sticky-filter-option-children">
                        {{ instrument_tag_filter_options }}
                      </div>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="sb-blog-overview__sticky-backdrop" data-sb-blog-filter-backdrop aria-hidden="true"></div>

      {% if section.settings.show_blog_title %}
        <header class="sb-blog-overview__header">
          <p class="sb-blog-overview__eyebrow font-caption weight-regular">
            {% if paginate.current_page > 1 %}
              Archive
            {% else %}
              Latest
            {% endif %}
          </p>
          <h1 class="sb-blog-overview__title font-title weight-bold">{{ blog_page_title }}</h1>
        </header>
      {% endif %}

      {% liquid
        assign show_featured_layout = false
        if paginate.current_page == 1
          assign show_featured_layout = true
        endif

        assign archive_offset = 0
        if show_featured_layout
          assign archive_offset = 9
        endif

        assign has_three_articles = false
        if blog.articles[2] != blank
          assign has_three_articles = true
        endif
      %}

      {% capture sidebar_box_one_markup %}
        {% if show_featured_layout %}
          {% capture sidebar_popular_items_markup %}
            {% for item_index in (1..5) %}
              {% liquid
                assign article_key = 'sidebar_popular_item_' | append: item_index | append: '_article'
                assign selected_article = section.settings[article_key]
                assign item_title = ''
                assign item_url = ''

                assign fallback_index = item_index | minus: 1
                assign fallback_article = blog.articles[fallback_index]
                assign popular_icon_asset = 'icon-blog-popular-rank-' | append: item_index | append: '.svg'

                if selected_article != blank
                  assign item_title = selected_article.title
                  assign item_url = selected_article.url
                elsif fallback_article != blank
                  assign item_title = fallback_article.title
                  assign item_url = fallback_article.url
                endif
              %}

              {% if item_title != blank and item_url != blank %}
                <li class="sb-blog-sidebar-box__popular-item">
                  <a class="sb-blog-sidebar-box__popular-link font-body weight-semibold" href="{{ item_url }}">
                    <span
                      class="sb-blog-sidebar-box__popular-rank"
                      aria-hidden="true"
                      style="--sb-popular-rank-icon: url('{{ popular_icon_asset | asset_url }}');"
                    >
                      <span class="sb-blog-sidebar-box__popular-rank-icon"></span>
                    </span>
                    <span class="sb-blog-sidebar-box__popular-link-text">{{ item_title }}</span>
                  </a>
                </li>
              {% endif %}
            {% endfor %}
          {% endcapture %}

          {% if sidebar_popular_items_markup != blank %}
            <section class="sb-blog-sidebar-box sb-blog-sidebar-box--popular" aria-label="{{ popular_heading }}">
              <h3 class="sb-blog-sidebar-box__heading font-callout weight-bold">{{ popular_heading }}</h3>
              <ol class="sb-blog-sidebar-box__popular-list" role="list">
                {{ sidebar_popular_items_markup }}
              </ol>
            </section>
          {% endif %}
        {% endif %}
      {% endcapture %}

      {% capture sidebar_box_two_markup %}
        {% liquid
          assign promo_title = section.settings.sidebar_promo_title | strip
          assign promo_text = section.settings.sidebar_promo_text | strip
          assign promo_button_label = section.settings.sidebar_promo_button_label | strip
          assign promo_button_link = section.settings.sidebar_promo_button_link
        %}

        {% if promo_title != blank or promo_text != blank or promo_button_label != blank %}
          <section class="sb-blog-sidebar-box sb-blog-sidebar-box--promo" aria-label="{{ promo_title }}">
            {% if promo_title != blank %}
              <h3 class="sb-blog-sidebar-box__promo-title font-callout weight-bold">{{ promo_title }}</h3>
            {% endif %}

            {% if promo_text != blank %}
              <p class="sb-blog-sidebar-box__promo-text font-body weight-regular">{{ promo_text }}</p>
            {% endif %}

            {% if promo_button_label != blank and promo_button_link != blank %}
              <a class="sb-blog-sidebar-box__promo-button font-caption weight-bold" href="{{ promo_button_link }}">
                {{ promo_button_label }}
              </a>
            {% elsif promo_button_label != blank %}
              <span class="sb-blog-sidebar-box__promo-button font-caption weight-bold">
                {{ promo_button_label }}
              </span>
            {% endif %}
          </section>
        {% endif %}
      {% endcapture %}

      {% liquid
        assign sidebar_box_one_markup = sidebar_box_one_markup | strip
        assign sidebar_box_two_markup = sidebar_box_two_markup | strip
      %}

      <div class="sb-blog-overview__layout">
        <div class="sb-blog-overview__main-column">
          {% if show_featured_layout %}
            <div class="sb-blog-overview__featured" aria-label="Featured articles">
              <div class="sb-blog-overview__row sb-blog-overview__row--feature">
                {% for article in blog.articles limit: 1 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--feature',
                    show_excerpt: false
                  %}
                {% endfor %}
              </div>

              <div class="sb-blog-overview__row sb-blog-overview__row--half">
                {% for article in blog.articles limit: 2 offset: 1 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--half',
                    show_excerpt: false
                  %}
                {% endfor %}
              </div>

              {% if sidebar_box_one_markup != blank and has_three_articles %}
                <div class="sb-blog-overview__mobile-insert" aria-label="{{ popular_heading }}">
                  {{ sidebar_box_one_markup }}
                </div>
              {% endif %}

              <div class="sb-blog-overview__row sb-blog-overview__row--third" data-sb-third-row-anchor>
                {% for article in blog.articles limit: 3 offset: 3 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--third',
                    show_excerpt: false
                  %}
                {% endfor %}
              </div>

              <div class="sb-blog-overview__row sb-blog-overview__row--third">
                {% for article in blog.articles limit: 3 offset: 6 %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--third',
                    show_excerpt: false
                  %}
                {% endfor %}
              </div>

              {% if sidebar_box_two_markup != blank and has_three_articles %}
                <div class="sb-blog-overview__mobile-insert" aria-label="{{ section.settings.sidebar_promo_title }}">
                  {{ sidebar_box_two_markup }}
                </div>
              {% endif %}

            </div>
          {% endif %}

          <div class="sb-blog-overview__archive{% unless show_featured_layout %} sb-blog-overview__archive--paginated{% endunless %}" aria-label="Archive">
            {% if show_featured_layout and section.settings.archive_heading != blank %}
              <h2 class="sb-blog-overview__archive-title font-title weight-bold">{{ section.settings.archive_heading }}</h2>
            {% endif %}

            <div class="sb-blog-overview__archive-list">
              {% if show_featured_layout %}
                {% for article in blog.articles offset: archive_offset %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--archive',
                    show_excerpt: false
                  %}
                {% endfor %}
              {% else %}
                {% for article in blog.articles offset: archive_offset %}
                  {% render 'sb-blog-overview-article-card',
                    article: article,
                    blog_title: blog.title,
                    card_class: 'sb-blog-overview-card--archive',
                    show_excerpt: false
                  %}
                  {% if sidebar_box_two_markup != blank and forloop.index == 5 %}
                    <div class="sb-blog-overview__archive-insert" aria-label="{{ section.settings.sidebar_promo_title }}">
                      {{ sidebar_box_two_markup }}
                    </div>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>
          </div>

        </div>

        <aside class="sb-blog-overview__sidebar" aria-label="Sidebar content">
          <div
            class="sb-blog-overview__sidebar-stack{% if sidebar_box_one_markup != blank and sidebar_box_two_markup != blank %} sb-blog-overview__sidebar-stack--handoff{% endif %}"
            data-sb-blog-sticky-stack
          >
            {% if sidebar_box_one_markup != blank and sidebar_box_two_markup != blank %}
              <div class="sb-blog-overview__sidebar-phase sb-blog-overview__sidebar-phase--1" data-sb-sidebar-phase-1>
                <div class="sb-blog-overview__sidebar-card-wrap" data-sb-sidebar-sticky-card>
                  {{ sidebar_box_one_markup }}
                </div>
              </div>
              <div class="sb-blog-overview__sidebar-phase sb-blog-overview__sidebar-phase--2" data-sb-sidebar-phase-2>
                <div class="sb-blog-overview__sidebar-card-wrap" data-sb-sidebar-sticky-card>
                  {{ sidebar_box_two_markup }}
                </div>
              </div>
            {% elsif sidebar_box_one_markup != blank %}
              <div class="sb-blog-overview__sidebar-phase sb-blog-overview__sidebar-phase--1" data-sb-sidebar-phase-1>
                <div class="sb-blog-overview__sidebar-card-wrap" data-sb-sidebar-sticky-card>
                  {{ sidebar_box_one_markup }}
                </div>
              </div>
            {% elsif sidebar_box_two_markup != blank %}
              <div class="sb-blog-overview__sidebar-phase sb-blog-overview__sidebar-phase--1" data-sb-sidebar-phase-1>
                <div class="sb-blog-overview__sidebar-card-wrap" data-sb-sidebar-sticky-card>
                  {{ sidebar_box_two_markup }}
                </div>
              </div>
            {% endif %}
          </div>
        </aside>
      </div>

      {% if paginate.pages > 1 %}
        <nav class="sb-blog-overview__pagination" aria-label="Pagination">
          {% if paginate.previous %}
            <a
              class="sb-blog-overview__pagination-arrow sb-blog-overview__pagination-arrow--prev"
              href="{{ paginate.previous.url }}"
              aria-label="Previous page"
            >
              <span class="sb-blog-overview__pagination-arrow-icon" aria-hidden="true">
                {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
              </span>
            </a>
          {% else %}
            <span
              class="sb-blog-overview__pagination-arrow sb-blog-overview__pagination-arrow--prev is-disabled"
              aria-disabled="true"
            >
              <span class="sb-blog-overview__pagination-arrow-icon" aria-hidden="true">
                {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
              </span>
            </span>
          {% endif %}

          <p class="sb-blog-overview__pagination-status font-body weight-semibold">
            {{ paginate.current_page }} of {{ paginate.pages }}
          </p>

          {% if paginate.next %}
            <a
              class="sb-blog-overview__pagination-arrow sb-blog-overview__pagination-arrow--next"
              href="{{ paginate.next.url }}"
              aria-label="Next page"
            >
              <span class="sb-blog-overview__pagination-arrow-icon" aria-hidden="true">
                {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
              </span>
            </a>
          {% else %}
            <span
              class="sb-blog-overview__pagination-arrow sb-blog-overview__pagination-arrow--next is-disabled"
              aria-disabled="true"
            >
              <span class="sb-blog-overview__pagination-arrow-icon" aria-hidden="true">
                {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
              </span>
            </span>
          {% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  </div>
</section>

{% stylesheet %}
  .shopify-section:has(> .sb-blog-overview) {
    margin-top: 0 !important;
  }

  .sb-blog-overview {
    --sb-menu-unroll-duration: 420ms;
    --sb-menu-unroll-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --sb-menu-surface-shadow: 0 var(--sb-space-48) var(--sb-space-48) 0 var(--sb-color-always-black-25);
    --sb-blog-sticky-first-offset: var(--sb-space-128);
    padding: 0;
  }

  .sb-blog-overview__sticky-nav-wrap {
    display: none;
  }

  .sb-blog-overview__sticky-backdrop {
    opacity: 0;
    pointer-events: none;
    position: fixed;
    transition: opacity 180ms ease;
    z-index: 39;
  }

  html.is-blog-filter-open,
  body.is-blog-filter-open {
    overflow: hidden;
  }

  body.is-blog-filter-open {
    overscroll-behavior: none;
    touch-action: none;
  }

