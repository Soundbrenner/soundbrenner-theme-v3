<section class="sb-manual-chapters" id="sb-manual-{{ section.id }}">
  {% assign manual_chapter_fallback = 'sb.manual.chapter' | t %}
  <aside class="sb-manual-chapters__sidebar" data-sb-reveal>
    <nav class="sb-manual-chapters__nav" aria-label="{{ 'sb.manual.product_manual' | t }}">
      {% assign first_chapter_link = true %}
      {% for block in section.blocks %}
        {% if block.type == 'heading' %}
          {% assign raw_anchor = block.settings.heading | append: '-' | append: block.id %}
          {% assign chapter_id = raw_anchor | handleize %}
          <a
            class="sb-manual-chapters__nav-link font-caption weight-semibold{% if first_chapter_link %} is-active{% endif %}"
            href="#{{ chapter_id }}"
            data-sb-reveal-item
            data-manual-link
            data-target="{{ chapter_id }}"
            data-manual-label="{{ block.settings.heading | default: manual_chapter_fallback | escape }}"
          >
            {{ block.settings.heading | default: manual_chapter_fallback }}
          </a>
          {% assign first_chapter_link = false %}
        {% endif %}
      {% endfor %}
    </nav>
  </aside>

  {% liquid
    assign initial_mobile_chapter_label = 'sb.manual.chapters' | t
    for block in section.blocks
      if block.type == 'heading'
        assign initial_mobile_chapter_label = block.settings.heading | default: manual_chapter_fallback
        break
      endif
    endfor
  %}
  <div
    class="sb-manual-chapters__sticky-nav-wrap sb-manual-chapters__sticky-nav-wrap--mobile"
    aria-label="{{ 'sb.manual.sticky_navigation' | t }}"
    data-sb-reveal
    data-sb-sticky-top-navigation
    data-sb-sticky-active="true"
  >
    <div class="sb-manual-chapters__sticky-nav sb-manual-chapters__sticky-nav--mobile" data-sb-reveal-item>
      <div class="sb-manual-chapters__sticky-dropdown" data-manual-chapter-dropdown>
        <button
          type="button"
          class="sb-manual-chapters__sticky-filter sb-manual-chapters__sticky-filter--dropdown sb-manual-chapters__sticky-filter--mobile font-caption"
          aria-expanded="false"
          aria-controls="SbManualChaptersPanel-{{ section.id }}"
          data-manual-chapter-trigger
        >
          <span class="sb-manual-chapters__sticky-filter-label sb-manual-chapters__sticky-filter-label--mobile weight-semibold" data-manual-current-chapter-label>
            {{- initial_mobile_chapter_label | escape -}}
          </span>
          <span class="sb-manual-chapters__sticky-filter-caret" aria-hidden="true">
            {{ 'icon-chevron.svg' | inline_asset_content }}
          </span>
        </button>

        <div
          id="SbManualChaptersPanel-{{ section.id }}"
          class="sb-manual-chapters__sticky-filter-panel sb-manual-chapters__sticky-filter-panel--mobile"
          data-manual-chapter-panel
        >
          <div class="sb-manual-chapters__sticky-filter-panel-surface">
            <div class="sb-manual-chapters__sticky-filter-panel-inner sb-manual-chapters__sticky-filter-panel-inner--mobile">
              <div class="sb-manual-chapters__sticky-filter-panel-header">
                <button
                  type="button"
                  class="sb-manual-chapters__sticky-filter-close"
                  data-manual-chapter-close
                  aria-label="{{ 'sb.manual.close_chapters' | t }}"
                >
                  <span class="sb-manual-chapters__sticky-filter-close-icon" aria-hidden="true">
                    {{ 'icon-cancel.svg' | inline_asset_content }}
                  </span>
                </button>
                <p class="sb-manual-chapters__sticky-filter-panel-title font-callout weight-bold">{{ 'sb.manual.chapters' | t }}</p>
              </div>

              <div class="sb-manual-chapters__sticky-filter-panel-list">
                {% assign first_mobile_chapter_link = true %}
                {% for block in section.blocks %}
                  {% if block.type == 'heading' %}
                    {% assign raw_anchor = block.settings.heading | append: '-' | append: block.id %}
                    {% assign chapter_id = raw_anchor | handleize %}
                    <a
                      class="sb-manual-chapters__sticky-filter-option font-caption{% if first_mobile_chapter_link %} is-active{% endif %}"
                      href="#{{ chapter_id }}"
                      data-sb-reveal-item
                      data-manual-link
                      data-target="{{ chapter_id }}"
                      data-manual-label="{{ block.settings.heading | default: manual_chapter_fallback | escape }}"
                      data-manual-chapter-option
                    >
                      {{ block.settings.heading | default: manual_chapter_fallback }}
                    </a>
                    {% assign first_mobile_chapter_link = false %}
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="sb-manual-chapters__sticky-backdrop" data-manual-chapter-backdrop aria-hidden="true"></div>

  <div class="sb-manual-chapters__content">
    {% for block in section.blocks %}
      {% if block.type == 'heading' %}
        {% assign raw_anchor = block.settings.heading | append: '-' | append: block.id %}
        {% assign chapter_id = raw_anchor | handleize %}
        <article id="{{ chapter_id }}" class="sb-manual-chapters__chapter" data-sb-reveal {{ block.shopify_attributes }}>
          <h2 class="sb-manual-chapters__heading font-title weight-bold" data-sb-reveal-item>{{ block.settings.heading }}</h2>
        </article>
      {% elsif block.type == 'text' %}
        <div class="sb-manual-chapters__body font-body weight-regular rte" data-sb-reveal {{ block.shopify_attributes }}>
          <div data-sb-reveal-item>
            {% render 'localized-richtext-links', content: block.settings.text %}
          </div>
        </div>
      {% elsif block.type == 'subheading' %}
        <h3 class="sb-manual-chapters__heading-medium font-callout weight-bold" data-sb-reveal {{ block.shopify_attributes }}>
          <span data-sb-reveal-item>{{ block.settings.heading }}</span>
        </h3>
      {% elsif block.type == 'heading_small' %}
        <h4 class="sb-manual-chapters__heading-small font-body weight-bold" data-sb-reveal {{ block.shopify_attributes }}>
          <span data-sb-reveal-item>{{ block.settings.heading }}</span>
        </h4>
      {% elsif block.type == 'image' %}
        <figure class="sb-manual-chapters__media" data-sb-reveal {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1824
              | image_tag:
                loading: 'lazy',
                class: 'sb-manual-chapters__media-file',
                alt: block.settings.image.alt
            }}
          {% else %}
            <img
              src="{{ 'placeholder-manual-chapter.jpg' | asset_url }}"
              alt=""
              loading="lazy"
              class="sb-manual-chapters__media-file"
              width="1824"
              height="1026"
            >
          {% endif %}
        </figure>
      {% elsif block.type == 'image_grid' %}
        {% liquid
          assign image_grid_fetch_from_product = false
          if block.settings.fetch_whats_in_the_box_from_product == true
            assign image_grid_fetch_from_product = true
          endif

          assign image_grid_items_from_product = blank
          if image_grid_fetch_from_product
            assign image_grid_root_source = blank
            if block.settings.source_metaobject != blank
              assign image_grid_root_source = block.settings.source_metaobject.value | default: block.settings.source_metaobject.reference.value | default: block.settings.source_metaobject.reference | default: block.settings.source_metaobject
            endif

            if image_grid_root_source != blank
              assign image_grid_root = blank
              for image_grid_root_candidate in image_grid_root_source limit: 1
                assign image_grid_root = image_grid_root_candidate
              endfor
              if image_grid_root == blank
                assign image_grid_root = image_grid_root_source
              endif
              if image_grid_root != blank and image_grid_root.products == blank
                assign image_grid_nested = image_grid_root.sbv2_what_s_in_the_box.value | default: image_grid_root.sbv2_what_s_in_the_box.reference.value | default: image_grid_root.sbv2_what_s_in_the_box.reference | default: image_grid_root.sbv2_what_s_in_the_box
                if image_grid_nested != blank
                  assign image_grid_root = image_grid_nested
                endif
              endif
              if image_grid_root != blank
                assign image_grid_items_from_product = image_grid_root.products.value | default: image_grid_root.products.references | default: image_grid_root.products
              endif
            endif
          endif

          assign image_grid_has_items = false
          if image_grid_fetch_from_product and image_grid_items_from_product != blank
            assign image_grid_has_items = true
          endif
          if image_grid_fetch_from_product == false and image_grid_has_items == false
            for item_index in (1..9)
              assign image_setting_key = 'item_' | append: item_index | append: '_image'
              assign text_setting_key = 'item_' | append: item_index | append: '_text'
              assign image_grid_item_image = block.settings[image_setting_key]
              assign image_grid_item_text = block.settings[text_setting_key] | strip
              if image_grid_item_image != blank or image_grid_item_text != blank
                assign image_grid_has_items = true
                break
              endif
            endfor
          endif
        %}
        {% if image_grid_has_items %}
          <div class="sb-manual-chapters__image-grid" data-sb-reveal {{ block.shopify_attributes }}>
            {% if image_grid_fetch_from_product and image_grid_items_from_product != blank %}
              {% for image_grid_source_item in image_grid_items_from_product %}
                {% liquid
                  assign image_grid_entry = image_grid_source_item.value | default: image_grid_source_item.reference.value | default: image_grid_source_item.reference | default: image_grid_source_item
                  assign image_grid_media_field = image_grid_entry.product_media
                  assign image_grid_media_source = image_grid_media_field.value | default: image_grid_media_field.reference.value | default: image_grid_media_field.reference | default: image_grid_media_field
                  assign image_grid_media = blank
                  for image_grid_media_candidate in image_grid_media_source limit: 1
                    assign image_grid_media = image_grid_media_candidate
                  endfor
                  if image_grid_media == blank
                    assign image_grid_media = image_grid_media_source
                  endif

                  assign image_grid_title = image_grid_entry.product_title.value | default: image_grid_entry.product_title | strip
                  if image_grid_title == blank
                    continue
                  endif

                  assign image_grid_media_url = blank
                  if image_grid_media.url != blank
                    assign image_grid_media_url = image_grid_media.url
                  elsif image_grid_media.src != blank
                    assign image_grid_media_url = image_grid_media.src
                  elsif image_grid_media.preview_image != blank
                    assign image_grid_media_url = image_grid_media.preview_image | image_url: width: 400
                  elsif image_grid_media.image != blank
                    assign image_grid_media_url = image_grid_media.image | image_url: width: 400
                  endif
                  if image_grid_media_url == blank and image_grid_media != blank
                    assign image_grid_media_url = image_grid_media | file_url
                    if image_grid_media_url contains 'Liquid error' or image_grid_media_url contains 'MediaListDrop'
                      assign image_grid_media_url = blank
                    endif
                  endif
                  if image_grid_media_url != blank and image_grid_media_url contains 'files/'
                    unless image_grid_media_url contains '/cdn/shop/' or image_grid_media_url contains '://'
                      assign image_grid_media_url_prefix_files = image_grid_media_url | slice: 0, 6
                      assign image_grid_media_url_prefix_slash_files = image_grid_media_url | slice: 0, 7
                      if image_grid_media_url_prefix_files == 'files/'
                        assign image_grid_media_url = '/cdn/shop/' | append: image_grid_media_url
                      elsif image_grid_media_url_prefix_slash_files == '/files/'
                        assign image_grid_media_url = '/cdn/shop' | append: image_grid_media_url
                      endif
                    endunless
                  endif
                %}
                <figure class="sb-manual-chapters__image-grid-item" data-sb-reveal-item>
                  <span class="sb-manual-chapters__image-grid-media">
                    {% if image_grid_media_url != blank %}
                      {% # theme-check-disable RemoteAsset %}
                      <img
                        src="{{ image_grid_media_url }}"
                        alt="{{ image_grid_title | escape }}"
                        loading="lazy"
                        class="sb-manual-chapters__image-grid-image"
                        width="400"
                        height="400"
                      >
                      {% # theme-check-enable RemoteAsset %}
                    {% else %}
                      <img
                        src="{{ 'manual-image-grid-item-placeholder.png' | asset_url }}"
                        alt="{{ image_grid_title | escape }}"
                        loading="lazy"
                        class="sb-manual-chapters__image-grid-image"
                        width="400"
                        height="400"
                      >
                    {% endif %}
                  </span>
                  <figcaption class="sb-manual-chapters__image-grid-caption font-body weight-regular">{{ image_grid_title | escape }}</figcaption>
                </figure>
              {% endfor %}
            {% elsif image_grid_fetch_from_product == false %}
              {% for item_index in (1..9) %}
                {% liquid
                  assign image_setting_key = 'item_' | append: item_index | append: '_image'
                  assign text_setting_key = 'item_' | append: item_index | append: '_text'
                  assign image_grid_item_image = block.settings[image_setting_key]
                  assign image_grid_item_text = block.settings[text_setting_key] | strip
                %}
                {% if image_grid_item_image != blank or image_grid_item_text != blank %}
                  <figure class="sb-manual-chapters__image-grid-item" data-sb-reveal-item>
                    <span class="sb-manual-chapters__image-grid-media">
                      {% if image_grid_item_image != blank %}
                        {{
                          image_grid_item_image
                          | image_url: width: 400
                          | image_tag:
                            loading: 'lazy',
                            class: 'sb-manual-chapters__image-grid-image',
                            alt: image_grid_item_image.alt | default: image_grid_item_text
                        }}
                      {% else %}
                        <img
                          src="{{ 'manual-image-grid-item-placeholder.png' | asset_url }}"
                          alt="{{ image_grid_item_text | escape }}"
                          loading="lazy"
                          class="sb-manual-chapters__image-grid-image"
                          width="400"
                          height="400"
                        >
                      {% endif %}
                    </span>
                    {% if image_grid_item_text != blank %}
                      <figcaption class="sb-manual-chapters__image-grid-caption font-body weight-regular">{{ image_grid_item_text | escape }}</figcaption>
                    {% endif %}
                  </figure>
                {% endif %}
              {% endfor %}
            {% endif %}
          </div>
        {% endif %}
      {% elsif block.type == 'tech_specs_accordions' %}
        {% liquid
          assign tech_specs_source = blank
          if block.settings.source_metaobject != blank
            assign tech_specs_source = block.settings.source_metaobject.value | default: block.settings.source_metaobject.reference.value | default: block.settings.source_metaobject.reference | default: block.settings.source_metaobject
          endif

          assign tech_specs_root = blank
          for tech_specs_candidate in tech_specs_source limit: 1
            assign tech_specs_root = tech_specs_candidate
          endfor
          if tech_specs_root == blank
            assign tech_specs_root = tech_specs_source
          endif

          assign tech_specs_groups = blank
          if tech_specs_root != blank
            assign tech_specs_groups = tech_specs_root.items_tech_specs.value | default: tech_specs_root.items_tech_specs.references | default: tech_specs_root.items_tech_specs
          endif

          assign tech_specs_has_content = false
          assign tech_specs_is_grouped = false
          if tech_specs_groups != blank
            assign tech_specs_first_entry = tech_specs_groups | first
            assign tech_specs_first_entry = tech_specs_first_entry.value | default: tech_specs_first_entry.reference.value | default: tech_specs_first_entry.reference | default: tech_specs_first_entry
            assign tech_specs_first_group_items = tech_specs_first_entry.tech_specs_item.value | default: tech_specs_first_entry.tech_specs_item.references | default: tech_specs_first_entry.tech_specs_item
            if tech_specs_first_group_items != blank
              assign tech_specs_is_grouped = true
            endif

            if tech_specs_is_grouped
              for tech_specs_group_raw in tech_specs_groups
                assign tech_specs_group_entry = tech_specs_group_raw.value | default: tech_specs_group_raw.reference.value | default: tech_specs_group_raw.reference | default: tech_specs_group_raw
                assign tech_specs_group_items = tech_specs_group_entry.tech_specs_item.value | default: tech_specs_group_entry.tech_specs_item.references | default: tech_specs_group_entry.tech_specs_item
                if tech_specs_group_items == blank
                  continue
                endif

                for tech_specs_line_raw in tech_specs_group_items
                  assign tech_specs_line_entry = tech_specs_line_raw.value | default: tech_specs_line_raw.reference.value | default: tech_specs_line_raw.reference | default: tech_specs_line_raw
                  assign tech_specs_line_title = tech_specs_line_entry.tech_specs_line_title.value | default: tech_specs_line_entry.tech_specs_line_title
                  assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text | metafield_tag
                  if tech_specs_line_text == blank
                    assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text.value | default: tech_specs_line_entry.tech_specs_line_text
                  endif
                  assign tech_specs_line_title = tech_specs_line_title | append: '' | strip
                  assign tech_specs_line_text = tech_specs_line_text | append: '' | strip
                  if tech_specs_line_title != blank or tech_specs_line_text != blank
                    assign tech_specs_has_content = true
                    break
                  endif
                endfor

                if tech_specs_has_content
                  break
                endif
              endfor
            else
              for tech_specs_line_raw in tech_specs_groups
                assign tech_specs_line_entry = tech_specs_line_raw.value | default: tech_specs_line_raw.reference.value | default: tech_specs_line_raw.reference | default: tech_specs_line_raw
                assign tech_specs_line_title = tech_specs_line_entry.tech_specs_line_title.value | default: tech_specs_line_entry.tech_specs_line_title
                assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text | metafield_tag
                if tech_specs_line_text == blank
                  assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text.value | default: tech_specs_line_entry.tech_specs_line_text
                endif
                assign tech_specs_line_title = tech_specs_line_title | append: '' | strip
                assign tech_specs_line_text = tech_specs_line_text | append: '' | strip
                if tech_specs_line_title != blank or tech_specs_line_text != blank
                  assign tech_specs_has_content = true
                  break
                endif
              endfor
            endif
          endif
        %}

        {% if tech_specs_has_content %}
          <div class="sb-manual-chapters__tech-specs" data-sb-reveal {{ block.shopify_attributes }}>
            {% if tech_specs_is_grouped %}
              {% for tech_specs_group_raw in tech_specs_groups %}
                {% liquid
                  assign tech_specs_group_entry = tech_specs_group_raw.value | default: tech_specs_group_raw.reference.value | default: tech_specs_group_raw.reference | default: tech_specs_group_raw
                  assign tech_specs_group_title = tech_specs_group_entry.tech_specs_title.value | default: tech_specs_group_entry.tech_specs_title | default: tech_specs_group_entry.title.value | default: tech_specs_group_entry.title | default: 'Tech specs'
                  assign tech_specs_group_title = tech_specs_group_title | append: '' | strip
                  assign tech_specs_group_title_normalized = tech_specs_group_title | downcase | strip
                  assign tech_specs_group_items = tech_specs_group_entry.tech_specs_item.value | default: tech_specs_group_entry.tech_specs_item.references | default: tech_specs_group_entry.tech_specs_item
                  assign tech_specs_group_has_rows = false
                %}
                {% if tech_specs_group_items == blank %}
                  {% continue %}
                {% endif %}

                {% for tech_specs_line_raw in tech_specs_group_items %}
                  {% liquid
                    assign tech_specs_line_entry = tech_specs_line_raw.value | default: tech_specs_line_raw.reference.value | default: tech_specs_line_raw.reference | default: tech_specs_line_raw
                    assign tech_specs_line_title = tech_specs_line_entry.tech_specs_line_title.value | default: tech_specs_line_entry.tech_specs_line_title
                    assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text | metafield_tag
                    if tech_specs_line_text == blank
                      assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text.value | default: tech_specs_line_entry.tech_specs_line_text
                    endif
                    assign tech_specs_line_title = tech_specs_line_title | append: '' | strip
                    assign tech_specs_line_text = tech_specs_line_text | append: '' | strip
                  %}
                  {% if tech_specs_line_title != blank or tech_specs_line_text != blank %}
                    {% assign tech_specs_group_has_rows = true %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if tech_specs_group_has_rows == false %}
                  {% continue %}
                {% endif %}

                <section class="sb-manual-chapters__tech-specs-group" data-sb-reveal-item>
                  {% if tech_specs_group_title != blank and tech_specs_group_title_normalized != 'tech specs' %}
                    <h3 class="sb-manual-chapters__tech-specs-title font-body weight-bold">{{ tech_specs_group_title }}</h3>
                  {% endif %}
                  <div class="sb-manual-chapters__tech-specs-rows">
                    {% for tech_specs_line_raw in tech_specs_group_items %}
                      {% liquid
                        assign tech_specs_line_entry = tech_specs_line_raw.value | default: tech_specs_line_raw.reference.value | default: tech_specs_line_raw.reference | default: tech_specs_line_raw
                        assign tech_specs_line_title = tech_specs_line_entry.tech_specs_line_title.value | default: tech_specs_line_entry.tech_specs_line_title
                        assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text | metafield_tag
                        if tech_specs_line_text == blank
                          assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text.value | default: tech_specs_line_entry.tech_specs_line_text
                        endif
                        assign tech_specs_line_title = tech_specs_line_title | append: '' | strip
                        assign tech_specs_line_text = tech_specs_line_text | append: '' | strip
                      %}
                      {% if tech_specs_line_title == blank and tech_specs_line_text == blank %}
                        {% continue %}
                      {% endif %}
                      <div class="sb-manual-chapters__spec-row">
                        <p class="sb-manual-chapters__spec-label font-caption weight-bold">{{ tech_specs_line_title }}</p>
                        <div class="sb-manual-chapters__spec-value font-caption weight-regular">{{ tech_specs_line_text }}</div>
                      </div>
                    {% endfor %}
                  </div>
                </section>
              {% endfor %}
            {% else %}
              {% liquid
                assign tech_specs_title = tech_specs_root.tech_specs_title.value | default: tech_specs_root.tech_specs_title | default: 'Tech specs'
                assign tech_specs_title = tech_specs_title | append: '' | strip
                assign tech_specs_title_normalized = tech_specs_title | downcase | strip
              %}
              <section class="sb-manual-chapters__tech-specs-group" data-sb-reveal-item>
                {% if tech_specs_title != blank and tech_specs_title_normalized != 'tech specs' %}
                  <h3 class="sb-manual-chapters__tech-specs-title font-body weight-bold">{{ tech_specs_title }}</h3>
                {% endif %}
                <div class="sb-manual-chapters__tech-specs-rows">
                  {% for tech_specs_line_raw in tech_specs_groups %}
                    {% liquid
                      assign tech_specs_line_entry = tech_specs_line_raw.value | default: tech_specs_line_raw.reference.value | default: tech_specs_line_raw.reference | default: tech_specs_line_raw
                      assign tech_specs_line_title = tech_specs_line_entry.tech_specs_line_title.value | default: tech_specs_line_entry.tech_specs_line_title
                      assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text | metafield_tag
                      if tech_specs_line_text == blank
                        assign tech_specs_line_text = tech_specs_line_entry.tech_specs_line_text.value | default: tech_specs_line_entry.tech_specs_line_text
                      endif
                      assign tech_specs_line_title = tech_specs_line_title | append: '' | strip
                      assign tech_specs_line_text = tech_specs_line_text | append: '' | strip
                    %}
                    {% if tech_specs_line_title == blank and tech_specs_line_text == blank %}
                      {% continue %}
                    {% endif %}
                    <div class="sb-manual-chapters__spec-row">
                      <p class="sb-manual-chapters__spec-label font-caption weight-bold">{{ tech_specs_line_title }}</p>
                      <div class="sb-manual-chapters__spec-value font-caption weight-regular">{{ tech_specs_line_text }}</div>
                    </div>
                  {% endfor %}
                </div>
              </section>
            {% endif %}
          </div>
        {% endif %}
      {% elsif block.type == 'button' %}
        <div class="sb-manual-chapters__button-wrap" data-sb-reveal {{ block.shopify_attributes }}>
          {% render 'radiant-button',
            label: block.settings.label,
            link: block.settings.link,
            size: block.settings.button_size,
            icon_position: block.settings.icon_position,
            reveal: true
          %}
        </div>
      {% elsif block.type == 'vimeo_video' %}
        <figure
          class="sb-manual-chapters__video"
          data-sb-reveal
          data-manual-vimeo
          data-vimeo-source="{{ block.settings.video_source | escape }}"
          {{ block.shopify_attributes }}
        >
          <iframe
            title="{{ 'sb.media.vimeo_video' | t }}"
            loading="lazy"
            allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
            allowfullscreen
            referrerpolicy="strict-origin-when-cross-origin"
            data-manual-vimeo-frame
          ></iframe>
          <div class="sb-manual-chapters__video-placeholder" aria-hidden="true" data-sb-reveal-item></div>
        </figure>
      {% elsif block.type == 'accordion_item' %}
        <article class="sb-manual-chapters__accordion" data-sb-reveal {{ block.shopify_attributes }}>
          <button
            type="button"
            class="sb-manual-chapters__accordion-trigger"
            aria-expanded="false"
            data-manual-accordion-trigger
            data-sb-reveal-item
          >
            <span class="sb-manual-chapters__accordion-question font-body weight-bold">{{ block.settings.question }}</span>
            <span class="sb-manual-chapters__accordion-icon" aria-hidden="true">
              <span class="sb-manual-chapters__accordion-icon-plus">{{ 'icon-accordion-add.svg' | inline_asset_content }}</span>
              <span class="sb-manual-chapters__accordion-icon-close">{{ 'icon-accordion-close.svg' | inline_asset_content }}</span>
            </span>
          </button>
          <div class="sb-manual-chapters__accordion-answer font-body weight-regular rte" data-manual-accordion-answer data-sb-reveal-item>
            {% render 'localized-richtext-links', content: block.settings.answer %}
          </div>
          <hr class="sb-manual-chapters__accordion-divider" data-sb-reveal-item>
        </article>
      {% elsif block.type == 'divider' %}
        <div data-sb-reveal>
          <hr class="sb-manual-chapters__divider" data-sb-reveal-item {{ block.shopify_attributes }}>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .sb-manual-chapters {
    --sb-supplementary-sticky-top-gap-mobile: 16px;
    --sb-supplementary-sticky-inline-margin-tablet: 60px;
    --sb-supplementary-sticky-inline-margin-mobile: 16px;
    --sb-supplementary-sticky-nav-padding-y-mobile: 12px;
    --sb-manual-sidebar-sticky-top-gap: 36px;
    --sb-manual-scroll-target-offset: var(
      --sb-sticky-scroll-target-offset,
      calc(var(--sb-sticky-top-stack-bottom, 0px) + var(--sb-space-96))
    );
    --sb-manual-first-offset-extra: 0px;
    --sb-manual-mobile-sticky-nav-control-height: 36px;
    --sb-menu-unroll-duration: 420ms;
    --sb-menu-unroll-ease: cubic-bezier(0.22, 1, 0.36, 1);
    display: grid;
    gap: var(--sb-space-48);
    grid-template-columns: 280px minmax(0, 1fr);
  }

  .sb-manual-chapters__sidebar {
    align-self: start;
    position: sticky;
    top: max(var(--sb-space-96), calc(var(--sb-sticky-top-stack-bottom, 0px) + var(--sb-manual-sidebar-sticky-top-gap)));
    width: 280px;
  }

  .sb-manual-chapters__nav {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-12);
  }

  .sb-manual-chapters__nav-link {
    background: var(--sb-color-neutral-200);
    border-radius: 999px;
    color: var(--sb-color-neutral-900);
    padding: var(--sb-space-16) var(--sb-space-20);
    text-decoration: none;
  }

  .sb-manual-chapters__nav-link.is-active {
    background: var(--sb-color-primary-500);
  }

  .sb-manual-chapters__nav-link:not(.is-active):hover,
  .sb-manual-chapters__nav-link:not(.is-active):focus-visible {
    background: var(--sb-color-neutral-300);
  }

  .sb-manual-chapters__content {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-24);
    min-width: 0;
  }

  .sb-manual-chapters__chapter {
    scroll-margin-top: var(--sb-manual-scroll-target-offset);
  }

  .sb-manual-chapters__media {
    margin: 0;
    overflow: hidden;
    border-radius: 24px;
    width: 100%;
  }

  .sb-manual-chapters__media-file {
    display: block;
    height: auto;
    width: 100%;
  }

  .sb-manual-chapters__image-grid {
    display: grid;
    gap: var(--sb-space-36);
    grid-template-columns: repeat(5, minmax(0, 1fr));
    width: 100%;
  }

  .sb-manual-chapters__image-grid-item {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-16);
    margin: 0;
    min-width: 0;
  }

  .sb-manual-chapters__image-grid-media {
    aspect-ratio: 1 / 1;
    border-radius: 24px;
    display: block;
    overflow: hidden;
    width: 100%;
  }

  .sb-manual-chapters__image-grid-image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .sb-manual-chapters__image-grid-caption {
    color: var(--sb-color-neutral-900);
    margin: 0;
    text-align: left;
  }

  .sb-manual-chapters__divider {
    background: var(--sb-color-neutral-600);
    border: 0;
    height: 1px;
    margin: var(--sb-space-24) 0;
    width: 100%;
  }

  .sb-manual-chapters__button-wrap {
    width: fit-content;
  }

  .sb-manual-chapters__video {
    margin: 0;
    max-width: min(100%, 400px);
    width: 100%;
  }

  .sb-manual-chapters__video iframe {
    border: 0;
    border-radius: 0;
    display: none;
    height: auto;
    width: 100%;
  }

  .sb-manual-chapters__video.is-ready iframe {
    display: block;
  }

  .sb-manual-chapters__video.is-ready .sb-manual-chapters__video-placeholder {
    display: none;
  }

  .sb-manual-chapters__video-placeholder {
    background: var(--sb-color-neutral-200);
    border: 1px solid var(--sb-color-neutral-600);
    display: block;
    aspect-ratio: 16 / 9;
    min-height: 220px;
    width: 100%;
  }

  .sb-manual-chapters__accordion {
    width: 100%;
  }

  .sb-manual-chapters__accordion-trigger {
    align-items: center;
    background: transparent;
    border: 0;
    color: var(--sb-color-neutral-900);
    cursor: pointer;
    display: flex;
    gap: var(--sb-space-16);
    justify-content: space-between;
    padding: 0;
    text-align: left;
    width: 100%;
  }

  .sb-manual-chapters__accordion-question {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-manual-chapters__accordion-icon {
    color: var(--sb-color-primary-500);
    display: inline-flex;
    flex: 0 0 auto;
    height: var(--sb-space-20);
    line-height: 0;
    position: relative;
    width: var(--sb-space-20);
  }

  .sb-manual-chapters__accordion-icon svg {
    display: block;
    height: var(--sb-space-20);
    width: var(--sb-space-20);
  }

  .sb-manual-chapters__accordion-icon svg path:not([fill='none']),
  .sb-manual-chapters__accordion-icon svg circle:not([fill='none']),
  .sb-manual-chapters__accordion-icon svg rect:not([fill='none']) {
    fill: currentColor !important;
  }

  .sb-manual-chapters__accordion-icon svg path:not([stroke='none']),
  .sb-manual-chapters__accordion-icon svg circle:not([stroke='none']),
  .sb-manual-chapters__accordion-icon svg rect:not([stroke='none']) {
    stroke: currentColor !important;
  }

  .sb-manual-chapters__accordion-icon-plus,
  .sb-manual-chapters__accordion-icon-close {
    display: inline-flex;
    inset: 0;
    position: absolute;
    transition:
      opacity 220ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sb-manual-chapters__accordion-answer {
    color: var(--sb-color-neutral-900);
    display: none;
    margin-top: var(--sb-space-24);
  }

  .sb-manual-chapters__tech-specs {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .sb-manual-chapters__tech-specs-group {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sb-manual-chapters__tech-specs-group + .sb-manual-chapters__tech-specs-group {
    border-top: 1px solid var(--sb-color-neutral-600);
    padding-top: 24px;
  }

  .sb-manual-chapters__tech-specs-title {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-manual-chapters__spec-row {
    align-items: start;
    column-gap: 16px;
    display: grid;
    grid-template-columns: 240px minmax(0, 1fr);
    width: 100%;
  }

  .sb-manual-chapters__spec-row + .sb-manual-chapters__spec-row {
    margin-top: 20px;
  }

  .sb-manual-chapters__spec-label,
  .sb-manual-chapters__spec-value {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-manual-chapters__spec-value p {
    margin: 0;
  }

  .sb-manual-chapters__spec-value a,
  .sb-manual-chapters__spec-value a:visited {
    color: var(--sb-color-primary-500);
    text-decoration: none;
  }

  .sb-manual-chapters__spec-value a:hover,
  .sb-manual-chapters__spec-value a:focus-visible,
  .sb-manual-chapters__spec-value a:active {
    color: var(--sb-color-primary-500);
    text-decoration: underline;
  }

  .sb-manual-chapters__accordion.is-open .sb-manual-chapters__accordion-answer {
    display: block;
  }

  .sb-manual-chapters__accordion-icon-plus {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .sb-manual-chapters__accordion-icon-close {
    opacity: 0;
    transform: rotate(-90deg) scale(0.85);
  }

  .sb-manual-chapters__accordion.is-open .sb-manual-chapters__accordion-icon-plus {
    opacity: 0;
    transform: rotate(90deg) scale(0.85);
  }

  .sb-manual-chapters__accordion.is-open .sb-manual-chapters__accordion-icon-close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .sb-manual-chapters__accordion-divider {
    background: var(--sb-color-neutral-600);
    border: 0;
    height: 1px;
    margin: var(--sb-space-24) 0 0;
    width: 100%;
  }

  .sb-manual-chapters__heading {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-manual-chapters__heading-medium {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-manual-chapters__heading-small {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-manual-chapters__body {
    color: var(--sb-color-neutral-900);
  }

  .sb-manual-chapters__body [data-sb-reveal-item] > *,
  .sb-manual-chapters__accordion-answer > * {
    margin: 0;
  }

  .sb-manual-chapters__body [data-sb-reveal-item] > * + *,
  .sb-manual-chapters__accordion-answer > * + * {
    margin-top: var(--sb-space-24);
  }

  .sb-manual-chapters__sticky-nav-wrap {
    display: none;
  }

  .sb-manual-chapters__sticky-backdrop {
    display: none;
    opacity: 0;
    pointer-events: none;
    position: fixed;
    transition: opacity 180ms ease;
    z-index: 109;
  }

  html.is-manual-chapter-open,
  body.is-manual-chapter-open {
    overflow: hidden;
  }

  body.is-manual-chapter-open {
    overscroll-behavior: none;
    touch-action: none;
  }

  @media (max-width: 1239px) {
    .sb-manual-chapters {
      display: flex;
      flex-direction: column;
      gap: var(--sb-space-24);
      padding-top: 0;
    }

    .sb-manual-chapters__sidebar {
      display: none;
    }

    .sb-manual-chapters__content {
      display: flex;
      flex-direction: column;
      gap: var(--sb-space-24);
      padding-top: var(--sb-manual-first-offset-extra);
    }

    .sb-manual-chapters__sticky-nav-wrap--mobile {
      --sb-supplementary-sticky-inline-margin: var(--sb-supplementary-sticky-inline-margin-tablet);
      --sb-supplementary-sticky-top-gap: var(--sb-supplementary-sticky-top-gap-mobile);
      display: block;
      left: 0;
      pointer-events: none;
      position: fixed;
      right: 0;
      top: var(
        --sb-manual-sticky-nav-top,
        calc(var(--sb-header-height, 60px) + var(--sb-announcement-min-height, 0px) + var(--sb-supplementary-sticky-top-gap))
      );
      width: 100%;
      z-index: 110;
    }

    .sb-manual-chapters__sticky-nav--mobile {
      --sb-supplementary-sticky-nav-padding-y: var(--sb-supplementary-sticky-nav-padding-y-mobile);
      align-items: center;
      background: var(--sb-color-neutral-200);
      border-radius: 24px;
      box-shadow: inset 0 0 0 1px var(--sb-color-neutral-600);
      column-gap: 16px;
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      justify-items: start;
      margin-inline: auto;
      padding: var(--sb-supplementary-sticky-nav-padding-y) 12px;
      pointer-events: auto;
      width: calc(100vw - (var(--sb-supplementary-sticky-inline-margin) * 2));
    }

    .sb-manual-chapters__sticky-nav--mobile .sb-manual-chapters__sticky-dropdown {
      max-width: 100%;
      min-width: 0;
      position: relative;
    }

    html.is-manual-chapter-open .sb-manual-chapters__sticky-nav--mobile,
    body.is-manual-chapter-open .sb-manual-chapters__sticky-nav--mobile {
      position: relative;
    }

    html.is-manual-chapter-open .sb-manual-chapters__sticky-nav--mobile::after,
    body.is-manual-chapter-open .sb-manual-chapters__sticky-nav--mobile::after {
      background: var(--sb-color-always-black-25);
      border-radius: inherit;
      content: '';
      inset: 0;
      pointer-events: none;
      position: absolute;
      z-index: 1;
    }

    .sb-manual-chapters__sticky-filter {
      align-items: center;
      background: var(--sb-color-neutral-400);
      border: 0;
      border-radius: 12px;
      color: var(--sb-color-neutral-900);
      cursor: pointer;
      display: inline-flex;
      font-family: var(--font-primary--family);
      font-size: var(--font-size-caption);
      font-weight: 400;
      height: 36px;
      line-height: 1;
      padding: 0 12px;
      text-decoration: none;
      white-space: nowrap;
    }

    .sb-manual-chapters__sticky-filter--dropdown {
      appearance: none;
      gap: 8px;
      justify-content: center;
    }

    .sb-manual-chapters__sticky-filter--mobile {
      justify-content: flex-start;
      max-width: 100%;
      min-width: 0;
    }

    .sb-manual-chapters__sticky-filter-label--mobile {
      flex: 1 1 auto;
      line-height: 1.2;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .sb-manual-chapters__sticky-filter-caret {
      align-items: center;
      display: inline-flex;
      height: 12px;
      justify-content: center;
      transition: transform 220ms var(--sb-menu-unroll-ease);
      width: 12px;
    }

    .sb-manual-chapters__sticky-filter-caret svg {
      display: block;
      height: 100%;
      width: 100%;
    }

    .sb-manual-chapters__sticky-filter-caret svg [fill] {
      fill: currentColor;
    }

    .sb-manual-chapters__sticky-nav--mobile .sb-manual-chapters__sticky-dropdown[data-open='true'] .sb-manual-chapters__sticky-filter-caret {
      transform: none;
    }

    .sb-manual-chapters__sticky-filter:hover,
    .sb-manual-chapters__sticky-filter:focus-visible {
      background: var(--sb-color-neutral-600);
      color: var(--sb-color-neutral-900);
    }

    .sb-manual-chapters__sticky-filter-panel--mobile {
      align-items: stretch;
      border-radius: 0;
      display: block;
      grid-template-rows: none;
      height: 100dvh;
      left: 0;
      max-width: none;
      min-width: 0;
      opacity: 0;
      overflow: hidden;
      pointer-events: none;
      position: fixed;
      top: 0;
      transform: translateX(-100%);
      transition:
        transform var(--sb-menu-unroll-duration) var(--sb-menu-unroll-ease),
        opacity 180ms ease;
      width: min(500px, calc(100vw - 20px));
      box-shadow: 0 var(--sb-space-4) var(--sb-space-20) 0 var(--sb-color-always-black-25);
      z-index: 110;
    }

    .sb-manual-chapters__sticky-filter-panel--mobile.is-active {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
    }

    .sb-manual-chapters__sticky-filter-panel--mobile.is-closing {
      opacity: 0;
      transform: translateX(-100%);
    }

    .sb-manual-chapters__sticky-filter-panel--mobile .sb-manual-chapters__sticky-filter-panel-surface {
      background: var(--sb-color-neutral-200);
      border-radius: 0;
      height: 100%;
      min-height: 0;
      overflow: hidden;
      width: 100%;
    }

    .sb-manual-chapters__sticky-filter-panel-inner--mobile {
      display: flex;
      flex-direction: column;
      gap: 0;
      height: 100%;
      overflow-y: auto;
      padding: calc(20px + env(safe-area-inset-top, 0px)) 20px calc(20px + env(safe-area-inset-bottom, 0px));
      width: 100%;
    }

    .sb-manual-chapters__sticky-filter-panel-header {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-bottom: 20px;
    }

    .sb-manual-chapters__sticky-filter-close {
      align-items: center;
      background: transparent;
      border: 0;
      color: var(--sb-color-neutral-900);
      cursor: pointer;
      display: inline-flex;
      flex: 0 0 auto;
      height: 20px;
      justify-content: center;
      padding: 0;
      position: relative;
      width: 20px;
    }

    .sb-manual-chapters__sticky-filter-close-icon {
      color: inherit;
      display: inline-flex;
      height: 16px;
      transition: color 140ms ease;
      width: 16px;
    }

    .sb-manual-chapters__sticky-filter-close:hover .sb-manual-chapters__sticky-filter-close-icon,
    .sb-manual-chapters__sticky-filter-close:focus-visible .sb-manual-chapters__sticky-filter-close-icon {
      color: var(--sb-color-primary-500);
    }

    .sb-manual-chapters__sticky-filter-close-icon svg {
      display: block;
      height: 100%;
      width: 100%;
    }

    .sb-manual-chapters__sticky-filter-close-icon svg path:not([fill='none']),
    .sb-manual-chapters__sticky-filter-close-icon svg circle:not([fill='none']),
    .sb-manual-chapters__sticky-filter-close-icon svg rect:not([fill='none']) {
      fill: currentColor !important;
    }

    .sb-manual-chapters__sticky-filter-panel-title {
      color: var(--sb-color-neutral-900);
      margin: 0;
    }

    .sb-manual-chapters__sticky-filter-panel-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }

    .sb-manual-chapters__sticky-filter-option {
      align-items: center;
      border-radius: 12px;
      color: var(--sb-color-neutral-900);
      display: inline-flex;
      font-family: var(--font-primary--family);
      font-size: var(--font-size-caption);
      font-weight: 400;
      height: 36px;
      line-height: 1;
      min-height: 0;
      padding: 0 12px;
      text-decoration: none;
      white-space: nowrap;
      width: 100%;
    }

    .sb-manual-chapters__sticky-filter-option:hover,
    .sb-manual-chapters__sticky-filter-option:focus-visible {
      background: var(--sb-color-neutral-400);
      color: var(--sb-color-neutral-900);
    }

    .sb-manual-chapters__sticky-filter-option.is-active {
      background: var(--sb-color-primary-500);
      color: var(--sb-color-always-white);
      font-weight: 600;
    }

    .sb-manual-chapters__sticky-filter-option.is-active:hover,
    .sb-manual-chapters__sticky-filter-option.is-active:focus-visible {
      background: var(--sb-color-primary-700);
      color: var(--sb-color-always-white);
    }

    .sb-manual-chapters__sticky-backdrop {
      -webkit-backdrop-filter: brightness(0.75);
      backdrop-filter: brightness(0.75);
      background: var(--sb-color-always-black-25);
      display: block;
      inset: 0;
    }

    .sb-manual-chapters__sticky-backdrop.is-active {
      opacity: 1;
      pointer-events: auto;
    }
  }

  @media (max-width: 989px) {
    .sb-manual-chapters__image-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 749px) {
    .sb-manual-chapters__sticky-nav-wrap--mobile {
      --sb-supplementary-sticky-inline-margin: var(--sb-supplementary-sticky-inline-margin-mobile);
    }
  }

  @media (max-width: 749px) {
    .sb-manual-chapters__spec-row {
      grid-template-columns: minmax(0, 1fr);
      row-gap: 8px;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const root = document.getElementById('sb-manual-{{ section.id }}');
    if (!root || root.dataset.manualInit === 'true') return;
    root.dataset.manualInit = 'true';

    const links = [...root.querySelectorAll('[data-manual-link]')];
    const chapters = [...root.querySelectorAll('.sb-manual-chapters__chapter')];
    const sidebar = root.querySelector('.sb-manual-chapters__sidebar');
    const stickyNavWraps = Array.from(root.querySelectorAll('.sb-manual-chapters__sticky-nav-wrap'));
    const chapterDropdowns = Array.from(root.querySelectorAll('[data-manual-chapter-dropdown]'));
    const chapterCloseButtons = Array.from(root.querySelectorAll('[data-manual-chapter-close]'));
    const chapterBackdrop = root.querySelector('[data-manual-chapter-backdrop]');
    const currentChapterLabels = Array.from(root.querySelectorAll('[data-manual-current-chapter-label]'));
    const headerElement = document.querySelector('.header');
    const chapterFallbackLabel = {{ 'sb.manual.chapter' | t | json }};
