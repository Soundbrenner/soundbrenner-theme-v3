      setActive(nextId);
    };

    const updateChapterBackdropState = () => {
      const isOpen = chapterDropdowns.some((dropdown) => dropdown.getAttribute('data-open') === 'true');
      if (chapterBackdrop) {
        chapterBackdrop.classList.toggle('is-active', isOpen);
      }
      document.documentElement.classList.toggle('is-manual-chapter-open', isOpen);
      if (document.body) {
        document.body.classList.toggle('is-manual-chapter-open', isOpen);
      }
    };

    const closeChapterDropdown = (dropdown, { returnFocus = false } = {}) => {
      if (!dropdown || dropdown.getAttribute('data-open') !== 'true') return;
      const trigger = dropdown.querySelector('[data-manual-chapter-trigger]');
