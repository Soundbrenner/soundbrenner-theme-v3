    const chapterData = chapters.map((chapter) => {
      const heading = chapter.querySelector('.sb-manual-chapters__heading');
      const label = `${heading?.textContent || chapter.id || ''}`.trim() || chapterFallbackLabel;
      return { id: chapter.id, heading: heading || chapter, label };
