    const getActiveTopAccessoryWraps = () => stickyNavWraps.filter((wrap) => isActiveTopAccessoryWrap(wrap));
    const getTopAccessoryGap = (wrap) => {
      const explicit = parsePxValue(wrap.getAttribute('data-sb-sticky-gap'), Number.NaN);
      if (Number.isFinite(explicit)) return explicit;
      const styles = window.getComputedStyle(wrap);
      const gap = parsePxValue(styles.getPropertyValue('--sb-supplementary-sticky-top-gap'), Number.NaN);
      if (Number.isFinite(gap)) return gap;
      return 0;
    };
    const getTopAccessoryControlHeight = (wrap) => {
      const control = wrap.querySelector('.sb-manual-chapters__sticky-nav--mobile');
      if (control instanceof Element && isVisibleElement(control)) {
        return Math.max(control.getBoundingClientRect().height || 0, 0);
      }
      return Math.max(wrap.getBoundingClientRect().height || 0, 0);
    };
    const getTopAccessoryCurrentBottom = () => {
      let maxBottom = 0;
      getActiveTopAccessoryWraps().forEach((wrap) => {
        const rect = wrap.getBoundingClientRect();
        if (!Number.isFinite(rect.bottom) || rect.height <= 0) return;
        maxBottom = Math.max(maxBottom, rect.bottom);
      });
