        } else {
          openChapterDropdown(dropdown);
        }
      });
    });

    chapterCloseButtons.forEach((button) => {
      button.addEventListener('click', () => {
        closeAllChapterDropdowns();
      });
    });

    if (chapterBackdrop) {
      chapterBackdrop.addEventListener('click', () => {
        closeAllChapterDropdowns();
      });
    }

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape') return;
