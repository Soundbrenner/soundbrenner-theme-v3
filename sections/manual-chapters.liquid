    };
    const getCurrentHeaderBottomFromDom = () => {
      if (!(headerElement instanceof Element) || !isVisibleElement(headerElement)) return 0;
      const styles = window.getComputedStyle(headerElement);
      const borderBottom = parsePxValue(styles.borderBottomWidth, 0);
      return Math.max((headerElement.getBoundingClientRect().bottom || 0) - borderBottom, 0);
    };
    const getAnnouncementHeight = () => {
      if (!(headerElement instanceof Element) || !isVisibleElement(headerElement)) return 0;
      const announcement = headerElement.querySelector('.header__announcement');
      const minAnnouncementHeight = parseSpaceVar('--sb-announcement-min-height', 0);
      if (!(announcement instanceof Element) || !isVisibleElement(announcement)) {
        return Math.max(minAnnouncementHeight, 0);
      }
      return Math.max(announcement.getBoundingClientRect().height || 0, minAnnouncementHeight, 0);
    };
    const getCurrentTopStackBottomFromDom = () => {
      let topStackBottom = Math.max(getCurrentHeaderBottomFromDom(), 0);
      getActiveTopAccessoryWraps().forEach((wrap) => {
        const control = wrap.querySelector('.sb-manual-chapters__sticky-nav--mobile');
        const measuredElement = (control instanceof Element && isVisibleElement(control)) ? control : wrap;
        const rect = measuredElement.getBoundingClientRect();
        if (!Number.isFinite(rect.bottom) || rect.height <= 0) return;
        topStackBottom = Math.max(topStackBottom, rect.bottom);
      });
      return Math.max(topStackBottom, 0);
    };

    const getHeadingOffset = () => parseSpaceVar('--sb-space-96', 96);

    const getTopStackBottom = () => {
      if (window.SBStickyStack && typeof window.SBStickyStack.getState === 'function') {
        const stickyState = window.SBStickyStack.getState();
        if (Number.isFinite(stickyState?.topStackBottom)) {
          return Math.max(stickyState.topStackBottom, 0);
        }
      }
      return parseSpaceVar('--sb-sticky-top-stack-bottom', 0);
    };
    const getHeaderExpandedHeight = () => {
      if (!(headerElement instanceof Element) || !isVisibleElement(headerElement)) {
        return 0;
      }
      return Math.max(headerElement.getBoundingClientRect().height || 0, 0);
    };
    const getProjectedTopStackBottomForDirection = (direction = 'down') => {
      const activeWraps = getActiveTopAccessoryWraps();
      const hasActiveTopAccessory = activeWraps.length > 0;
      const headerExpandedHeight = getHeaderExpandedHeight();
      let projectedHeaderBottom = headerExpandedHeight;
      if (direction === 'down') {
        projectedHeaderBottom = hasActiveTopAccessory
          ? 0
          : Math.max(headerExpandedHeight - getAnnouncementHeight(), 0);
      }
      let projectedBottom = Math.max(projectedHeaderBottom, 0);
      activeWraps.forEach((wrap) => {
        const accessoryBottom = projectedHeaderBottom + getTopAccessoryGap(wrap) + getTopAccessoryControlHeight(wrap);
        projectedBottom = Math.max(projectedBottom, accessoryBottom);
      });
      return Math.max(projectedBottom, 0);
    };
    const syncManualScrollTargetOffsetVar = () => {
      const headingOffset = getHeadingOffset();
      const currentTopBottom = Math.max(getTopStackBottom(), getTopAccessoryCurrentBottom(), getCurrentTopStackBottomFromDom());
      const nextOffset = Math.max(Math.round(currentTopBottom + headingOffset), headingOffset);
      const nextOffsetValue = `${nextOffset}px`;
      if (root.style.getPropertyValue('--sb-manual-scroll-target-offset') !== nextOffsetValue) {
        root.style.setProperty('--sb-manual-scroll-target-offset', nextOffsetValue);
      }
    };

    const setFirstTemplateSection = (section) => {
      if (activeFirstTemplateSection && activeFirstTemplateSection !== section) {
        activeFirstTemplateSection.removeAttribute('data-sb-manual-first-section');
        activeFirstTemplateSection.style.removeProperty('--sb-manual-first-offset-extra');
      }
      activeFirstTemplateSection = section || null;
      if (activeFirstTemplateSection) {
        activeFirstTemplateSection.setAttribute('data-sb-manual-first-section', 'true');
      }
    };

    const clearFirstTemplateSectionOffset = () => {
      if (!activeFirstTemplateSection) return;
      activeFirstTemplateSection.removeAttribute('data-sb-manual-first-section');
      activeFirstTemplateSection.style.removeProperty('--sb-manual-first-offset-extra');
      activeFirstTemplateSection = null;
    };

    const getFirstTemplateSection = () => {
      const scopedRoot = document.querySelector('#MainContent') || document;
      const sections = Array.from(scopedRoot.querySelectorAll('.shopify-section[id*="template--"]'));
      return sections.find((section) => section instanceof HTMLElement && section.offsetHeight > 0) || null;
    };

    let layoutTicking = false;
    let pendingForcedLayoutSync = false;
    const requestLayoutSync = ({ force = false } = {}) => {
      if (force) pendingForcedLayoutSync = true;
      if (layoutTicking) return;
      layoutTicking = true;
      window.requestAnimationFrame(() => {
        const shouldForce = pendingForcedLayoutSync;
        pendingForcedLayoutSync = false;
        syncManualScrollTargetOffsetVar();
        syncFirstContentOffset({ force: shouldForce });
        layoutTicking = false;
      });
    };

    const syncFirstContentOffset = ({ force = false } = {}) => {
      const shouldApplyOffset = isMobileViewport();
      if (!shouldApplyOffset) {
        clearFirstTemplateSectionOffset();
        return;
      }

      const currentScrollTop = window.scrollY || window.pageYOffset || 0;
      if (!force && currentScrollTop > 4) {
        return;
      }

      const firstTemplateSection = getFirstTemplateSection();
      setFirstTemplateSection(firstTemplateSection);
      if (!activeFirstTemplateSection) return;

      const sectionTop = activeFirstTemplateSection.getBoundingClientRect().top + currentScrollTop;
      const topStackBottom = Math.max(getTopStackBottom(), getTopAccessoryCurrentBottom(), getCurrentTopStackBottomFromDom());
      const nextOffset = Math.max(Math.round(topStackBottom + getHeadingOffset() - sectionTop), 0);
      const nextOffsetValue = `${nextOffset}px`;
      if (activeFirstTemplateSection.style.getPropertyValue('--sb-manual-first-offset-extra') !== nextOffsetValue) {
        activeFirstTemplateSection.style.setProperty('--sb-manual-first-offset-extra', nextOffsetValue);
      }
    };

    const getStickyOffset = () => {
      const headingOffset = getHeadingOffset();
      const topStackBottom = Math.max(getTopStackBottom(), getTopAccessoryCurrentBottom(), getCurrentTopStackBottomFromDom());
      if (isMobileViewport()) {
        return Math.max(topStackBottom + 8, 72);
      }

      if (!sidebar || window.getComputedStyle(sidebar).display === 'none') {
        return Math.max(topStackBottom + 8, headingOffset);
      }

      const sidebarTop = Number.parseFloat(window.getComputedStyle(sidebar).top);
      if (Number.isFinite(sidebarTop)) return Math.max(sidebarTop + 8, headingOffset);
      return Math.max(topStackBottom + 8, headingOffset);
    };

    const getScrollTargetOffset = (targetElement = null, { directionOverride = null, preferCurrentState = false } = {}) => {
      const headingOffset = getHeadingOffset();
      const pageY = window.scrollY || window.pageYOffset || 0;
      const targetPageY = targetElement instanceof Element
        ? targetElement.getBoundingClientRect().top + pageY
        : pageY;
      const direction = directionOverride || (targetPageY > pageY ? 'down' : 'up');
      if (preferCurrentState) {
        const currentTopStackBottom = Math.max(getTopStackBottom(), getTopAccessoryCurrentBottom(), getCurrentTopStackBottomFromDom());
        return Math.max(Math.round(currentTopStackBottom + headingOffset), headingOffset);
      }
      const projectedTopStackBottom = getProjectedTopStackBottomForDirection(direction);
      return Math.max(Math.round(projectedTopStackBottom + headingOffset), headingOffset);
    };

    const setActive = (id) => {
      links.forEach((link) => {
        link.classList.toggle('is-active', link.dataset.target === id);
      });
      setCurrentChapterLabel(id);
    };

    const getActiveChapterId = () => {
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
      const stickyTriggerLine = getStickyOffset();
      const activationOffset = getScrollTargetOffset(null, { preferCurrentState: true });
      const triggerLine = Math.min(
