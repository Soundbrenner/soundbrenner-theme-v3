          applyAspectRatio(data?.width, data?.height);
        })
        .catch(() => {
          if (directId) applyFrameSrc(directId);
        });
    });

    window.addEventListener(
      'scroll',
      () => {
        requestSync();
      },
      { passive: true }
    );
    window.addEventListener(
      'resize',
      () => {
        closeAllChapterDropdowns();
        syncStickyTopNavigationMarker();
        requestLayoutSync({ force: true });
        requestSync();
      },
      { passive: true }
    );
    window.addEventListener('hashchange', () => {
      requestLayoutSync({ force: true });
      requestSync();
    });
    window.addEventListener('load', () => {
      requestLayoutSync({ force: true });
      requestSync();
    });
    document.addEventListener('sb:cart-drawer:state-change', () => {
      requestLayoutSync({ force: true });
      requestSync();
    });
    document.addEventListener('sb:sticky-stack:change', () => {
      requestLayoutSync();
      requestSync();
    });

    if (document.fonts && typeof document.fonts.ready === 'object') {
      document.fonts.ready.then(() => {
        requestLayoutSync({ force: true });
      }).catch(() => {});
    }

    if (window.ResizeObserver) {
      const observer = new ResizeObserver(() => {
        requestLayoutSync({ force: true });
        requestSync();
      });
      if (headerElement) observer.observe(headerElement);
      stickyNavWraps.forEach((wrap) => observer.observe(wrap));
      if (sidebar) observer.observe(sidebar);
    }

    if (headerElement) {
      const headerObserver = new MutationObserver(() => {
        requestLayoutSync();
        requestSync();
      });
      headerObserver.observe(headerElement, { attributes: true, attributeFilter: ['class'] });
    }

    syncStickyTopNavigationMarker();
    requestLayoutSync({ force: true });
    syncActive();
    window.setTimeout(syncActive, 120);
    window.setTimeout(syncActive, 360);
  })();
</script>

