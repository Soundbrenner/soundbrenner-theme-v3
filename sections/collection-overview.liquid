{% liquid
  assign trustpilot_entry = metaobjects.trustpilot.values | first
  assign all_reviews_rating_source = ''
  assign all_reviews_count_source = ''

  if trustpilot_entry != blank
    assign rating_field = trustpilot_entry.combined_klaviyo_product_review_ratings
    assign count_field = trustpilot_entry.combined_klaviyo_product_review_count

    assign all_reviews_rating_source = rating_field.value | default: rating_field
    assign all_reviews_count_source = count_field.value | default: count_field
  endif

  assign all_reviews_rating_string = all_reviews_rating_source | append: '' | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ',' | first | strip
  assign all_reviews_count_string = all_reviews_count_source | append: '' | replace: '[', '' | replace: ']', '' | replace: '"', '' | split: ',' | first | strip

  assign all_reviews_rating_number = all_reviews_rating_string | replace: ',', '.' | plus: 0
  assign all_reviews_count_number = all_reviews_count_string | replace: ',', '' | plus: 0 | round: 0

  assign all_reviews_count_display = '0'
  if all_reviews_count_number > 0
    assign count_string = all_reviews_count_number | append: ''
    assign count_length = count_string.size

    if count_length <= 3
      assign all_reviews_count_display = count_string
    else
      assign first_group_size = count_length | modulo: 3
      if first_group_size == 0
        assign first_group_size = 3
      endif

      capture formatted_count
        echo count_string | slice: 0, first_group_size
      endcapture

      assign consumed_digits = first_group_size
      assign trailing_digits = count_length | minus: first_group_size
      assign trailing_groups = trailing_digits | divided_by: 3

      if trailing_groups > 0
        for group_index in (1..trailing_groups)
          assign group_segment = count_string | slice: consumed_digits, 3
          capture formatted_count
            echo formatted_count
            echo ','
            echo group_segment
          endcapture
          assign consumed_digits = consumed_digits | plus: 3
        endfor
      endif

      assign all_reviews_count_display = formatted_count
    endif
  endif

  if all_reviews_rating_number < 0
    assign all_reviews_rating_number = 0
  endif
  if all_reviews_rating_number > 5
    assign all_reviews_rating_number = 5
  endif

  assign rating_rounded = all_reviews_rating_number | round: 2
  assign rating_string = rating_rounded | append: ''
  assign rating_parts = rating_string | split: '.'
  assign rating_integer = rating_parts[0] | default: '0'
  assign rating_decimal = rating_parts[1] | default: ''
  if rating_decimal == blank
    assign rating_decimal = '00'
  elsif rating_decimal.size == 1
    assign rating_decimal = rating_decimal | append: '0'
  else
    assign rating_decimal = rating_decimal | slice: 0, 2
  endif
  assign rating_display = rating_integer | append: '.' | append: rating_decimal

  assign read_all_fallback_url = pages['all-reviews'].url | default: routes.root_url
  assign read_all_url = section.settings.read_all_url | default: read_all_fallback_url
  assign star_icon_url = 'icon-review-star.svg' | asset_url
  assign read_all_arrow_icon_url = 'arrow-reduced-padding.svg' | asset_url
  assign view_all_arrow_icon_url = 'collection-overview-view-all-arrow.svg' | asset_url
  assign explore_collection_label = 'sb.collection_overview.explore_collection' | t

%}

<section
  class="sb-collection-overview"
  data-sb-reveal
  data-sb-thumbnail-section
>
  <div class="sb-collection-overview__header-wrap">
    <div class="sb-collection-overview__header" data-sb-reveal-item>
      <span class="sb-collection-overview__dot" aria-hidden="true"></span>

      <div
        class="sb-collection-overview__stars"
        role="img"
        aria-label="{{ 'sb.rating.out_of_five_stars' | t: rating: rating_display }}"
        data-sb-rating-value="{{ all_reviews_rating_number }}"
        data-sb-rating-template="{{ 'sb.rating.out_of_five_stars' | t: rating: '__RATING__' | escape }}"
        style="--sb-collection-overview-star-url: url('{{ star_icon_url }}');"
      >
        {% for star_index in (1..5) %}
          {% liquid
            assign star_offset = star_index | minus: 1
            assign star_fill = all_reviews_rating_number | minus: star_offset
            if star_fill < 0
              assign star_fill = 0
            endif
            if star_fill > 1
              assign star_fill = 1
            endif
            assign star_fill_percent = star_fill | times: 100
          %}
          <span class="sb-collection-overview__star" style="--sb-collection-overview-star-fill: {{ star_fill_percent }}%;"></span>
        {% endfor %}
      </div>

      <p
        class="sb-collection-overview__summary font-caption weight-regular"
        data-sb-rating-value="{{ all_reviews_rating_number }}"
        data-sb-count-value="{{ all_reviews_count_number }}"
        data-sb-summary-template="{{ 'sb.collection_overview.rating_summary' | t: rating: '__RATING__', count: '__COUNT__' | escape }}"
      >
        {{ 'sb.collection_overview.rating_summary' | t: rating: rating_display, count: all_reviews_count_display }}
      </p>

      <a class="sb-collection-overview__read-all font-caption2 weight-semibold" href="{{ read_all_url }}">
        <span>{{ 'sb.collection_overview.read_all' | t }}</span>
        <span
          class="sb-collection-overview__read-all-arrow"
          aria-hidden="true"
          style="--sb-collection-overview-arrow-url: url('{{ read_all_arrow_icon_url }}');"
        ></span>
      </a>

      <span class="sb-collection-overview__dot" aria-hidden="true"></span>
    </div>
  </div>

  <div class="sb-collection-overview__section-divider" aria-hidden="true" data-sb-reveal-item></div>

  <div class="sb-collection-overview__rows">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% liquid
          assign overview_collection = block.settings.collection
          assign collection_title = block.settings.collection_name_override | strip
          if collection_title == blank
            assign collection_title = overview_collection.title | strip
          endif
          if collection_title == blank
            assign collection_title = 'sb.collection_overview.collection_name' | t
          endif

          assign explore_link = overview_collection.url | default: routes.collections_url
          assign compare_link = block.settings.compare_link

          assign manual_products_count = 0
          for product_slot in (1..6)
            case product_slot
              when 1
                assign selected_product = block.settings.product_1
              when 2
                assign selected_product = block.settings.product_2
              when 3
                assign selected_product = block.settings.product_3
              when 4
                assign selected_product = block.settings.product_4
              when 5
                assign selected_product = block.settings.product_5
              when 6
                assign selected_product = block.settings.product_6
            endcase
            if selected_product != blank
              assign manual_products_count = manual_products_count | plus: 1
            endif
          endfor

          assign collection_products_total = overview_collection.all_products_count | default: overview_collection.products_count | default: 0
          assign show_view_all_card = false
          if collection_products_total > 6
            assign show_view_all_card = true
          elsif collection_products_total == 0 and manual_products_count >= 6
            assign show_view_all_card = true
          endif
        %}

        <article class="sb-collection-overview__row{% unless forloop.first %} sb-collection-overview__row--with-divider{% endunless %}" {{ block.shopify_attributes }}>
          {% unless forloop.first %}
            <div class="sb-collection-overview__section-divider" aria-hidden="true" data-sb-reveal-item></div>
          {% endunless %}

          <div class="sb-collection-overview__heading-row" data-sb-reveal-item>
            <h2 class="sb-collection-overview__collection-title font-title weight-bold">{{ collection_title }}</h2>

            <div class="sb-collection-overview__actions">
              {% render 'radiant-button',
                label: explore_collection_label,
                link: explore_link,
                size: 'large',
                extra_class: 'sb-collection-overview__explore-button font-caption weight-bold'
              %}

              {% if compare_link != blank %}
                <a class="sb-collection-overview__compare-button font-caption weight-semibold" href="{{ compare_link }}">
                  {{ 'sb.collection_overview.compare' | t }}
                </a>
              {% endif %}
            </div>
          </div>

          <div class="sb-collection-overview__carousel" data-sb-carousel data-sb-reveal-item>
            <div class="sb-collection-overview__carousel-viewport" data-sb-carousel-viewport>
              <div class="sb-collection-overview__carousel-track" data-sb-carousel-track>
                {% if manual_products_count > 0 %}
                  {% for product_slot in (1..6) %}
                    {% liquid
                      assign selected_product = blank
                      case product_slot
                        when 1
                          assign selected_product = block.settings.product_1
                        when 2
                          assign selected_product = block.settings.product_2
                        when 3
                          assign selected_product = block.settings.product_3
                        when 4
                          assign selected_product = block.settings.product_4
                        when 5
                          assign selected_product = block.settings.product_5
                        when 6
                          assign selected_product = block.settings.product_6
                      endcase
                    %}
                    {% if selected_product == blank %}
                      {% continue %}
                    {% endif %}
                    <div class="sb-collection-overview__carousel-item" data-sb-carousel-item>
                      {% render 'often-bought-together-product-card', product_item: selected_product %}
                    </div>
                  {% endfor %}
                {% elsif overview_collection != blank %}
                  {% for selected_product in overview_collection.products limit: 6 %}
                    <div class="sb-collection-overview__carousel-item" data-sb-carousel-item>
                      {% render 'often-bought-together-product-card', product_item: selected_product %}
                    </div>
                  {% endfor %}
                {% else %}
                  {% for placeholder_index in (1..6) %}
                    <div class="sb-collection-overview__carousel-item" data-sb-carousel-item>
                      {% render 'product-thumbnail',
                        product_name: 'sb.collection_overview.product_placeholder' | t,
                        hide_reviews: true,
                        show_add_to_cart: false,
                        show_compare_add_to_cart_large: false
                      %}
                    </div>
                  {% endfor %}
                {% endif %}

                {% if show_view_all_card %}
                  <div class="sb-collection-overview__carousel-item sb-collection-overview__carousel-item--view-all" data-sb-carousel-item>
                    <a class="sb-collection-overview__view-all-link" href="{{ explore_link }}">
                      <span class="sb-collection-overview__view-all-card">
                        <span class="sb-collection-overview__view-all-label font-callout weight-bold">{{ 'sb.collection_overview.view_all' | t }}</span>
                        <span
                          class="sb-collection-overview__view-all-icon"
                          aria-hidden="true"
                          style="--sb-collection-overview-view-all-arrow-url: url('{{ view_all_arrow_icon_url }}');"
                        ></span>
                      </span>
                    </a>
                  </div>
                {% endif %}
              </div>
            </div>

            <div class="sb-collection-overview__carousel-controls" data-sb-carousel-controls>
              <button type="button" class="sb-collection-overview__carousel-arrow" data-sb-carousel-prev aria-label="{{ 'sb.common.previous' | t }}" disabled>
                <span class="sb-collection-overview__carousel-arrow-icon sb-collection-overview__carousel-arrow-icon--left" aria-hidden="true">
                  {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
                </span>
              </button>

              <button type="button" class="sb-collection-overview__carousel-arrow" data-sb-carousel-next aria-label="{{ 'sb.common.next' | t }}" disabled>
                <span class="sb-collection-overview__carousel-arrow-icon sb-collection-overview__carousel-arrow-icon--right" aria-hidden="true">
                  {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
                </span>
              </button>
            </div>
          </div>
        </article>
      {% endfor %}
    {% else %}
      <article class="sb-collection-overview__row">
        <div class="sb-collection-overview__heading-row" data-sb-reveal-item>
          <h2 class="sb-collection-overview__collection-title font-title weight-bold">{{ 'sb.collection_overview.collection_name' | t }}</h2>
          <div class="sb-collection-overview__actions">
            {% render 'radiant-button',
              label: explore_collection_label,
              link: routes.collections_url,
              size: 'large',
              extra_class: 'sb-collection-overview__explore-button font-caption weight-bold'
            %}
          </div>
        </div>

        <div class="sb-collection-overview__carousel" data-sb-carousel data-sb-reveal-item>
          <div class="sb-collection-overview__carousel-viewport" data-sb-carousel-viewport>
            <div class="sb-collection-overview__carousel-track" data-sb-carousel-track>
              {% for placeholder_index in (1..6) %}
                <div class="sb-collection-overview__carousel-item" data-sb-carousel-item>
                  {% render 'product-thumbnail',
                    product_name: 'sb.collection_overview.product_placeholder' | t,
                    hide_reviews: true,
                    show_add_to_cart: false,
                    show_compare_add_to_cart_large: false
                  %}
                </div>
              {% endfor %}

            </div>
          </div>

          <div class="sb-collection-overview__carousel-controls" data-sb-carousel-controls>
            <button type="button" class="sb-collection-overview__carousel-arrow" data-sb-carousel-prev aria-label="{{ 'sb.common.previous' | t }}" disabled>
              <span class="sb-collection-overview__carousel-arrow-icon sb-collection-overview__carousel-arrow-icon--left" aria-hidden="true">
                {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
              </span>
            </button>

            <button type="button" class="sb-collection-overview__carousel-arrow" data-sb-carousel-next aria-label="{{ 'sb.common.next' | t }}" disabled>
              <span class="sb-collection-overview__carousel-arrow-icon sb-collection-overview__carousel-arrow-icon--right" aria-hidden="true">
                {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
              </span>
            </button>
          </div>
        </div>
      </article>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .sb-collection-overview {
    width: 100%;
  }

  .sb-collection-overview__header-wrap {
    display: flex;
    justify-content: flex-start;
    width: 100%;
  }

  .sb-collection-overview__header {
    align-items: center;
    background: var(--sb-color-neutral-200);
    border-radius: 999px;
    display: inline-flex;
    flex-wrap: wrap;
    gap: 8px;
    max-width: 100%;
    padding: 8px 12px;
  }

  .sb-collection-overview__dot {
    background: var(--sb-color-neutral-800);
    border-radius: 50%;
    display: block;
    flex-shrink: 0;
    height: 6px;
    width: 6px;
  }

  .sb-collection-overview__stars {
    align-items: center;
    display: inline-flex;
    gap: 4px;
  }

  .sb-collection-overview__star {
    background: var(--sb-color-neutral-400);
    display: inline-block;
    flex-shrink: 0;
    height: 16px;
    mask-image: var(--sb-collection-overview-star-url);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
    position: relative;
    -webkit-mask-image: var(--sb-collection-overview-star-url);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    width: 16px;
  }

  .sb-collection-overview__star::before {
    background: var(--sb-color-neutral-900);
    content: '';
    inset: 0 auto 0 0;
    position: absolute;
    width: var(--sb-collection-overview-star-fill);
  }

  .sb-collection-overview__summary {
    color: var(--sb-color-neutral-900);
    font-size: 14px;
    line-height: 1.3;
    margin: 0;
    white-space: nowrap;
  }

  .sb-collection-overview__read-all {
    align-items: center;
    background: var(--sb-color-neutral-400);
    border-radius: 999px;
    color: var(--sb-color-neutral-900);
    display: inline-flex;
    font-size: 12px;
    gap: 4px;
    line-height: 1.2;
    padding: 2px 6px 2px 8px;
    text-decoration: none;
    white-space: nowrap;
  }

  .sb-collection-overview__read-all:hover,
  .sb-collection-overview__read-all:focus-visible {
    background: var(--sb-color-primary-500);
  }

  .sb-collection-overview__read-all-arrow {
    background: currentColor;
    display: inline-block;
    flex-shrink: 0;
    height: 12px;
    mask-image: var(--sb-collection-overview-arrow-url);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
    -webkit-mask-image: var(--sb-collection-overview-arrow-url);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    width: 12px;
  }

  .sb-collection-overview__section-divider {
    background: var(--sb-color-neutral-600);
    height: 1px;
    margin-top: var(--sb-space-36);
    width: 100%;
  }

  .sb-collection-overview__rows {
    width: 100%;
  }

  .sb-collection-overview__row--with-divider {
    margin-top: var(--sb-space-36);
  }

  .sb-collection-overview__heading-row {
    align-items: center;
    display: flex;
    gap: var(--sb-space-16) var(--sb-space-24);
    justify-content: space-between;
    margin-top: var(--sb-space-36);
    width: 100%;
  }

  .sb-collection-overview__collection-title {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-collection-overview__actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sb-space-16);
  }

  .sb-collection-overview__compare-button {
    align-items: center;
    background: var(--sb-color-neutral-100);
    border: 0;
    border-radius: 999px;
    box-shadow: inset 0 0 0 1px var(--sb-color-neutral-900);
    color: var(--sb-color-neutral-900);
    display: inline-flex;
    height: 48px;
    justify-content: center;
    padding: 0 24px;
    text-decoration: none;
    white-space: nowrap;
  }

  .sb-collection-overview__compare-button:hover,
  .sb-collection-overview__compare-button:focus-visible {
    background: var(--sb-color-neutral-900);
    box-shadow: none;
    color: var(--sb-color-neutral-100);
  }

  .sb-collection-overview__carousel {
    --sb-carousel-gap: var(--sb-space-36);
    --sb-carousel-bleed-inline: var(--page-margin);
    --sb-carousel-shadow-bleed-top: var(--sb-space-24);
    margin-top: var(--sb-space-36);
    width: 100%;
  }

  .sb-collection-overview__carousel-viewport {
    margin-left: calc(-1 * var(--sb-carousel-bleed-inline));
    margin-right: calc(-1 * var(--sb-carousel-bleed-inline));
    margin-top: calc(-1 * var(--sb-carousel-shadow-bleed-top));
    overflow-x: auto;
    overflow-y: hidden;
    padding-left: var(--sb-carousel-bleed-inline);
    padding-right: var(--sb-carousel-bleed-inline);
    padding-top: var(--sb-carousel-shadow-bleed-top);
    scrollbar-width: none;
    width: calc(100% + (var(--sb-carousel-bleed-inline) * 2));
    -webkit-overflow-scrolling: touch;
  }

  .sb-collection-overview__carousel-viewport::-webkit-scrollbar {
    display: none;
  }

  .sb-collection-overview__carousel-track {
    display: flex;
    gap: var(--sb-carousel-gap);
    padding: 0;
    width: max-content;
  }

  .sb-collection-overview__carousel-item {
    flex: 0 0 283px;
    max-width: 283px;
    min-width: 283px;
  }

  .sb-collection-overview__view-all-link {
    color: var(--sb-color-neutral-900);
    display: block;
    text-decoration: none;
    width: 100%;
  }

  .sb-collection-overview__view-all-card {
    align-items: center;
    aspect-ratio: 1 / 1;
    background: var(--sb-color-neutral-200);
    border-radius: var(--sb-space-24);
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-16);
    justify-content: center;
    transform: scale(1);
    transition: transform 160ms linear, background-color 160ms linear;
    width: 100%;
  }

  .sb-collection-overview__view-all-link:hover .sb-collection-overview__view-all-card,
  .sb-collection-overview__view-all-link:focus-visible .sb-collection-overview__view-all-card {
    background: var(--sb-color-neutral-400);
    transform: scale(var(--sb-hover-scale-factor, 1.015));
  }

  .sb-collection-overview__view-all-label {
    color: var(--sb-color-neutral-900);
  }

  .sb-collection-overview__view-all-icon {
    background: currentColor;
    color: var(--sb-color-neutral-900);
    display: inline-block;
    height: var(--sb-space-20);
    mask-image: var(--sb-collection-overview-view-all-arrow-url);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
    -webkit-mask-image: var(--sb-collection-overview-view-all-arrow-url);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    width: var(--sb-space-20);
  }

  .sb-collection-overview__carousel-controls {
    align-items: center;
    display: none;
    gap: var(--sb-space-16);
    justify-content: flex-end;
    margin-top: var(--sb-space-48);
  }

  .sb-collection-overview__carousel.is-overflowing .sb-collection-overview__carousel-controls {
    display: flex;
  }

  .sb-collection-overview__carousel-arrow {
    align-items: center;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: inline-flex;
    height: var(--sb-space-48);
    justify-content: center;
    padding: 0;
    width: var(--sb-space-48);
  }

  .sb-collection-overview__carousel-arrow[disabled] {
    cursor: default;
    opacity: 0.5;
  }

  .sb-collection-overview__carousel-arrow-icon {
    display: inline-flex;
    height: var(--sb-space-48);
    width: var(--sb-space-48);
  }

  .sb-collection-overview__carousel-arrow-icon--right {
    transform: scaleX(-1);
  }

  .sb-collection-overview__carousel-arrow-icon svg {
    display: block;
    height: 100%;
    width: 100%;
  }

  .sb-collection-overview__carousel-arrow-icon svg path:first-child {
    fill: var(--sb-color-neutral-200);
  }

  .sb-collection-overview__carousel-arrow-icon svg path:last-child {
    fill: var(--sb-color-neutral-800);
  }

  .sb-collection-overview__carousel-arrow:hover:not([disabled]) .sb-collection-overview__carousel-arrow-icon svg path:last-child,
  .sb-collection-overview__carousel-arrow:focus-visible:not([disabled]) .sb-collection-overview__carousel-arrow-icon svg path:last-child {
    fill: var(--sb-color-primary-500);
  }

  .sb-collection-overview__carousel.is-not-overflowing .sb-collection-overview__carousel-track {
    margin-inline: 0;
  }

  .sb-collection-overview__carousel-item,
  .sb-collection-overview__carousel-item .sb-often-bought-together__item,
  .sb-collection-overview__carousel-item .sb-product-thumbnail {
    min-width: 0;
    width: 100%;
  }

  .sb-collection-overview__carousel-item .sb-often-bought-together__item {
    display: flex;
    margin: 0 !important;
    padding: 0 !important;
  }

  @media (max-width: 989px) {
    .sb-collection-overview__heading-row {
      align-items: flex-start;
      flex-direction: column;
      gap: 16px;
    }

    .sb-collection-overview__actions {
      width: 100%;
    }
  }

  @media (max-width: 749px) {
    .sb-collection-overview__header {
      align-items: center;
      padding-right: 8px;
    }

    .sb-collection-overview__dot:last-child {
      display: none;
    }
  }
{% endstylesheet %}

{% render 'sb-carousel-init' %}

<script>
  (() => {
    const formatLocalizedRatingSummary = (scope = document) => {
      const locale = document.documentElement.lang || undefined;
      const ratingFormatter = new Intl.NumberFormat(locale, {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      });
      const countFormatter = new Intl.NumberFormat(locale, {
        maximumFractionDigits: 0,
      });

      scope.querySelectorAll('[data-sb-summary-template][data-sb-rating-value][data-sb-count-value]').forEach((node) => {
        const ratingValue = Number.parseFloat(node.getAttribute('data-sb-rating-value') || '0');
        const countValue = Number.parseFloat(node.getAttribute('data-sb-count-value') || '0');
        const template = node.getAttribute('data-sb-summary-template') || '';
        const formattedRating = ratingFormatter.format(Number.isFinite(ratingValue) ? ratingValue : 0);
        const formattedCount = countFormatter.format(Number.isFinite(countValue) ? countValue : 0);
        node.textContent = template
          .replace('__RATING__', formattedRating)
          .replace('__COUNT__', formattedCount);
      });

      scope.querySelectorAll('[data-sb-rating-template][data-sb-rating-value]').forEach((node) => {
        const ratingValue = Number.parseFloat(node.getAttribute('data-sb-rating-value') || '0');
        const template = node.getAttribute('data-sb-rating-template') || '';
        const formattedRating = ratingFormatter.format(Number.isFinite(ratingValue) ? ratingValue : 0);
        node.setAttribute('aria-label', template.replace('__RATING__', formattedRating));
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => formatLocalizedRatingSummary(document));
    } else {
      formatLocalizedRatingSummary(document);
    }

    document.addEventListener('shopify:section:load', (event) => {
      if (!event.target) return;
      formatLocalizedRatingSummary(event.target);
    });
  })();
</script>

