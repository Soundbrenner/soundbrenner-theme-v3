{% liquid
  assign trustpilot_entry = metaobjects.trustpilot.values | first
  assign all_reviews_rating_raw = ''
  assign all_reviews_count_raw = ''

  if trustpilot_entry != blank
    assign rating_field = trustpilot_entry.combined_klaviyo_product_review_ratings
    assign count_field = trustpilot_entry.combined_klaviyo_product_review_count

    assign all_reviews_rating_raw = rating_field.value | default: rating_field
    assign all_reviews_count_raw = count_field.value | default: count_field
  endif

  assign all_reviews_rating_number = all_reviews_rating_raw | replace: ',', '.' | plus: 0
  assign all_reviews_count_number = all_reviews_count_raw | replace: ',', '' | plus: 0 | round: 0

  assign all_reviews_count_display = '0'
  if all_reviews_count_number > 0
    assign count_string = all_reviews_count_number | append: ''
    assign count_length = count_string.size

    if count_length <= 3
      assign all_reviews_count_display = count_string
    else
      assign first_group_size = count_length | modulo: 3
      if first_group_size == 0
        assign first_group_size = 3
      endif

      capture formatted_count
        echo count_string | slice: 0, first_group_size
      endcapture

      assign consumed_digits = first_group_size
      assign trailing_digits = count_length | minus: first_group_size
      assign trailing_groups = trailing_digits | divided_by: 3

      if trailing_groups > 0
        for group_index in (1..trailing_groups)
          assign group_segment = count_string | slice: consumed_digits, 3
          capture formatted_count
            echo formatted_count
            echo ','
            echo group_segment
          endcapture
          assign consumed_digits = consumed_digits | plus: 3
        endfor
      endif

      assign all_reviews_count_display = formatted_count
    endif
  endif
  if all_reviews_rating_number < 0
    assign all_reviews_rating_number = 0
  endif
  if all_reviews_rating_number > 5
    assign all_reviews_rating_number = 5
  endif

  assign rating_rounded = all_reviews_rating_number | round: 2
  assign rating_string = rating_rounded | append: ''
  assign rating_parts = rating_string | split: '.'
  assign rating_integer = rating_parts[0] | default: '0'
  assign rating_decimal = rating_parts[1] | default: ''
  if rating_decimal == blank
    assign rating_decimal = '00'
  elsif rating_decimal.size == 1
    assign rating_decimal = rating_decimal | append: '0'
  else
    assign rating_decimal = rating_decimal | slice: 0, 2
  endif
  assign rating_display = rating_integer | append: '.' | append: rating_decimal

  assign read_all_url = section.settings.read_all_url | default: '/pages/all-reviews'
  assign star_icon_url = 'icon-review-star.svg' | asset_url
  assign read_all_arrow_icon_url = 'arrow-reduced-padding.svg' | asset_url
  assign view_all_arrow_icon_url = 'collection-overview-view-all-arrow.svg' | asset_url
%}

<section class="sb-collection-overview" data-sb-reveal>
  <div class="sb-collection-overview__header-wrap">
    <div class="sb-collection-overview__header" data-sb-reveal-item>
      <span class="sb-collection-overview__dot" aria-hidden="true"></span>

      <div
        class="sb-collection-overview__stars"
        role="img"
        aria-label="{{ rating_display }} out of 5 stars"
        style="--sb-collection-overview-star-url: url('{{ star_icon_url }}');"
      >
        {% for star_index in (1..5) %}
          {% liquid
            assign star_offset = star_index | minus: 1
            assign star_fill = all_reviews_rating_number | minus: star_offset
            if star_fill < 0
              assign star_fill = 0
            endif
            if star_fill > 1
              assign star_fill = 1
            endif
            assign star_fill_percent = star_fill | times: 100
          %}
          <span class="sb-collection-overview__star" style="--sb-collection-overview-star-fill: {{ star_fill_percent }}%;"></span>
        {% endfor %}
      </div>

      <p class="sb-collection-overview__summary font-caption weight-regular">
        {{ rating_display }} out of {{ all_reviews_count_display }} reviews
      </p>

      <a class="sb-collection-overview__read-all font-caption2 weight-semibold" href="{{ read_all_url }}">
        <span>Read all</span>
        <span
          class="sb-collection-overview__read-all-arrow"
          aria-hidden="true"
          style="--sb-collection-overview-arrow-url: url('{{ read_all_arrow_icon_url }}');"
        ></span>
      </a>

      <span class="sb-collection-overview__dot" aria-hidden="true"></span>
    </div>
  </div>

  <h2 class="sb-collection-overview__title font-title weight-bold" data-sb-reveal-item>
    Designed for musicians by Soundbrenner.
  </h2>

  <div class="sb-collection-overview__divider" aria-hidden="true" data-sb-reveal-item></div>

  <div class="sb-collection-overview__labels-row" data-sb-reveal-item>
    <p class="sb-collection-overview__collections-label font-body weight-regular">
      Collections
    </p>
    <div class="sb-collection-overview__bestsellers-label-wrap">
      <p class="sb-collection-overview__bestsellers-label font-body weight-regular">
        Bestsellers
      </p>
      <span class="sb-collection-overview__bestsellers-line" aria-hidden="true"></span>
    </div>
  </div>

  <div class="sb-collection-overview__collections-grid">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}
        {% liquid
          assign overview_collection = block.settings.collection

          assign collection_title = block.settings.title | strip
          if collection_title == blank
            assign collection_title = overview_collection.title
          endif
          if collection_title == blank
            assign collection_title = 'Collection name'
          endif

          assign collection_description = block.settings.description | strip
          if collection_description == blank
            assign collection_description = overview_collection.description | strip_html | strip
          endif
          if collection_description == blank
            assign collection_description = 'Collection description'
          endif

          assign explore_label = block.settings.explore_label | strip
          if explore_label == blank
            assign explore_label = 'Explore collection'
          endif

          assign compare_label = block.settings.compare_label | strip
          if compare_label == blank
            assign compare_label = 'Compare'
          endif

          assign explore_link = block.settings.explore_link
          if explore_link == blank
            assign explore_link = overview_collection.url
          endif
          if explore_link == blank
            assign explore_link = '/collections'
          endif

          assign compare_link = block.settings.compare_link
          assign collection_background_url = ''
          assign collection_background = overview_collection.image
          if collection_background != blank
            assign collection_background_request_width = 1275
            if collection_background.width != blank
              assign collection_background_request_width = collection_background.width | at_most: 1275
            endif
            assign collection_background_url = collection_background | image_url: width: collection_background_request_width
          endif

          assign manual_products_count = 0
          for product_slot in (1..5)
            case product_slot
              when 1
                assign selected_product = block.settings.product_1
              when 2
                assign selected_product = block.settings.product_2
              when 3
                assign selected_product = block.settings.product_3
              when 4
                assign selected_product = block.settings.product_4
              when 5
                assign selected_product = block.settings.product_5
            endcase
            if selected_product != blank
              assign manual_products_count = manual_products_count | plus: 1
            endif
          endfor
        %}

        <article class="sb-collection-overview__collection-row" data-sb-reveal-item {{ block.shopify_attributes }}>
          <div
            class="sb-collection-overview__collection-card{% if collection_background_url != blank %} sb-collection-overview__collection-card--with-image{% endif %}"
            {% if collection_background_url != blank %}
              style="--sb-collection-overview-collection-bg-image: url('{{ collection_background_url }}');"
            {% endif %}
          >
            <h3 class="sb-collection-overview__collection-title font-title weight-bold">{{ collection_title }}</h3>
            <p class="sb-collection-overview__collection-body font-body weight-regular">{{ collection_description }}</p>

            <div class="sb-collection-overview__collection-actions">
              {% render 'radiant-button',
                label: explore_label,
                link: explore_link,
                size: 'large',
                extra_class: 'sb-collection-overview__collection-explore font-caption weight-bold'
              %}

              {% if compare_link != blank %}
                <a class="sb-collection-overview__compare-button font-caption weight-semibold" href="{{ compare_link }}">
                  {{- compare_label -}}
                </a>
              {% endif %}
            </div>
          </div>

          <div class="sb-collection-overview__products-panel">
            <div class="sb-collection-overview__products-carousel" data-collection-overview-carousel>
              <div class="sb-collection-overview__products-viewport-wrap">
                <div class="sb-collection-overview__products-viewport" data-collection-overview-carousel-viewport>
                  <div class="sb-collection-overview__products-track" data-collection-overview-carousel-track>
                  {% if manual_products_count > 0 %}
                    {% for product_slot in (1..5) %}
                      {% liquid
                        assign selected_product = blank
                        case product_slot
                          when 1
                            assign selected_product = block.settings.product_1
                          when 2
                            assign selected_product = block.settings.product_2
                          when 3
                            assign selected_product = block.settings.product_3
                          when 4
                            assign selected_product = block.settings.product_4
                          when 5
                            assign selected_product = block.settings.product_5
                        endcase
                      %}
                      {% if selected_product == blank %}
                        {% continue %}
                      {% endif %}
                      <div class="sb-collection-overview__product-item" data-collection-overview-carousel-item>
                        {% render 'often-bought-together-product-card', product_item: selected_product %}
                      </div>
                    {% endfor %}
                  {% elsif overview_collection != blank %}
                    {% for selected_product in overview_collection.products limit: 5 %}
                      <div class="sb-collection-overview__product-item" data-collection-overview-carousel-item>
                        {% render 'often-bought-together-product-card', product_item: selected_product %}
                      </div>
                    {% endfor %}
                  {% else %}
                    {% for placeholder_index in (1..5) %}
                      <div class="sb-collection-overview__product-item" data-collection-overview-carousel-item>
                        {% render 'product-thumbnail',
                          product_name: 'Product',
                          hide_reviews: true,
                          show_add_to_cart: false,
                          show_compare_add_to_cart_large: false
                        %}
                      </div>
                    {% endfor %}
                  {% endif %}

                  <div class="sb-collection-overview__product-item sb-collection-overview__product-item--view-all" data-collection-overview-carousel-item>
                    <a class="sb-collection-overview__view-all-link" href="{{ explore_link }}">
                      <div
                        class="sb-collection-overview__view-all-media"
                        style="--sb-collection-overview-arrow-url: url('{{ view_all_arrow_icon_url }}');"
                      >
                        <p class="sb-collection-overview__view-all-label">View all</p>
                        <span class="sb-collection-overview__view-all-arrow" aria-hidden="true"></span>
                      </div>
                    </a>
                  </div>
                  </div>
                </div>
              </div>

              <div class="sb-collection-overview__products-controls">
                <button
                  type="button"
                  class="sb-collection-overview__products-arrow"
                  data-collection-overview-carousel-prev
                  aria-label="Previous products"
                  disabled
                >
                  <span class="sb-collection-overview__products-arrow-icon sb-collection-overview__products-arrow-icon--left" aria-hidden="true">
                    {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
                  </span>
                </button>
                <button
                  type="button"
                  class="sb-collection-overview__products-arrow"
                  data-collection-overview-carousel-next
                  aria-label="Next products"
                  disabled
                >
                  <span class="sb-collection-overview__products-arrow-icon sb-collection-overview__products-arrow-icon--right" aria-hidden="true">
                    {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
                  </span>
                </button>
              </div>
            </div>
          </div>
        </article>
      {% endfor %}
    {% else %}
      <article class="sb-collection-overview__collection-row" data-sb-reveal-item>
        <div class="sb-collection-overview__collection-card">
          <h3 class="sb-collection-overview__collection-title font-title weight-bold">Collection name</h3>
          <p class="sb-collection-overview__collection-body font-body weight-regular">Collection description</p>

          <div class="sb-collection-overview__collection-actions">
            {% render 'radiant-button',
              label: 'Explore collection',
              link: '/collections',
              size: 'large',
              extra_class: 'sb-collection-overview__collection-explore font-caption weight-bold'
            %}
          </div>
        </div>

        <div class="sb-collection-overview__products-panel">
          <div class="sb-collection-overview__products-carousel" data-collection-overview-carousel>
            <div class="sb-collection-overview__products-viewport-wrap">
              <div class="sb-collection-overview__products-viewport" data-collection-overview-carousel-viewport>
                <div class="sb-collection-overview__products-track" data-collection-overview-carousel-track>
                {% for placeholder_index in (1..5) %}
                  <div class="sb-collection-overview__product-item" data-collection-overview-carousel-item>
                    {% render 'product-thumbnail',
                      product_name: 'Product',
                      hide_reviews: true,
                      show_add_to_cart: false,
                      show_compare_add_to_cart_large: false
                    %}
                  </div>
                {% endfor %}
                <div class="sb-collection-overview__product-item sb-collection-overview__product-item--view-all" data-collection-overview-carousel-item>
                  <a class="sb-collection-overview__view-all-link" href="/collections">
                    <div
                      class="sb-collection-overview__view-all-media"
                      style="--sb-collection-overview-arrow-url: url('{{ view_all_arrow_icon_url }}');"
                    >
                      <p class="sb-collection-overview__view-all-label">View all</p>
                      <span class="sb-collection-overview__view-all-arrow" aria-hidden="true"></span>
                    </div>
                  </a>
                </div>
                </div>
              </div>
            </div>

            <div class="sb-collection-overview__products-controls">
              <button
                type="button"
                class="sb-collection-overview__products-arrow"
                data-collection-overview-carousel-prev
                aria-label="Previous products"
                disabled
              >
                <span class="sb-collection-overview__products-arrow-icon sb-collection-overview__products-arrow-icon--left" aria-hidden="true">
                  {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
                </span>
              </button>
              <button
                type="button"
                class="sb-collection-overview__products-arrow"
                data-collection-overview-carousel-next
                aria-label="Next products"
                disabled
              >
                <span class="sb-collection-overview__products-arrow-icon sb-collection-overview__products-arrow-icon--right" aria-hidden="true">
                  {{ 'icon-carousel-arrow-filled.svg' | inline_asset_content }}
                </span>
              </button>
            </div>
          </div>
        </div>
      </article>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .sb-collection-overview {
    --sb-collection-overview-products-offset: 36px;
    --sb-collection-overview-right-bleed: 0px;
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .sb-collection-overview__header-wrap {
    display: flex;
    justify-content: flex-start;
    width: 100%;
  }

  .sb-collection-overview__header {
    align-items: center;
    background: var(--sb-color-neutral-200);
    border-radius: 999px;
    display: inline-flex;
    gap: 8px;
    max-width: 100%;
    padding: 8px 12px;
  }

  .sb-collection-overview__dot {
    background: var(--sb-color-neutral-800);
    border-radius: 50%;
    display: block;
    flex-shrink: 0;
    height: 6px;
    width: 6px;
  }

  .sb-collection-overview__stars {
    align-items: center;
    display: inline-flex;
    gap: 4px;
  }

  .sb-collection-overview__star {
    background: var(--sb-color-neutral-400);
    display: inline-block;
    flex-shrink: 0;
    height: 16px;
    mask-image: var(--sb-collection-overview-star-url);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
    position: relative;
    -webkit-mask-image: var(--sb-collection-overview-star-url);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    width: 16px;
  }

  .sb-collection-overview__star::before {
    background: var(--sb-color-neutral-900);
    content: '';
    inset: 0 auto 0 0;
    position: absolute;
    width: var(--sb-collection-overview-star-fill);
  }

  .sb-collection-overview__summary {
    color: var(--sb-color-neutral-900);
    margin: 0;
    white-space: nowrap;
  }

  .sb-collection-overview__read-all {
    align-items: center;
    background: var(--sb-color-neutral-400);
    border-radius: 999px;
    color: var(--sb-color-neutral-900);
    display: inline-flex;
    gap: 4px;
    padding: 2px 6px 2px 8px;
    text-decoration: none;
    white-space: nowrap;
  }

  .sb-collection-overview__read-all:hover,
  .sb-collection-overview__read-all:focus-visible {
    background: var(--sb-color-primary-500);
  }

  .sb-collection-overview__read-all-arrow {
    background: currentColor;
    display: inline-block;
    flex-shrink: 0;
    height: 12px;
    mask-image: var(--sb-collection-overview-arrow-url);
    mask-position: center;
    mask-repeat: no-repeat;
    mask-size: contain;
    -webkit-mask-image: var(--sb-collection-overview-arrow-url);
    -webkit-mask-position: center;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-size: contain;
    width: 12px;
  }

  .sb-collection-overview__title {
    color: var(--sb-color-neutral-900);
    margin: 36px 0 0;
    max-width: 50%;
    width: 100%;
  }

  .sb-collection-overview__divider {
    background: var(--sb-color-neutral-600);
    height: 1px;
    margin-top: 36px;
    width: 100%;
  }

  .sb-collection-overview__labels-row {
    column-gap: 0;
    display: grid;
    grid-template-columns: 425px minmax(0, 1fr);
    margin-top: 36px;
    width: 100%;
  }

  .sb-collection-overview__collections-label,
  .sb-collection-overview__bestsellers-label {
    color: var(--sb-color-neutral-900);
    margin: 0;
    text-transform: uppercase;
  }

  .sb-collection-overview__bestsellers-label-wrap {
    align-items: center;
    display: flex;
    gap: 24px;
    padding-left: var(--sb-collection-overview-products-offset);
  }

  .sb-collection-overview__bestsellers-line {
    background: var(--sb-color-neutral-600);
    flex: 1 1 auto;
    height: 1px;
    position: relative;
  }

  .sb-collection-overview__bestsellers-line::after {
    background: var(--sb-color-neutral-600);
    content: '';
    height: 24px;
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 1px;
  }

  .sb-collection-overview__collections-grid {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-64);
    margin-top: 36px;
    width: 100%;
  }

  .sb-collection-overview__collection-row {
    display: grid;
    column-gap: 0;
    row-gap: 24px;
    grid-template-columns: 425px minmax(0, 1fr);
    width: 100%;
  }

  .sb-collection-overview__collection-card {
    background-color: var(--sb-color-neutral-200);
    background-image: var(--sb-collection-overview-collection-bg-image);
    background-position: center;
    background-repeat: no-repeat;
    background-size: cover;
    border-radius: 24px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    gap: 20px;
    min-height: 360px;
    overflow: hidden;
    padding: 36px;
    position: relative;
    width: 100%;
  }

  .sb-collection-overview__collection-card--with-image::after {
    background: linear-gradient(
      180deg,
      var(--sb-color-always-black-50) 0%,
      var(--sb-color-always-black-0) 50%,
      var(--sb-color-always-black-0) 100%
    );
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 0;
  }

  .sb-collection-overview__collection-card--with-image .sb-collection-overview__collection-title,
  .sb-collection-overview__collection-card--with-image .sb-collection-overview__collection-body {
    color: var(--sb-color-always-white);
  }

  .sb-collection-overview__collection-card > * {
    position: relative;
    z-index: 1;
  }

  .sb-collection-overview__collection-title,
  .sb-collection-overview__collection-body {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-collection-overview__collection-actions {
    align-items: flex-end;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: auto;
  }

  .sb-collection-overview__collection-explore {
    flex-shrink: 0;
  }

  .sb-collection-overview__compare-button {
    align-items: center;
    background: var(--sb-color-neutral-900);
    border: 0;
    border-radius: 999px;
    color: var(--sb-color-neutral-100);
    display: inline-flex;
    flex-shrink: 0;
    height: 48px;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    text-decoration: none;
  }

  .sb-collection-overview__compare-button:hover,
  .sb-collection-overview__compare-button:focus-visible {
    background: var(--sb-color-neutral-100);
    color: var(--sb-color-neutral-900);
  }

  .sb-collection-overview__products-panel {
    min-width: 0;
    width: calc(100% + var(--sb-collection-overview-right-bleed));
  }

  .sb-collection-overview__products-carousel {
    width: 100%;
  }

  .sb-collection-overview__products-viewport-wrap {
    overflow: visible;
    position: relative;
  }

  .sb-collection-overview__products-viewport-wrap::before {
    background: var(--sb-color-neutral-100);
    content: '';
    inset: 0 auto 0 0;
    pointer-events: none;
    position: absolute;
    width: var(--sb-collection-overview-products-offset);
    z-index: 0;
    -webkit-mask-image: linear-gradient(90deg, var(--sb-color-always-black) 0%, var(--sb-color-always-black-0) 100%);
    mask-image: linear-gradient(90deg, var(--sb-color-always-black) 0%, var(--sb-color-always-black-0) 100%);
  }

  .sb-collection-overview__products-viewport {
    --sb-collection-overview-shadow-bleed-top: 24px;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0,
      var(--sb-color-always-black) var(--sb-collection-overview-products-offset),
      var(--sb-color-always-black) 100%
    );
    mask-image: linear-gradient(
      90deg,
      transparent 0,
      var(--sb-color-always-black) var(--sb-collection-overview-products-offset),
      var(--sb-color-always-black) 100%
    );
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-size: 100% 100%;
    mask-size: 100% 100%;
    margin-top: calc(var(--sb-collection-overview-shadow-bleed-top) * -1);
    overflow-x: auto;
    overflow-y: hidden;
    padding-top: var(--sb-collection-overview-shadow-bleed-top);
    position: relative;
    scrollbar-width: none;
    width: 100%;
    z-index: 1;
    -webkit-overflow-scrolling: touch;
  }

  .sb-collection-overview__products-viewport::-webkit-scrollbar {
    display: none;
  }

  .sb-collection-overview__products-track {
    display: flex;
    gap: 20px;
    padding-left: var(--sb-collection-overview-products-offset);
    width: max-content;
  }

  .sb-collection-overview__product-item {
    flex: 0 0 292px;
    max-width: 292px;
    min-width: 292px;
  }

  .sb-collection-overview__product-item,
  .sb-collection-overview__product-item .sb-often-bought-together__item,
  .sb-collection-overview__product-item .sb-product-thumbnail {
    min-width: 0;
    width: 100%;
  }

  .sb-collection-overview__view-all-link {
    color: var(--sb-color-neutral-900);
    display: block;
    text-decoration: none;
    width: 100%;
  }

  .sb-collection-overview__view-all-media {
    align-items: center;
