{% javascript %}
  (() => {
    const initCollectionOverviewAddToCart = (scope = document) => {
      const roots = scope.querySelectorAll('.sb-collection-overview');
      if (!roots.length) return;

      roots.forEach((root) => {
        root.querySelectorAll('[data-add-to-cart]').forEach((button) => {
          if (button.dataset.collectionOverviewAtcBound === 'true') return;
          button.dataset.collectionOverviewAtcBound = 'true';

          button.addEventListener('click', async (event) => {
            event.preventDefault();
            event.stopPropagation();
            if (button.disabled) return;

            const variantId = Number.parseInt(button.dataset.variantId || '', 10);
            if (!Number.isFinite(variantId) || variantId <= 0) return;

            button.disabled = true;
            try {
              if (window.SBCart && typeof window.SBCart.add === 'function') {
                await window.SBCart.add(variantId, {
                  quantity: 1,
                  sourceElement: button
                });
              } else {
                const response = await fetch('/cart/add.js', {
                  method: 'POST',
                  headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
                  credentials: 'same-origin',
                  body: JSON.stringify({ id: variantId, quantity: 1 })
                });
                if (!response.ok) throw new Error('Add to cart failed');
              }
            } finally {
              button.disabled = false;
            }
          });
        });
      });
    };

    const initCollectionOverviewCarousels = (scope = document) => {
      const roots = scope.querySelectorAll('[data-collection-overview-carousel]');
      if (!roots.length) return;

      roots.forEach((root) => {
        if (root.dataset.collectionOverviewCarouselInit === 'true') return;
        root.dataset.collectionOverviewCarouselInit = 'true';

        const viewport = root.querySelector('[data-collection-overview-carousel-viewport]');
        const track = root.querySelector('[data-collection-overview-carousel-track]');
        const prevButton = root.querySelector('[data-collection-overview-carousel-prev]');
        const nextButton = root.querySelector('[data-collection-overview-carousel-next]');

        if (!viewport || !track || !prevButton || !nextButton) return;

        const epsilon = 2;
        const getItems = () => Array.from(track.querySelectorAll('[data-collection-overview-carousel-item]'));
        const getMaxScroll = () => Math.max(0, viewport.scrollWidth - viewport.clientWidth);

        const getSnapPoints = () => {
          const items = getItems();
          const maxScroll = getMaxScroll();
          if (!items.length) return [0];

          const firstLeft = items[0].offsetLeft;
          const points = items.map((item) => {
            const offset = item.offsetLeft - firstLeft;
            return Math.max(0, Math.min(maxScroll, Number(offset.toFixed(2))));
          });
          points.push(maxScroll);

          return Array.from(new Set(points)).sort((a, b) => a - b);
        };

        const syncState = () => {
          const maxScroll = getMaxScroll();
          const overflowing = maxScroll > 1;

          root.classList.toggle('is-overflowing', overflowing);
          root.classList.toggle('is-not-overflowing', !overflowing);

          if (!overflowing) {
            if (Math.abs(viewport.scrollLeft) > epsilon) viewport.scrollLeft = 0;
            prevButton.disabled = true;
            nextButton.disabled = true;
            return;
          }

          if (viewport.scrollLeft < epsilon) viewport.scrollLeft = 0;
          if (viewport.scrollLeft > maxScroll - epsilon) viewport.scrollLeft = maxScroll;

          prevButton.disabled = viewport.scrollLeft <= epsilon;
          nextButton.disabled = viewport.scrollLeft >= maxScroll - epsilon;
        };

        const scrollToOffset = (targetOffset) => {
          const maxScroll = getMaxScroll();
          let nextOffset = Math.max(0, Math.min(targetOffset, maxScroll));
          if (nextOffset < epsilon) nextOffset = 0;
          if (nextOffset > maxScroll - epsilon) nextOffset = maxScroll;
          viewport.scrollTo({ left: nextOffset, behavior: 'smooth' });
        };

        const getNextSnap = () => {
          const current = viewport.scrollLeft;
          const maxScroll = getMaxScroll();
          const points = getSnapPoints();
          for (const point of points) {
            if (point > current + epsilon) return point;
          }
          return maxScroll;
        };

        const getPrevSnap = () => {
          const current = viewport.scrollLeft;
          const points = getSnapPoints();
          for (let i = points.length - 1; i >= 0; i -= 1) {
            if (points[i] < current - epsilon) return points[i];
          }
          return 0;
        };

        prevButton.addEventListener('click', () => {
          scrollToOffset(getPrevSnap());
        });

        nextButton.addEventListener('click', () => {
          scrollToOffset(getNextSnap());
        });

        viewport.addEventListener(
          'scroll',
          () => {
            window.requestAnimationFrame(syncState);
          },
          { passive: true }
        );

        if ('ResizeObserver' in window) {
          const observer = new ResizeObserver(() => syncState());
          observer.observe(viewport);
          observer.observe(track);
        }

        track.querySelectorAll('img').forEach((image) => {
          if (image.complete) return;
          image.addEventListener('load', syncState, { once: true });
          image.addEventListener('error', syncState, { once: true });
        });

        window.addEventListener('resize', syncState);
        window.addEventListener('load', syncState);

        syncState();
        window.requestAnimationFrame(syncState);
        window.setTimeout(syncState, 120);
      });
    };

    initCollectionOverviewAddToCart(document);
    initCollectionOverviewCarousels(document);
    document.addEventListener('shopify:section:load', (event) => {
      initCollectionOverviewAddToCart(event.target);
      initCollectionOverviewCarousels(event.target);
    });
  })();
{% endjavascript %}

