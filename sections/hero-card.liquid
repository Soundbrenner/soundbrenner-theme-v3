      "label": "Show app download QR code",
      "default": false,
      "visible_if": "{{ section.settings.use_product_page_metaobjects == false and section.settings.use_seasonal_hero_card == false and section.settings.use_resource_title_description == false }}"
    },
    {
      "type": "checkbox",
      "id": "show_app_download_app_store",
      "label": "Show App Store download button",
      "default": false,
      "visible_if": "{{ section.settings.use_product_page_metaobjects == false and section.settings.use_seasonal_hero_card == false and section.settings.use_resource_title_description == false }}"
    },
    {
      "type": "checkbox",
      "id": "show_app_download_google_play",
      "label": "Show Google Play download button",
      "default": false,
      "visible_if": "{{ section.settings.use_product_page_metaobjects == false and section.settings.use_seasonal_hero_card == false and section.settings.use_resource_title_description == false }}"
    },
    {
      "type": "checkbox",
      "id": "show_app_download_china",
      "label": "Show China download button",
      "default": false,
      "visible_if": "{{ section.settings.use_product_page_metaobjects == false and section.settings.use_seasonal_hero_card == false and section.settings.use_resource_title_description == false }}"
    }
  ],
  "presets": [
    {
      "name": "Hero card"
    }
  ]
}
{% endschema %}
