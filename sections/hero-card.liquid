{% assign hero_card_fallback_image_desktop = 'placeholder-hero-card-desktop.jpg' | asset_url %}
{% assign hero_card_fallback_image_mobile = 'placeholder-hero-card-mobile.jpg' | asset_url %}
{% assign hero_card_use_seasonal = section.settings.use_seasonal_hero_card %}
{% assign hero_card_use_resource_copy = section.settings.use_resource_title_description %}
{% assign hero_card_use_product_metaobjects = section.settings.use_product_page_metaobjects %}
{% assign hero_card_product_mode = false %}
{% assign hero_card_hide_section = false %}
{% assign hero_card_selected_variant = blank %}
{% assign hero_card_app_store_link = 'https://apps.apple.com/us/app/the-metronome-by-soundbrenner/id1048954353' %}
{% assign hero_card_google_play_link = 'https://play.google.com/store/apps/details?id=com.soundbrenner.pulse' %}
{% assign hero_card_china_download_link = 'https://files.soundbrenner.com/downloads/TheMetronome.apk' %}
{% assign seasonal_sale_name = settings.seasonal_sale_name | strip %}
{% assign sale_name_token = '{{ Sale name }}' %}
{% assign sitewide_discount_depth_token = '{{ Sitewide discount depth }}' %}
{% assign shipping_country_token = '{{ Shipping country }}' %}
{% assign free_shipping_threshold_token = '{{ Free shipping threshold }}' %}
{% assign affiliate_name_token = '{{ Affiliate name }}' %}
{% assign sitewide_seasonal_discount_depth = settings.sitewide_seasonal_discount_depth | default: 48 | strip %}
{% assign sitewide_affiliate_discount_depth = settings.sitewide_affiliate_discount_depth | default: 20 | strip %}
{% assign hero_card_enable_affiliate_cookie_mode = false %}
{% assign hero_card_seasonal_kicker_template = '' %}
{% assign hero_card_seasonal_headline_template = '' %}
{% assign hero_card_seasonal_subheadline_template = '' %}
{% assign hero_card_seasonal_button_label_template = '' %}
{% assign hero_card_affiliate_headline_template = 'sb.hero_card.affiliate_headline' | t %}
{% assign hero_card_affiliate_metaobject = blank %}
{% if request.page_type == 'page' and page != blank %}
  {% assign hero_card_affiliate_metaobject = page.metafields.custom.affiliate.value | default: page.metafields.custom.affiliate %}
  {% if hero_card_affiliate_metaobject == blank %}
    {% assign hero_card_affiliate_metaobject = page.metafields.custom.affiliate_deal.value | default: page.metafields.custom.affiliate_deal %}
  {% endif %}
  {% if hero_card_affiliate_metaobject == blank %}
    {% assign hero_card_affiliate_metaobject = page.metafields.custom.affiliate_profile.value | default: page.metafields.custom.affiliate_profile %}
  {% endif %}
{% endif %}
{% assign hero_card_is_affiliate_page = false %}
{% if hero_card_affiliate_metaobject != blank %}
  {% assign hero_card_is_affiliate_page = true %}
{% endif %}
{% assign hero_card_shipping_country_fallback = 'sb.cart.your_country' | t %}
{% assign hero_card_shipping_country_name = localization.country.name | default: localization.country.iso_code | default: hero_card_shipping_country_fallback %}
{% assign hero_card_shipping_country_iso = localization.country.iso_code | upcase | strip %}
{% assign hero_card_shipping_country_handle = hero_card_shipping_country_iso | downcase %}
{% assign hero_card_shipping_is_blocked = false %}
{% assign hero_card_shipping_has_free_shipping = false %}
{% assign hero_card_free_shipping_threshold_display = '' %}
{% assign hero_card_shipping_entry = shop.metaobjects['database_localized_shipping_info'][hero_card_shipping_country_handle] %}
{% if hero_card_shipping_entry != blank and hero_card_shipping_country_iso != blank %}
  {% assign hero_card_entry_ship_to = hero_card_shipping_entry.ship_to_it.value | default: hero_card_shipping_entry.ship_to_it | append: '' | downcase %}
  {% assign hero_card_entry_has_free_shipping = hero_card_shipping_entry.free_shipping_available.value | default: hero_card_shipping_entry.free_shipping_available | append: '' | downcase %}
  {% assign hero_card_entry_threshold = hero_card_shipping_entry.free_shipping_threshold_in_local_currency.value | default: hero_card_shipping_entry.free_shipping_threshold_in_local_currency %}

  {% if hero_card_entry_ship_to == 'false' or hero_card_entry_ship_to == '0' or hero_card_entry_ship_to == 'no' %}
    {% assign hero_card_shipping_is_blocked = true %}
  {% endif %}
  {% if hero_card_entry_has_free_shipping == 'true' or hero_card_entry_has_free_shipping == '1' or hero_card_entry_has_free_shipping == 'yes' %}
    {% assign hero_card_shipping_has_free_shipping = true %}
  {% endif %}
  {% if hero_card_entry_threshold != blank %}
    {% assign hero_card_entry_threshold_cents = hero_card_entry_threshold | times: 100 %}
    {% capture hero_card_free_shipping_threshold_display %}
      {% render 'sb-money-no-decimals', amount: hero_card_entry_threshold_cents %}
    {% endcapture %}
    {% assign hero_card_free_shipping_threshold_display = hero_card_free_shipping_threshold_display | strip %}
  {% endif %}
{% endif %}

{% if hero_card_use_product_metaobjects %}
  {% if request.page_type == 'product' and product != blank %}
    {% assign hero_card_footer_ref = product.metafields.custom.sbv2_footer_card.value | default: product.metafields.custom.sbv2_footer_card %}
    {% if hero_card_footer_ref != blank %}
      {% assign hero_card_product_mode = true %}
      {% assign hero_card_selected_variant = product.selected_or_first_available_variant %}
      {% assign hero_card_source_image_desktop = hero_card_footer_ref.background_image_desktop.value | default: hero_card_footer_ref.background_image_desktop %}
      {% assign hero_card_source_image_mobile = hero_card_footer_ref.background_image_mobile.value | default: hero_card_footer_ref.background_image_mobile %}
      {% assign hero_card_headline = 'sb.hero_card.product_mode_headline' | t %}
      {% assign hero_card_subheadline = 'sb.hero_card.product_mode_subheadline' | t %}
      {% assign hero_card_show_button = true %}
    {% else %}
      {% assign hero_card_hide_section = true %}
    {% endif %}
  {% else %}
    {% assign hero_card_hide_section = true %}
  {% endif %}
{% elsif hero_card_use_seasonal %}
  {% if hero_card_is_affiliate_page %}
    {% assign hero_card_hide_section = true %}
  {% else %}
    {% assign hero_card_source_image_desktop = settings.seasonal_hero_image_desktop %}
    {% assign hero_card_source_image_mobile = settings.seasonal_hero_image_mobile %}
    {% assign hero_card_kicker = settings.seasonal_hero_kicker %}
    {% assign hero_card_headline = settings.seasonal_hero_headline %}
    {% assign hero_card_subheadline_free_shipping = settings.seasonal_hero_subheadline_free_shipping | strip %}
    {% assign hero_card_subheadline_no_free_shipping = settings.seasonal_hero_subheadline_no_free_shipping | strip %}
    {% assign hero_card_subheadline_blocked = settings.seasonal_hero_subheadline_blocked | strip %}
    {% if hero_card_subheadline_free_shipping == blank %}
      {% assign hero_card_subheadline_free_shipping = 'sb.hero_card.subheadline_free_shipping' | t %}
    {% endif %}
    {% if hero_card_subheadline_no_free_shipping == blank %}
      {% assign hero_card_subheadline_no_free_shipping = 'sb.hero_card.subheadline_no_free_shipping' | t %}
    {% endif %}
    {% if hero_card_subheadline_blocked == blank %}
      {% assign hero_card_subheadline_blocked = 'sb.hero_card.subheadline_blocked' | t %}
    {% endif %}
    {% if hero_card_shipping_is_blocked %}
      {% assign hero_card_subheadline = hero_card_subheadline_blocked %}
    {% elsif hero_card_shipping_has_free_shipping %}
      {% assign hero_card_subheadline = hero_card_subheadline_free_shipping %}
    {% else %}
      {% assign hero_card_subheadline = hero_card_subheadline_no_free_shipping %}
    {% endif %}
    {% assign hero_card_button_label = settings.seasonal_hero_button_label %}
    {% assign hero_card_button_link = settings.seasonal_hero_button_link %}
    {% assign hero_card_seasonal_kicker_template = hero_card_kicker %}
    {% assign hero_card_seasonal_headline_template = hero_card_headline %}
    {% assign hero_card_seasonal_subheadline_template = hero_card_subheadline %}
    {% assign hero_card_seasonal_button_label_template = hero_card_button_label %}
    {% assign hero_card_enable_affiliate_cookie_mode = true %}
    {% assign hero_card_resolved_sale_name = seasonal_sale_name %}
    {% assign hero_card_resolved_discount_depth = sitewide_seasonal_discount_depth %}
    {% assign hero_card_kicker = hero_card_kicker | replace: sale_name_token, hero_card_resolved_sale_name %}
    {% assign hero_card_headline = hero_card_headline | replace: sale_name_token, hero_card_resolved_sale_name %}
    {% assign hero_card_subheadline = hero_card_subheadline | replace: sale_name_token, hero_card_resolved_sale_name %}
    {% assign hero_card_subheadline = hero_card_subheadline | replace: sitewide_discount_depth_token, hero_card_resolved_discount_depth %}
    {% assign hero_card_subheadline = hero_card_subheadline | replace: shipping_country_token, hero_card_shipping_country_name %}
    {% assign hero_card_subheadline = hero_card_subheadline | replace: free_shipping_threshold_token, hero_card_free_shipping_threshold_display %}
    {% assign hero_card_button_label = hero_card_button_label | replace: sale_name_token, hero_card_resolved_sale_name %}
    {% if hero_card_button_label != blank %}
      {% assign hero_card_show_button = true %}
    {% else %}
      {% assign hero_card_show_button = false %}
    {% endif %}
  {% endif %}
{% elsif hero_card_use_resource_copy %}
  {% assign hero_card_source_image_desktop = section.settings.background_image_desktop %}
  {% assign hero_card_source_image_mobile = section.settings.background_image_mobile %}
  {% assign hero_card_subheadline = section.settings.subheadline %}
  {% assign hero_card_button_label = section.settings.button_label %}
  {% assign hero_card_button_link = section.settings.button_link %}
  {% assign hero_card_show_button = section.settings.show_button %}
  {% if hero_card_show_button and hero_card_button_label == blank %}
    {% assign hero_card_button_label = 'sb.hero_card.placeholder_button' | t %}
  {% endif %}

  {% if collection != blank %}
    {% assign hero_card_kicker = collection.title %}
    {% assign hero_card_headline = collection.description | strip_html %}
  {% elsif page != blank %}
    {% assign hero_card_kicker = page.title %}
    {% assign hero_card_headline = page.content | strip_html %}
  {% else %}
    {% assign hero_card_kicker = section.settings.kicker %}
    {% assign hero_card_headline = section.settings.headline %}
  {% endif %}
{% else %}
  {% assign hero_card_source_image_desktop = section.settings.background_image_desktop %}
  {% assign hero_card_source_image_mobile = section.settings.background_image_mobile %}
  {% assign hero_card_kicker = section.settings.kicker %}
  {% assign hero_card_headline = section.settings.headline %}
  {% assign hero_card_subheadline = section.settings.subheadline %}
  {% assign hero_card_button_label = section.settings.button_label %}
  {% assign hero_card_button_link = section.settings.button_link %}
  {% assign hero_card_show_button = section.settings.show_button %}
  {% if hero_card_show_button and hero_card_button_label == blank %}
    {% assign hero_card_button_label = 'sb.hero_card.placeholder_button' | t %}
  {% endif %}
{% endif %}

{% if hero_card_source_image_mobile != blank %}
  {% assign hero_card_mobile_request_width = hero_card_source_image_mobile.width | at_most: 1206 %}
  {% assign hero_card_mobile_image = hero_card_source_image_mobile | image_url: width: hero_card_mobile_request_width %}
{% else %}
  {% assign hero_card_mobile_image = hero_card_fallback_image_mobile %}
{% endif %}
{% if hero_card_source_image_desktop != blank %}
  {% assign hero_card_desktop_request_width = hero_card_source_image_desktop.width | default: 2480 | at_most: 2480 %}
  {% assign hero_card_desktop_image = hero_card_source_image_desktop | image_url: width: hero_card_desktop_request_width %}
{% else %}
  {% assign hero_card_desktop_image = hero_card_fallback_image_desktop %}
{% endif %}

{% assign hero_card_app_download_mode = false %}
{% assign hero_card_show_app_download_qr = false %}
{% assign hero_card_show_app_download_app_store = false %}
{% assign hero_card_show_app_download_google_play = false %}
{% assign hero_card_show_app_download_china = false %}
{% assign hero_card_show_app_downloads = false %}
{% if hero_card_product_mode == false and hero_card_use_seasonal == false and hero_card_use_resource_copy == false %}
  {% assign hero_card_app_download_mode = true %}
  {% assign hero_card_show_app_download_qr = section.settings.show_app_download_qr %}
  {% assign hero_card_show_app_download_app_store = section.settings.show_app_download_app_store %}
  {% assign hero_card_show_app_download_google_play = section.settings.show_app_download_google_play %}
  {% assign hero_card_show_app_download_china = section.settings.show_app_download_china %}
  {% if hero_card_show_app_download_qr or hero_card_show_app_download_app_store or hero_card_show_app_download_google_play or hero_card_show_app_download_china %}
    {% assign hero_card_show_app_downloads = true %}
  {% endif %}
{% endif %}

{% if hero_card_hide_section %}
  <script>
    (() => {
      const sectionWrapper = document.currentScript && document.currentScript.closest('.shopify-section');
      if (sectionWrapper) {
        sectionWrapper.style.setProperty('display', 'none', 'important');
      }
    })();
  </script>
{% else %}
  <div class="sb-hero-card-section" data-sb-reveal>
    <div
      class="sb-framing-card{% if hero_card_product_mode %} sb-framing-card--product-mode{% endif %}"
      data-sb-reveal-item
      {% if hero_card_product_mode %}
        data-hero-card-product-mode
        data-product-id="{{ product.id }}"
        data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
        data-initial-variant-id="{{ hero_card_selected_variant.id }}"
        data-initial-price="{{ hero_card_selected_variant.price | default: 0 }}"
        data-initial-compare-price="{{ hero_card_selected_variant.compare_at_price | default: 0 }}"
      {% endif %}
      {% if hero_card_enable_affiliate_cookie_mode %}
        data-hero-card-seasonal="true"
        data-sale-name-token="{{ sale_name_token | escape }}"
        data-sitewide-discount-token="{{ sitewide_discount_depth_token | escape }}"
        data-shipping-country-token="{{ shipping_country_token | escape }}"
        data-free-shipping-threshold-token="{{ free_shipping_threshold_token | escape }}"
        data-affiliate-name-token="{{ affiliate_name_token | escape }}"
        data-affiliate-discount-depth="{{ sitewide_affiliate_discount_depth | escape }}"
        data-shipping-country-name="{{ hero_card_shipping_country_name | escape }}"
        data-free-shipping-threshold-display="{{ hero_card_free_shipping_threshold_display | escape }}"
        data-affiliate-headline-template="{{ hero_card_affiliate_headline_template | escape }}"
        data-seasonal-kicker-template="{{ hero_card_seasonal_kicker_template | escape }}"
        data-seasonal-headline-template="{{ hero_card_seasonal_headline_template | escape }}"
        data-seasonal-subheadline-template="{{ hero_card_seasonal_subheadline_template | escape }}"
        data-seasonal-button-label-template="{{ hero_card_seasonal_button_label_template | escape }}"
      {% endif %}
      style="--sb-hero-card-bg-mobile: url('{{ hero_card_mobile_image }}'); --sb-hero-card-bg-desktop: url('{{ hero_card_desktop_image }}');"
    >
      <div class="sb-framing-card__content">
        {% if hero_card_kicker != blank %}
          <p class="sb-framing-card__kicker font-body weight-semibold">{{ hero_card_kicker }}</p>
        {% endif %}
        {% if hero_card_headline != blank %}
          <h2 class="sb-framing-card__headline font-title weight-bold">{{ hero_card_headline }}</h2>
        {% endif %}
        {% if hero_card_subheadline != blank %}
          <p class="sb-framing-card__subheadline font-body weight-semibold">{{ hero_card_subheadline }}</p>
        {% endif %}
        {% if hero_card_show_button and hero_card_product_mode %}
          <form method="post" action="{{ routes.cart_add_url }}" class="sb-framing-card__product-form" data-hero-card-product-form>
            <input type="hidden" name="id" value="{{ hero_card_selected_variant.id }}" data-hero-card-variant-id>
            <button
              type="submit"
              class="sb-framing-card__product-button sb-button-radiant sb-button-radiant--large sb-button-radiant--leading-icon font-caption weight-bold"
              data-label-available="{{ 'sb.product.add_to_cart' | t }}"
              data-label-unavailable="{{ 'sb.product.sold_out' | t }}"
              aria-label="{{ 'sb.product.add_to_cart' | t }}"
              data-hero-card-submit
            >
              <span class="sb-framing-card__product-button-icon" aria-hidden="true">
                <img
                  class="sb-framing-card__product-button-icon-image"
                  src="{{ 'icon-add-to-cart.svg' | asset_url }}"
                  alt=""
                  width="16"
                  height="16"
                >
              </span>
              <span class="sb-framing-card__product-button-copy">
                <span class="sb-framing-card__product-button-label" data-hero-card-button-label>{{ 'sb.product.add_to_cart' | t }}</span>
                <span class="sb-framing-card__product-button-prices">
                  <span class="sb-framing-card__product-button-price sb-framing-card__product-button-price--compare" data-hero-card-compare-price></span>
                  <span class="sb-framing-card__product-button-price sb-framing-card__product-button-price--current" data-hero-card-current-price></span>
                </span>
              </span>
            </button>
          </form>
        {% endif %}

        {% if hero_card_app_download_mode and hero_card_show_app_downloads %}
          <div class="sb-framing-card__app-downloads">
            {% if hero_card_show_app_download_qr %}
              <div class="sb-framing-card__app-downloads-qr" aria-hidden="true">
                <img
                  src="{{ 'app-download-qr-metronome-app.png' | asset_url }}"
                  alt=""
                  loading="lazy"
                  width="80"
                  height="80"
                >
              </div>
            {% endif %}

            {% if hero_card_show_app_download_app_store %}
              <a class="sb-framing-card__app-download-link" href="{{ hero_card_app_store_link }}" target="_blank" rel="noopener noreferrer">
                <img
                  class="sb-framing-card__app-download-badge sb-framing-card__app-download-badge--app-store"
                  src="{{ 'app-download-app-store.png' | asset_url }}"
                  alt="{{ 'sb.app.download_app_store' | t }}"
                  loading="lazy"
                  width="108"
                  height="36"
                >
              </a>
            {% endif %}

            {% if hero_card_show_app_download_google_play %}
              <a class="sb-framing-card__app-download-link" href="{{ hero_card_google_play_link }}" target="_blank" rel="noopener noreferrer">
                <img
                  class="sb-framing-card__app-download-badge sb-framing-card__app-download-badge--google-play"
                  src="{{ 'app-download-google-play.png' | asset_url }}"
                  alt="{{ 'sb.app.download_google_play' | t }}"
                  loading="lazy"
                  width="122"
                  height="36"
                >
              </a>
            {% endif %}

            {% if hero_card_show_app_download_china %}
              <a class="sb-framing-card__app-download-link" href="{{ hero_card_china_download_link }}" target="_blank" rel="noopener noreferrer">
                <img
                  class="sb-framing-card__app-download-badge sb-framing-card__app-download-badge--china"
                  src="{{ 'app-download-china.png' | asset_url }}"
                  alt="{{ 'sb.app.download_china' | t }}"
                  loading="lazy"
                  width="122"
                  height="36"
                >
              </a>
            {% endif %}
          </div>
        {% endif %}

        {% if hero_card_show_button and hero_card_product_mode == false %}
          {% render 'radiant-button',
            label: hero_card_button_label,
            link: hero_card_button_link,
            size: section.settings.button_size,
            icon_position: section.settings.icon_position,
            extra_class: 'sb-framing-card__button'
          %}
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}

{% stylesheet %}
  .sb-framing-card {
    --sb-hero-bg-focus-mobile: 50%;
    --sb-hero-bg-focus-desktop: 75%;
    align-items: flex-start;
    background: var(--sb-color-neutral-200);
    background-image: var(--sb-hero-card-bg-mobile);
    background-position: var(--sb-hero-bg-focus-mobile) center;
    background-repeat: no-repeat;
    background-size: cover;
    border-radius: 24px;
    display: flex;
    height: 380px;
    padding-block: var(--sb-space-64);
    padding-inline: var(--sb-space-64);
    width: 100%;
  }

  .sb-framing-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--sb-space-20);
    margin-inline: 0;
    max-width: 560px;
    text-align: center;
    width: 100%;
  }

  .sb-framing-card__content h2,
  .sb-framing-card__content p {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-framing-card__button {
    margin-inline: auto;
    margin-top: var(--sb-space-4);
    width: fit-content;
  }

  .sb-framing-card__product-form {
    margin-top: var(--sb-space-4);
    width: 100%;
  }

  .sb-framing-card__product-button {
    justify-content: center;
    width: 100%;
  }

  .sb-framing-card__product-button-icon {
    align-items: center;
    display: inline-flex;
    justify-content: center;
    width: 16px;
  }

  .sb-framing-card__product-button-icon-image {
    display: block;
    height: 16px;
    width: 16px;
  }

  .sb-framing-card__product-button-copy {
    align-items: center;
    display: inline-flex;
    gap: var(--sb-space-4);
    justify-content: center;
  }

  .sb-framing-card__product-button-prices {
    align-items: center;
    display: inline-flex;
    gap: var(--sb-space-4);
  }

  .sb-framing-card__product-button-price {
    line-height: 1;
  }

  .sb-framing-card__product-button-price--compare {
    color: var(--sb-color-always-white);
    text-decoration: line-through;
  }

  .sb-framing-card__product-button-price--compare[hidden] {
    display: none;
  }

  .sb-framing-card__app-downloads {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sb-space-20);
    justify-content: flex-start;
    padding-top: var(--sb-space-4);
    width: 100%;
  }

  .sb-framing-card__app-downloads-qr {
    flex: 0 0 auto;
    height: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    max-height: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    max-width: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    min-height: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    min-width: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    width: var(--sb-space-80, calc(var(--sb-space-16) * 5));
  }

  .sb-framing-card__app-downloads-qr img {
    display: block;
    height: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    max-height: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    max-width: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    min-height: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    min-width: var(--sb-space-80, calc(var(--sb-space-16) * 5));
    object-fit: contain;
    width: var(--sb-space-80, calc(var(--sb-space-16) * 5));
  }

  .sb-framing-card__app-download-link {
    display: inline-flex;
    flex: 0 0 auto;
    line-height: 0;
    text-decoration: none;
    transition: none;
    user-select: none;
    -webkit-touch-callout: none;
    -webkit-user-select: none;
  }

  .sb-framing-card__app-download-badge {
    display: block;
    height: var(--sb-space-36);
    user-select: none;
    width: auto;
    -webkit-user-drag: none;
    -webkit-user-select: none;
  }

  .sb-framing-card__app-download-badge--app-store {
    aspect-ratio: 108 / 36;
  }

  .sb-framing-card__app-download-badge--google-play {
    aspect-ratio: 122 / 36;
  }

  .sb-framing-card__app-download-badge--china {
    aspect-ratio: 122 / 36;
  }

  .sb-framing-card__app-download-link[href]:hover,
  .sb-framing-card__app-download-link[href]:focus-visible {
    opacity: 0.75;
  }

  html.sb-affiliate-hero-pending .sb-framing-card[data-hero-card-seasonal="true"] {
    opacity: 0;
    pointer-events: none;
  }

  @media (max-width: 749px) {
    .sb-framing-card__app-downloads-qr {
      display: none;
    }

    .sb-framing-card__app-downloads {
      justify-content: center;
    }
  }

  @media (min-width: 750px) {
    .sb-framing-card {
      align-items: center;
      background-image: var(--sb-hero-card-bg-desktop);
      background-position: var(--sb-hero-bg-focus-desktop) center;
    }

    .sb-framing-card__content {
      text-align: left;
    }

    .sb-framing-card__button {
      margin-inline: 0;
    }

    .sb-framing-card__product-button {
      justify-content: flex-start;
      width: fit-content;
    }

    .sb-framing-card__product-button-copy {
      justify-content: flex-start;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const affiliateAnnouncementCookieName = 'sb_affiliate_announcement_state';
    const affiliateWindowStateKey = 'SBAffiliateAnnouncementState';
    const affiliateHeroPendingClass = 'sb-affiliate-hero-pending';
    const affiliateFinalizeBindingKey = '__sbAffiliateHeroFinalizeBound';

    const readCookie = (name) => {
      const cookieSource = `${document.cookie || ''}`;
      if (!cookieSource) return '';
      const cookieParts = cookieSource.split(';');
      for (const cookiePart of cookieParts) {
        const trimmedPart = cookiePart.trim();
        if (!trimmedPart.startsWith(`${name}=`)) continue;
        return trimmedPart.slice(name.length + 1);
      }
      return '';
    };

    const parseJson = (value) => {
      try {
        return JSON.parse(value);
      } catch (_) {
        return null;
      }
    };

    const normalizeAffiliateAnnouncementState = (rawState) => {
      if (!rawState || typeof rawState !== 'object') return null;

      const discountCode = `${rawState.discountCode || ''}`.trim();
      const affiliateName = `${rawState.affiliateName || discountCode}`.trim();
      const expiresAt = Number.parseInt(`${rawState.expiresAt || ''}`, 10);
      if (!discountCode || !affiliateName || !Number.isFinite(expiresAt) || expiresAt <= Date.now()) return null;

      return {
        discountCode,
        affiliateName,
        heroDesktopImage: `${rawState.heroDesktopImage || ''}`.trim(),
        heroMobileImage: `${rawState.heroMobileImage || ''}`.trim(),
        expiresAt,
      };
    };

    const getAffiliateAnnouncementState = () => {
      const rawCookieValue = readCookie(affiliateAnnouncementCookieName);
      if (!rawCookieValue) return null;

      const decodedCookieValue = (() => {
        try {
          return decodeURIComponent(rawCookieValue);
        } catch (_) {
          return rawCookieValue;
        }
      })();

      const parsedState = parseJson(decodedCookieValue);
      return normalizeAffiliateAnnouncementState(parsedState);
    };

    const getPrefetchedAffiliateAnnouncementState = () => {
      const prefetchedState = window[affiliateWindowStateKey];
      return normalizeAffiliateAnnouncementState(prefetchedState);
    };

    const replaceToken = (input, token, replacement) => {
      const source = `${input || ''}`;
      const target = `${token || ''}`;
      if (!target) return source;
      return source.split(target).join(`${replacement || ''}`);
    };

    const escapeCssUrl = (value) => `${value || ''}`.replace(/\\/g, '\\\\').replace(/"/g, '\\"');

    const applyAffiliateModeToSeasonalHeroCard = (card, state) => {
      if (!(card instanceof HTMLElement) || !state) return;

      const signature = `${state.discountCode}:${state.affiliateName}:${state.heroDesktopImage}:${state.heroMobileImage}`;
      if (card.dataset.heroCardAffiliateSignature === signature) return;
      card.dataset.heroCardAffiliateSignature = signature;

      const affiliateName = `${state.affiliateName || ''}`.trim();
      const affiliateNameToken = `${card.dataset.affiliateNameToken || ''}`;
      const saleNameToken = `${card.dataset.saleNameToken || ''}`;
      const sitewideDiscountToken = `${card.dataset.sitewideDiscountToken || ''}`;
      const shippingCountryToken = `${card.dataset.shippingCountryToken || ''}`;
      const freeShippingThresholdToken = `${card.dataset.freeShippingThresholdToken || ''}`;
      const affiliateDiscountDepth = `${card.dataset.affiliateDiscountDepth || ''}`;
      const shippingCountryName = `${card.dataset.shippingCountryName || ''}`;
      const freeShippingThresholdDisplay = `${card.dataset.freeShippingThresholdDisplay || ''}`;
      const affiliateHeadlineTemplate = `${card.dataset.affiliateHeadlineTemplate || ''}`;

      const resolveTemplate = (templateValue) => {
        let resolved = `${templateValue || ''}`;
        resolved = replaceToken(resolved, affiliateNameToken, affiliateName);
        resolved = replaceToken(resolved, saleNameToken, affiliateName);
        resolved = replaceToken(resolved, sitewideDiscountToken, affiliateDiscountDepth);
        resolved = replaceToken(resolved, shippingCountryToken, shippingCountryName);
        resolved = replaceToken(resolved, freeShippingThresholdToken, freeShippingThresholdDisplay);
        return resolved.trim();
      };

      const kickerElement = card.querySelector('.sb-framing-card__kicker');
      const headlineElement = card.querySelector('.sb-framing-card__headline');
      const subheadlineElement = card.querySelector('.sb-framing-card__subheadline');
      const buttonLabelElement = card.querySelector('.sb-framing-card__button .sb-button-radiant__label');

      if (kickerElement) {
        const kickerText = resolveTemplate(card.dataset.seasonalKickerTemplate);
        if (kickerText) kickerElement.textContent = kickerText;
      }

      if (headlineElement) {
        const headlineText = resolveTemplate(card.dataset.seasonalHeadlineTemplate);
        if (headlineText) headlineElement.textContent = headlineText;
      }

      const forcedAffiliateHeadline = resolveTemplate(affiliateHeadlineTemplate);
      if (forcedAffiliateHeadline) {
        if (headlineElement) {
          headlineElement.textContent = forcedAffiliateHeadline;
        } else {
          const contentElement = card.querySelector('.sb-framing-card__content');
          if (contentElement) {
            const injectedHeadlineElement = document.createElement('h2');
            injectedHeadlineElement.className = 'sb-framing-card__headline font-title weight-bold';
            injectedHeadlineElement.textContent = forcedAffiliateHeadline;

            if (subheadlineElement && subheadlineElement.parentElement === contentElement) {
              contentElement.insertBefore(injectedHeadlineElement, subheadlineElement);
            } else if (kickerElement && kickerElement.parentElement === contentElement) {
              kickerElement.insertAdjacentElement('afterend', injectedHeadlineElement);
            } else {
              contentElement.prepend(injectedHeadlineElement);
            }
          }
        }
      }

      if (subheadlineElement) {
        const subheadlineText = resolveTemplate(card.dataset.seasonalSubheadlineTemplate);
        if (subheadlineText) subheadlineElement.textContent = subheadlineText;
      }

      if (buttonLabelElement) {
        const buttonLabelText = resolveTemplate(card.dataset.seasonalButtonLabelTemplate);
        if (buttonLabelText) buttonLabelElement.textContent = buttonLabelText;
      }

      if (state.heroMobileImage) {
        card.style.setProperty('--sb-hero-card-bg-mobile', `url("${escapeCssUrl(state.heroMobileImage)}")`);
      }

      if (state.heroDesktopImage) {
        card.style.setProperty('--sb-hero-card-bg-desktop', `url("${escapeCssUrl(state.heroDesktopImage)}")`);
      }
    };

    const applyAffiliateModeToAllSeasonalHeroCards = () => {
      const seasonalCards = Array.from(document.querySelectorAll('[data-hero-card-seasonal="true"]'));
      if (!seasonalCards.length) return;

      const affiliateState = getPrefetchedAffiliateAnnouncementState() || getAffiliateAnnouncementState();
      if (!affiliateState) return;

      seasonalCards.forEach((card) => {
        applyAffiliateModeToSeasonalHeroCard(card, affiliateState);
      });
    };

    applyAffiliateModeToAllSeasonalHeroCards();

    const rootNode = document.documentElement;
    if (rootNode instanceof HTMLElement && rootNode.classList.contains(affiliateHeroPendingClass)) {
      const revealSeasonalHeroCards = () => {
        applyAffiliateModeToAllSeasonalHeroCards();
        rootNode.classList.remove(affiliateHeroPendingClass);
        window[affiliateFinalizeBindingKey] = false;
      };

      if (document.readyState === 'loading') {
        if (!window[affiliateFinalizeBindingKey]) {
          window[affiliateFinalizeBindingKey] = true;
          document.addEventListener('DOMContentLoaded', revealSeasonalHeroCards, { once: true });
        }
      } else {
        revealSeasonalHeroCards();
      }
    }

    const cards = Array.from(document.querySelectorAll('[data-hero-card-product-mode]'));
    if (!cards.length) return;

    cards.forEach((card) => {
      if (card.dataset.heroCardInit === 'true') return;
      card.dataset.heroCardInit = 'true';

      const variantIdInput = card.querySelector('[data-hero-card-variant-id]');
      const currentPriceElement = card.querySelector('[data-hero-card-current-price]');
      const comparePriceElement = card.querySelector('[data-hero-card-compare-price]');
      const form = card.querySelector('[data-hero-card-product-form]');
      const submitButton = card.querySelector('[data-hero-card-submit]');
      const buttonLabel = card.querySelector('[data-hero-card-button-label]');
      const currencyCode = card.dataset.currency || 'USD';
      const normalizedCurrencyCode = `${currencyCode}`.trim().toUpperCase();
      const productId = card.dataset.productId || '';
      if (!variantIdInput || !currentPriceElement || !comparePriceElement || !form || !submitButton || !buttonLabel) return;

      const storefrontPricing = window.SBStorefrontPricing || null;
      const fallbackMoneyFormatter = new Intl.NumberFormat(undefined, {
        style: 'currency',
        currency: currencyCode,
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      });
      const usdNoDecimalsFormatter = new Intl.NumberFormat('en-US', {
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      });

      const formatMoney = (centsValue) => {
        const amountInCents = Number(centsValue) || 0;
        if (normalizedCurrencyCode === 'USD') {
          return `$${usdNoDecimalsFormatter.format(Math.round(amountInCents / 100))}`;
        }
        return storefrontPricing && typeof storefrontPricing.formatMoney === 'function'
          ? storefrontPricing.formatMoney(amountInCents, currencyCode)
          : fallbackMoneyFormatter.format(amountInCents / 100);
      };

      const resolveDisplayPrice = (priceCents, comparePriceCents, overrideProductId = productId) => {
        if (storefrontPricing && typeof storefrontPricing.resolvePrice === 'function') {
          const resolved = storefrontPricing.resolvePrice({
            productId: overrideProductId,
            priceCents,
            comparePriceCents,
          }) || {};
          const currentPriceCents = Number(resolved.currentPriceCents);
          const resolvedComparePriceCents = Number(resolved.comparePriceCents);
          return {
            currentPriceCents: Number.isFinite(currentPriceCents) ? currentPriceCents : Number(priceCents || 0),
            comparePriceCents:
              Number.isFinite(resolvedComparePriceCents) && resolvedComparePriceCents > currentPriceCents
                ? resolvedComparePriceCents
                : null,
          };
        }

        const normalizedPrice = Number(priceCents) || 0;
        const normalizedCompare = Number(comparePriceCents) || 0;
        return {
          currentPriceCents: normalizedPrice,
          comparePriceCents: normalizedCompare > normalizedPrice ? normalizedCompare : null,
        };
      };

      const applyVariant = (variant) => {
        if (!variant || !variant.id) return;
        variantIdInput.value = `${variant.id}`;
        const priceValue = Number(variant.price) || 0;
        const comparePriceValue = Number(variant.compare_at_price) || 0;
        const resolvedPricing = resolveDisplayPrice(priceValue, comparePriceValue);
        const hasCompare =
          Number.isFinite(resolvedPricing.comparePriceCents)
          && resolvedPricing.comparePriceCents > resolvedPricing.currentPriceCents;
        currentPriceElement.textContent = formatMoney(resolvedPricing.currentPriceCents);
        if (hasCompare) {
          comparePriceElement.textContent = formatMoney(resolvedPricing.comparePriceCents);
          comparePriceElement.hidden = false;
        } else {
          comparePriceElement.textContent = '';
          comparePriceElement.hidden = true;
        }

        const isAvailable = variant.available !== false;
        const availableLabel = submitButton.dataset.labelAvailable || '';
        const unavailableLabel = submitButton.dataset.labelUnavailable || '';
        const nextLabel = isAvailable ? availableLabel : unavailableLabel;
        buttonLabel.textContent = nextLabel;
        submitButton.disabled = !isAvailable;
        submitButton.setAttribute('aria-label', nextLabel);
      };

      applyVariant({
        id: Number(card.dataset.initialVariantId || '0'),
        price: Number(card.dataset.initialPrice || '0'),
        compare_at_price: Number(card.dataset.initialComparePrice || '0'),
      });

      const productRoot = Array.from(document.querySelectorAll('.sb-product-main')).find(
        (node) => `${node.dataset.productId || ''}` === `${productId}`
      ) || null;
      const productVariantIdInput = productRoot ? productRoot.querySelector('[data-product-variant-id]') : null;

      const syncFromSelectedProductItem = () => {
        if (!productRoot) return;
        const selectedSelectorItem = productRoot.querySelector('[data-selector-list-item].is-selected');
        if (!(selectedSelectorItem instanceof HTMLElement)) return;

        const selectedVariantId = Number(selectedSelectorItem.dataset.variantId || '0');
        if (!selectedVariantId) return;

        applyVariant({
          id: selectedVariantId,
          available: selectedSelectorItem.dataset.variantAvailable === 'true',
          price: Number(selectedSelectorItem.dataset.variantPrice || '0'),
          compare_at_price: Number(selectedSelectorItem.dataset.variantComparePrice || '0'),
        });
      };

      syncFromSelectedProductItem();

      if (productRoot) {
        productRoot.addEventListener('click', (event) => {
          if (!(event.target instanceof Element)) return;
          if (!event.target.closest('[data-selector-list-item], [data-option-value]')) return;
          window.requestAnimationFrame(syncFromSelectedProductItem);
        });
      }

      if (productVariantIdInput) {
        productVariantIdInput.addEventListener('change', () => {
          window.requestAnimationFrame(syncFromSelectedProductItem);
        });
      }

      document.addEventListener('variant:update', (event) => {
        const variant = event?.detail?.resource;
        const eventProductId = event?.detail?.data?.productId;
        if (!variant || `${eventProductId || ''}` !== `${productId}`) return;
        applyVariant(variant);
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const variantId = Number(variantIdInput.value || '0');
        if (!variantId) return;

        submitButton.disabled = true;

        try {
          if (window.SBCart && typeof window.SBCart.add === 'function') {
            await window.SBCart.add(variantId, {
              sourceElement: submitButton,
              sourceId: `hero-card-${variantId}`,
              sourceData: {
                source: 'hero-card',
              },
            });
          } else {
            throw new Error('SBCart unavailable');
          }
        } catch (_) {
          // no-op
        } finally {
          submitButton.disabled = false;
        }
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Hero card",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_seasonal_hero_card",
      "label": "Use seasonal hero card",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "use_resource_title_description",
      "label": "Use Shopify page title and description",
      "default": false,
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false }}"
    },
    {
      "type": "checkbox",
      "id": "use_product_page_metaobjects",
      "label": "Use product page metaobject",
      "default": false,
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background image desktop",
      "info": "Target minimum 1240x380 at 2x export (2480x760).",
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "Background image mobile",
      "info": "Target minimum 402x380 at 3x export (1206x1140).",
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.use_resource_title_description == false and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.use_resource_title_description == false and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "Show button",
      "default": false,
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Placeholder",
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.show_button and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "select",
      "id": "button_size",
      "label": "Button size",
      "default": "large",
      "options": [
        { "value": "large", "label": "Large" },
        { "value": "medium", "label": "Medium" }
      ],
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.show_button and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "select",
      "id": "icon_position",
      "label": "Icon position",
      "default": "none",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "leading", "label": "Leading" },
        { "value": "trailing", "label": "Trailing" }
      ],
      "visible_if": "{{ section.settings.use_seasonal_hero_card == false and section.settings.show_button and section.settings.use_product_page_metaobjects == false }}"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
