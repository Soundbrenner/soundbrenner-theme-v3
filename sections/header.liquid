<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{% liquid
  assign primary_navigation = section.settings.primary_navigation
  assign show_language = true
  if localization.available_languages.size <= 1
    assign show_language = false
  endif
  assign show_country = true
  if localization.available_countries.size <= 1
    assign show_country = false
  endif
  assign show_country_flag = true
  assign localization_position = 'right'
  assign seasonal_sale_name = settings.seasonal_sale_name | strip
  assign sale_name_token = '{{ Sale name }}'
  assign sitewide_discount_depth_token = '{{ Sitewide discount depth }}'
  assign shipping_country_token = '{{ Shipping country }}'
  assign free_shipping_threshold_token = '{{ Free shipping threshold }}'
  assign affiliate_name_token = '{{ Affiliate name }}'
  assign affiliate_discount_cookie_duration_hours = 336
  assign sitewide_seasonal_discount_depth = settings.sitewide_seasonal_discount_depth | default: 48 | strip
  assign sitewide_affiliate_discount_depth = settings.sitewide_affiliate_discount_depth | default: 20 | strip
  assign affiliate_announcement_gradient_value = 'linear-gradient(90deg, #67E8F9 0%, #1E293B 33%, #1E293B 66%, #67E8F9 100%)'
  assign header_affiliate_metaobject = blank
  if request.page_type == 'page' and page != blank
    assign header_affiliate_metaobject = page.metafields.custom.affiliate.value | default: page.metafields.custom.affiliate
    if header_affiliate_metaobject == blank
      assign header_affiliate_metaobject = page.metafields.custom.affiliate_deal.value | default: page.metafields.custom.affiliate_deal
    endif
    if header_affiliate_metaobject == blank
      assign header_affiliate_metaobject = page.metafields.custom.affiliate_profile.value | default: page.metafields.custom.affiliate_profile
    endif
  endif
  assign is_affiliate_page = false
  if header_affiliate_metaobject != blank
    assign is_affiliate_page = true
  endif
  assign use_affiliate_announcement_override = false
  if is_affiliate_page
    assign use_affiliate_announcement_override = true
  endif
  assign header_affiliate_name = ''
  assign header_affiliate_discount_code = ''
  if header_affiliate_metaobject != blank
    assign header_affiliate_name = header_affiliate_metaobject.full_name.value | default: header_affiliate_metaobject.full_name | strip
    if header_affiliate_name == blank
      assign header_affiliate_name = header_affiliate_metaobject.discount_name.value | default: header_affiliate_metaobject.discount_name | strip
    endif
    assign header_affiliate_discount_code = header_affiliate_metaobject.discount_name.value | default: header_affiliate_metaobject.discount_name | strip
  endif
  if header_affiliate_name == blank and page != blank
    assign header_affiliate_name = page.title | strip
  endif
  assign seasonal_shipping_country_name = localization.country.name | default: localization.country.iso_code | default: 'your country'
  assign seasonal_shipping_country_iso = localization.country.iso_code | upcase | strip
  assign seasonal_shipping_country_handle = seasonal_shipping_country_iso | downcase
  assign seasonal_shipping_is_blocked = false
  assign seasonal_shipping_has_free_shipping = false
  assign seasonal_free_shipping_threshold_display = ''
  assign seasonal_shipping_advertised_min_time = blank
  assign seasonal_shipping_advertised_max_time = blank
  assign cart_summary_shipping_text = 'Ships worldwide'
  assign cart_summary_taxes_text = 'May be due on delivery'
  assign seasonal_shipping_entry = shop.metaobjects['database_localized_shipping_info'][seasonal_shipping_country_handle]
  if seasonal_shipping_entry != blank and seasonal_shipping_country_iso != blank
    assign seasonal_entry_ship_to = seasonal_shipping_entry.ship_to_it.value | default: seasonal_shipping_entry.ship_to_it | append: '' | downcase
    assign seasonal_entry_has_free_shipping = seasonal_shipping_entry.free_shipping_available.value | default: seasonal_shipping_entry.free_shipping_available | append: '' | downcase
    assign seasonal_entry_taxes_included = seasonal_shipping_entry.taxes_included_in_price.value | default: seasonal_shipping_entry.taxes_included_in_price | append: '' | downcase
    assign seasonal_entry_threshold = seasonal_shipping_entry.free_shipping_threshold_in_local_currency.value | default: seasonal_shipping_entry.free_shipping_threshold_in_local_currency
    assign seasonal_shipping_advertised_min_time = seasonal_shipping_entry.advertised_min_time.value | default: seasonal_shipping_entry.advertised_min_time
    assign seasonal_shipping_advertised_max_time = seasonal_shipping_entry.advertised_max_time.value | default: seasonal_shipping_entry.advertised_max_time
    if seasonal_entry_ship_to == 'false' or seasonal_entry_ship_to == '0' or seasonal_entry_ship_to == 'no'
      assign seasonal_shipping_is_blocked = true
    endif
    if seasonal_entry_has_free_shipping == 'true' or seasonal_entry_has_free_shipping == '1' or seasonal_entry_has_free_shipping == 'yes'
      assign seasonal_shipping_has_free_shipping = true
    endif
    if seasonal_entry_taxes_included == 'true' or seasonal_entry_taxes_included == '1' or seasonal_entry_taxes_included == 'yes'
      assign cart_summary_taxes_text = 'Included in price'
    endif
    if seasonal_entry_threshold != blank
      assign seasonal_entry_threshold_cents = seasonal_entry_threshold | times: 100
      assign seasonal_free_shipping_threshold_display = seasonal_entry_threshold_cents | money_without_trailing_zeros
    endif
  endif
  assign seasonal_shipping_advertised_min_time_number = seasonal_shipping_advertised_min_time | plus: 0
  assign seasonal_shipping_advertised_max_time_number = seasonal_shipping_advertised_max_time | plus: 0
  if seasonal_shipping_entry == blank
    assign cart_summary_shipping_text = 'Ships worldwide'
  elsif seasonal_shipping_is_blocked
    assign cart_summary_shipping_text = "We're not shipping to " | append: seasonal_shipping_country_name
  elsif seasonal_shipping_advertised_min_time != blank and seasonal_shipping_advertised_max_time != blank and seasonal_shipping_advertised_min_time_number < 11 and seasonal_shipping_advertised_max_time_number < 12
    assign cart_summary_shipping_text = seasonal_shipping_advertised_min_time | append: '-' | append: seasonal_shipping_advertised_max_time | append: ' days delivery in ' | append: seasonal_shipping_country_name
  else
    assign cart_summary_shipping_text = 'Ships to ' | append: seasonal_shipping_country_name
  endif

  assign announcement_text_free_shipping = settings.seasonal_announcement_copy_free_shipping | strip
  assign announcement_text_no_free_shipping = settings.seasonal_announcement_copy_no_free_shipping | strip
  assign announcement_text_blocked = settings.seasonal_announcement_copy_blocked | strip
  if announcement_text_free_shipping == blank
    assign announcement_text_free_shipping = '{{ Sale name }}: {{ Sitewide discount depth }}% off & free shipping in {{ Shipping country }} over {{ Free shipping threshold }}'
  endif
  if announcement_text_no_free_shipping == blank
    assign announcement_text_no_free_shipping = '{{ Sale name }}: {{ Sitewide discount depth }}% off in {{ Shipping country }}'
  endif
  if announcement_text_blocked == blank
    assign announcement_text_blocked = "We're not shipping to {{ Shipping country }}. Select a different country."
  endif

  if seasonal_shipping_is_blocked
    assign announcement_text = announcement_text_blocked
  elsif seasonal_shipping_has_free_shipping
    assign announcement_text = announcement_text_free_shipping
  else
    assign announcement_text = announcement_text_no_free_shipping
  endif

  if use_affiliate_announcement_override
    assign resolved_sale_name = header_affiliate_name
    assign resolved_discount_depth = sitewide_affiliate_discount_depth
    assign announcement_gradient = affiliate_announcement_gradient_value
  else
    assign resolved_sale_name = seasonal_sale_name
    assign resolved_discount_depth = sitewide_seasonal_discount_depth
    assign announcement_gradient = settings.seasonal_announcement_gradient | default: 'linear-gradient(90deg, #E9CC92 0%, #92734F 33%, #92734F 66%, #E9CC92 100%)'
  endif
  assign announcement_text = announcement_text | replace: sale_name_token, resolved_sale_name
  assign announcement_text = announcement_text | replace: sitewide_discount_depth_token, resolved_discount_depth
  assign announcement_text = announcement_text | replace: shipping_country_token, seasonal_shipping_country_name
  assign announcement_text = announcement_text | replace: free_shipping_threshold_token, seasonal_free_shipping_threshold_display
  assign announcement_text = announcement_text | replace: affiliate_name_token, resolved_sale_name
  if seasonal_shipping_is_blocked
    assign affiliate_announcement_text_template = announcement_text_blocked
  elsif seasonal_shipping_has_free_shipping
    assign affiliate_announcement_text_template = announcement_text_free_shipping
  else
    assign affiliate_announcement_text_template = announcement_text_no_free_shipping
  endif
  assign affiliate_announcement_text_template = affiliate_announcement_text_template | replace: sale_name_token, affiliate_name_token
  assign affiliate_announcement_text_template = affiliate_announcement_text_template | replace: sitewide_discount_depth_token, sitewide_affiliate_discount_depth
  assign affiliate_announcement_text_template = affiliate_announcement_text_template | replace: shipping_country_token, seasonal_shipping_country_name
  assign affiliate_announcement_text_template = affiliate_announcement_text_template | replace: free_shipping_threshold_token, seasonal_free_shipping_threshold_display
  assign show_announcement = false
  if announcement_text != blank
    assign show_announcement = true
  endif
  assign sale_end_date = settings.seasonal_sale_end_date | strip
  assign show_announcement_countdown = false
  if show_announcement and sale_end_date != blank and seasonal_shipping_is_blocked == false and use_affiliate_announcement_override == false
    assign show_announcement_countdown = true
  endif
  assign countdown_initial_days = '00'
  assign countdown_initial_hours = '00'
  assign countdown_initial_mins = '00'
  assign countdown_initial_secs = '00'
  assign countdown_initial_show = false
  assign countdown_display_threshold_seconds = 432000
  if show_announcement_countdown
    assign countdown_now_timestamp = 'now' | date: '%s' | plus: 0
    assign countdown_end_timestamp = sale_end_date | append: ' 23:59:59' | date: '%s' | plus: 0
    if countdown_end_timestamp > 0
      assign countdown_remaining_seconds = countdown_end_timestamp | minus: countdown_now_timestamp
      if countdown_remaining_seconds < 0
        assign countdown_remaining_seconds = 0
      endif
      if countdown_remaining_seconds > 0 and countdown_remaining_seconds <= countdown_display_threshold_seconds
        assign countdown_initial_show = true
      endif

      assign countdown_days_number = countdown_remaining_seconds | divided_by: 86400
      assign countdown_hours_number = countdown_remaining_seconds | modulo: 86400 | divided_by: 3600
      assign countdown_mins_number = countdown_remaining_seconds | modulo: 3600 | divided_by: 60
      assign countdown_secs_number = countdown_remaining_seconds | modulo: 60

      if countdown_days_number > 99
        assign countdown_days_number = 99
      endif
      if countdown_hours_number > 99
        assign countdown_hours_number = 99
      endif
      if countdown_mins_number > 99
        assign countdown_mins_number = 99
      endif
      if countdown_secs_number > 99
        assign countdown_secs_number = 99
      endif

      assign countdown_initial_days = countdown_days_number | prepend: '0' | slice: -2, 2
      assign countdown_initial_hours = countdown_hours_number | prepend: '0' | slice: -2, 2
      assign countdown_initial_mins = countdown_mins_number | prepend: '0' | slice: -2, 2
      assign countdown_initial_secs = countdown_secs_number | prepend: '0' | slice: -2, 2
    endif
  endif
  assign announcement_emoji_asset = 'emoji-sale-new-year.png'
  assign trustpilot_entry = metaobjects.trustpilot.values | first
  assign trustpilot_url = 'https://www.trustpilot.com/review/soundbrenner.com'
  assign trustpilot_rating_raw = trustpilot_entry.rating.value | default: trustpilot_entry.rating
  if trustpilot_rating_raw != blank
    assign trustpilot_rating_text = trustpilot_rating_raw | append: ' out of 5'
  else
    assign trustpilot_rating_text = 'X.X out of 5'
  endif
  assign metronome_rating_raw = trustpilot_entry.the_metronome_app_review_rating.value | default: trustpilot_entry.the_metronome_app_review_rating
  assign metronome_count_raw = trustpilot_entry.the_metronome_app_review_count.value | default: trustpilot_entry.the_metronome_app_review_count
  assign metronome_rating_display = metronome_rating_raw | strip
  assign metronome_count_display = metronome_count_raw | strip
  assign cart_placeholder_image = 'icon-square-placeholder.svg' | asset_url
  assign affiliate_announcement_emoji_asset_url = 'emoji-sale-affiliate.png' | asset_url

  case announcement_gradient
    when 'linear-gradient(90deg, #E9CC92 0%, #92734F 33%, #92734F 66%, #E9CC92 100%)'
      assign announcement_emoji_asset = 'emoji-sale-new-year.png'
    when 'linear-gradient(90deg, #F3C1DE 0%, #C77CA5 33%, #C77CA5 66%, #F3C1DE 100%)'
      assign announcement_emoji_asset = 'emoji-sale-valentines-day.png'
    when 'linear-gradient(90deg, #A4CF83 0%, #768E57 33%, #768E57 66%, #A4CF83 100%)'
      assign announcement_emoji_asset = 'emoji-sale-spring.png'
    when 'linear-gradient(90deg, #B19CD9 0%, #7B5EA7 33%, #7B5EA7 66%, #B19CD9 100%)'
      assign announcement_emoji_asset = 'emoji-sale-easter.png'
    when 'linear-gradient(90deg, #9CBDCD 0%, #F08835 33%, #F08835 66%, #9CBDCD 100%)'
      assign announcement_emoji_asset = 'emoji-sale-summer.png'
    when 'linear-gradient(90deg, #E6A53C 0%, #1E4F8F 33%, #1E4F8F 66%, #E6A53C 100%)'
      assign announcement_emoji_asset = 'emoji-sale-back-to-school.png'
    when 'linear-gradient(90deg, #1F3937 0%, #57522A 33%, #E58C56 66%, #6F351F 100%)'
      assign announcement_emoji_asset = 'emoji-sale-fall.png'
    when 'linear-gradient(90deg, #2F173A 0%, #D84418 33%, #D84418 66%, #2F173A 100%)'
      assign announcement_emoji_asset = 'emoji-sale-halloween.png'
    when 'linear-gradient(90deg, #8759F1 0%, #023CFB 33%, #8759F1 66%, #023CFB 100%)'
      assign announcement_emoji_asset = 'emoji-sale-bfcm.png'
    when 'linear-gradient(90deg, #B49F76 0%, #C32B2E 33%, #C32B2E 66%, #B49F76 100%)'
      assign announcement_emoji_asset = 'emoji-sale-holiday.png'
    when 'linear-gradient(90deg, var(--sb-color-primary-500) 0%, var(--sb-color-primary-700) 33%, var(--sb-color-primary-700) 66%, var(--sb-color-primary-500) 100%)'
      assign announcement_emoji_asset = 'emoji-sale-anniversary.png'
    when 'linear-gradient(90deg, #67E8F9 0%, #1E293B 33%, #1E293B 66%, #67E8F9 100%)'
      assign announcement_emoji_asset = 'emoji-sale-affiliate.png'
  endcase
%}
{% if show_country or show_language %}
  <script src="{{ 'localization.js' | asset_url }}" defer></script>
{% endif %}
<script src="{{ 'cart-system.js' | asset_url }}" defer></script>
{% if is_affiliate_page and header_affiliate_discount_code != blank %}
  <script>
    (() => {
      const code = {{ header_affiliate_discount_code | json }};
      if (!code) return;
      const appliedKey = `sb-affiliate-discount-applied-${code}`;
      const pendingKey = `sb-affiliate-discount-pending-${code}`;

      try {
        if (window.sessionStorage.getItem(appliedKey) === '1') return;
        if (window.sessionStorage.getItem(pendingKey) === '1') {
          window.sessionStorage.removeItem(pendingKey);
          window.sessionStorage.setItem(appliedKey, '1');
          return;
        }
      } catch (_) {
        return;
      }

      const currentUrl = new URL(window.location.href);
      const redirectUrl = `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`;

      try {
        window.sessionStorage.setItem(pendingKey, '1');
      } catch (_) {
        return;
      }

      const destination = `/discount/${encodeURIComponent(code)}?redirect=${encodeURIComponent(redirectUrl)}`;
      window.location.replace(destination);
    })();
  </script>
{% endif %}

<header
  class="header full-width{% if show_announcement %} has-announcement{% endif %}"
  data-affiliate-announcement-template="{{ affiliate_announcement_text_template | escape }}"
  data-affiliate-announcement-gradient="{{ affiliate_announcement_gradient_value | escape }}"
  data-affiliate-announcement-emoji="{{ affiliate_announcement_emoji_asset_url | escape }}"
  data-affiliate-name-token="{{ affiliate_name_token | escape }}"
  data-affiliate-discount-code="{{ header_affiliate_discount_code | escape }}"
  data-affiliate-name="{{ header_affiliate_name | escape }}"
  data-affiliate-cookie-duration-hours="{{ affiliate_discount_cookie_duration_hours }}"
  {% if show_announcement %}
    style="--sb-announcement-background: {{ announcement_gradient }};"
  {% endif %}
>
  {% if show_announcement %}
    <div class="header__announcement">
      <div class="header__announcement-content">
        <div class="header__announcement-emojis" aria-hidden="true">
          <span class="header__announcement-emoji header__announcement-emoji--left">
            <img src="{{ announcement_emoji_asset | asset_url }}" alt="" loading="eager" width="20" height="20">
          </span>
          <span class="header__announcement-emoji header__announcement-emoji--right">
            <img src="{{ announcement_emoji_asset | asset_url }}" alt="" loading="eager" width="20" height="20">
          </span>
        </div>

        <div class="header__announcement-top">
          <p class="header__announcement-text font-caption weight-semibold">{{ announcement_text | escape | newline_to_br }}</p>
        </div>

        {% if show_announcement_countdown %}
          <div
            class="header__announcement-countdown"
            data-announcement-countdown
            data-sale-end-date="{{ sale_end_date | escape }}"
            {% unless countdown_initial_show %}
              hidden
            {% endunless %}
          >
            <div class="header__announcement-countdown-group">
              <span class="header__announcement-countdown-value font-caption weight-bold" data-countdown-days>{{ countdown_initial_days }}</span>
              <span class="header__announcement-countdown-label font-caption2 weight-semibold">days</span>
            </div>
            <div class="header__announcement-countdown-group">
              <span class="header__announcement-countdown-value font-caption weight-bold" data-countdown-hours>{{ countdown_initial_hours }}</span>
              <span class="header__announcement-countdown-label font-caption2 weight-semibold">hours</span>
            </div>
            <div class="header__announcement-countdown-group">
              <span class="header__announcement-countdown-value font-caption weight-bold" data-countdown-mins>{{ countdown_initial_mins }}</span>
              <span class="header__announcement-countdown-label font-caption2 weight-semibold">mins</span>
            </div>
            <div class="header__announcement-countdown-group">
              <span class="header__announcement-countdown-value font-caption weight-bold" data-countdown-secs>{{ countdown_initial_secs }}</span>
              <span class="header__announcement-countdown-label font-caption2 weight-semibold">secs</span>
            </div>
          </div>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <div class="header__inner">
    <div class="header__icons header__icons--left">
      <button
        type="button"
        class="header__icon-link header__icon-link--menu"
        aria-label="Menu"
        aria-expanded="false"
        data-mobile-menu-toggle
      >
        <span class="header__icon-asset" aria-hidden="true">
          {{ 'icon-primary-navigation-menu.svg' | inline_asset_content }}
        </span>
      </button>
    </div>

    <a class="header__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      <span class="header__brand-logo" aria-hidden="true">
        {{ 'logo-soundbrenner-wordmark.svg' | inline_asset_content }}
      </span>
    </a>

    <nav class="header__menu" aria-label="Primary">
      {% if primary_navigation != blank and primary_navigation.links.size > 0 %}
        {% for link in primary_navigation.links %}
          {% liquid
            assign link_index = forloop.index
            assign link_path = link.url | split: '?' | first
            assign is_active_link = false
            if link.current or request.path == link_path
              assign is_active_link = true
            endif

            assign has_primary_cards = false
            assign dropdown_card_count = 0

            for block in section.blocks
              if block.type == 'primary_item_product' or block.type == 'primary_item_collection' or block.type == 'primary_item_page' or block.type == 'primary_item_app'
                assign card_menu_index = block.settings.menu_item_index | plus: 0
                if card_menu_index == link_index
                  assign has_primary_cards = true
                  assign dropdown_card_count = dropdown_card_count | plus: 1
                endif
              endif
            endfor

            assign has_dropdown = false
            if has_primary_cards
              assign has_dropdown = true
            endif

            assign dropdown_card_count = dropdown_card_count | at_least: 1 | at_most: 4
          %}

          <div class="header__menu-item{% if has_dropdown %} has-dropdown{% endif %}">
            <a
              class="header__menu-link font-caption weight-regular{% if is_active_link %} is-active{% endif %}"
              href="{{ link.url }}"
            >
              {{ link.title }}
            </a>

            {% if has_dropdown %}
              <div class="header__primary-menu" aria-label="{{ link.title | escape }}" style="--sb-primary-columns: {{ dropdown_card_count }};">
                <div class="header__primary-menu-panel">
                  <div class="header__primary-menu-panel-inner">
                  <a class="header__primary-menu-title font-callout weight-bold" href="{{ link.url }}">{{ link.title }}</a>
                  <div class="header__primary-menu-grid">
                    {% for block in section.blocks %}
                      {% liquid
                        assign block_type_key = block.type

                        if block_type_key != 'primary_item_product' and block_type_key != 'primary_item_collection' and block_type_key != 'primary_item_page' and block_type_key != 'primary_item_app'
                          continue
                        endif

                        assign block_menu_index = block.settings.menu_item_index | plus: 0
                        if block_menu_index != link_index
                          continue
                        endif
                        assign app_mode = false
                        assign card_product = blank
                        assign card_collection = blank
                        assign card_page = blank
                        assign hide_on_mobile = false

                        case block_type_key
                          when 'primary_item_product'
                            assign card_product = block.settings.product
                          when 'primary_item_collection'
                            assign card_collection = block.settings.collection
                            assign hide_on_mobile = block.settings.hide_on_mobile
                          when 'primary_item_page'
                            assign card_page = block.settings.page
                          when 'primary_item_app'
                            assign app_mode = true
                        endcase
                        assign card_image = block.settings.image
                        assign card_title = blank
                        assign card_body = blank
                        assign card_link = blank
                        assign card_rating_value = 4.8
                        assign card_rating_display = metronome_rating_display | default: '4.8'
                        assign card_rating_count_display = metronome_count_display | default: '100K+'
                        assign card_star_icon_url = 'icon-review-star.svg' | asset_url
                        assign card_app_store_link = 'https://apps.apple.com/us/app/the-metronome-by-soundbrenner/id1048954353'
                        assign card_google_play_link = 'https://play.google.com/store/apps/details?id=com.soundbrenner.pulse'

                        if app_mode == true
                          assign app_page = block.settings.app_page
                          if app_page != blank
                            assign card_link = app_page.url
                          else
                            assign card_link = routes.root_url | append: 'pages/the-app'
                          endif
                          assign card_title = 'The Metronome app'
                          assign card_body = 'Download for iOS and Android'
                          assign parsed_rating_value = card_rating_display | split: ' ' | first | plus: 0
                          if parsed_rating_value > 0
                            assign card_rating_value = parsed_rating_value
                          endif
                        else
                          if card_product != blank
                            assign card_link = card_product.url
                            assign card_title = card_product.title
                            assign product_settings_ref = card_product.metafields.custom.sbv2_product_settings.value | default: card_product.metafields.custom.sbv2_product_settings
                            if product_settings_ref != blank
                              assign card_body = product_settings_ref.tagline.value | default: product_settings_ref.tagline
                            endif
                            if card_body == blank and card_product.description != blank
                              assign card_body = card_product.description | strip_html
                            endif
                          elsif card_collection != blank
                            assign card_link = card_collection.url
                            assign card_title = card_collection.title
                            assign card_body = card_collection.description | strip_html
                          elsif card_page != blank
                            assign card_link = card_page.url
                            assign card_title = card_page.title
                            assign card_body = card_page.content | strip_html
                          endif
                        endif

                        assign card_image_url = blank
                        if card_image != blank
                          assign card_image_url = card_image | image_url: width: 502
                        endif

                        assign card_badge_label = blank
                        assign card_badge_type = blank
                        if card_product != blank and card_product.tags != blank
                          for product_tag in card_product.tags
                            assign product_tag_downcase = product_tag | downcase
                            if product_tag_downcase == 'bestseller'
                              assign card_badge_label = 'Bestseller'
                              assign card_badge_type = 'bestseller'
                              break
                            endif
                            if product_tag_downcase == 'new'
                              assign card_badge_label = 'New'
                              assign card_badge_type = 'new'
                            endif
                          endfor
                        endif
                      %}

                      <article class="header__primary-card" data-hide-on-mobile="{{ hide_on_mobile }}" {{ block.shopify_attributes }}>
                        <a class="header__primary-card-media" href="{{ card_link | default: '#' }}">
                          {% if card_badge_label != blank %}
                            <span class="header__primary-card-badge header__primary-card-badge--{{ card_badge_type }} font-caption weight-semibold">
                              {{ card_badge_label }}
                            </span>
                          {% endif %}

                          {% # theme-check-disable RemoteAsset %}
                          {% if card_image_url != blank %}
                            <img
                              class="header__primary-card-image"
                              src="{{ card_image_url }}"
                              alt="{{ card_title | default: link.title | escape }}"
                              loading="eager"
                              fetchpriority="low"
                              decoding="async"
                              width="502"
                              height="502"
                            >
                          {% else %}
                            <img
                              class="header__primary-card-image"
                              src="{{ 'placeholder-primary-navigation-item.jpg' | asset_url }}"
                              alt="{{ card_title | default: link.title | escape }}"
                              loading="eager"
                              fetchpriority="low"
                              decoding="async"
                              width="502"
                              height="502"
                            >
                          {% endif %}
                          {% # theme-check-enable RemoteAsset %}
                        </a>

                        <p class="header__primary-card-title font-body weight-bold">
                          <a class="header__primary-card-title-link" href="{{ card_link | default: '#' }}">{{ card_title | default: link.title }}</a>
                        </p>

                        {% if app_mode == true %}
                          <div class="header__primary-card-app">
                            <p class="header__primary-card-rating font-caption weight-semibold">
                              <span class="header__primary-card-stars" aria-hidden="true">
                                {% for star_index in (1..5) %}
                                  {% assign prior_stars = star_index | minus: 1 %}
                                  {% assign star_fill = 0 %}
                                  {% if card_rating_value >= star_index %}
                                    {% assign star_fill = 100 %}
                                  {% elsif card_rating_value > prior_stars %}
                                    {% assign star_fill = card_rating_value | minus: prior_stars | times: 100 | round %}
                                  {% endif %}
                                  <span class="header__primary-card-star" style="--sb-star-fill: {{ star_fill }}%; --sb-star-icon-url: url('{{ card_star_icon_url }}');"></span>
                                {% endfor %}
                              </span>
                              <span>{{ card_rating_display }}</span>
                            </p>
                            <p class="header__primary-card-rating-count font-caption weight-regular">{{ card_rating_count_display }} ratings</p>

                            <div class="header__primary-card-app-links">
                              <a href="{{ card_app_store_link }}" target="_blank" rel="noopener noreferrer" aria-label="Download on the App Store">
                                <img
                                  src="{{ 'app-download-app-store.png' | asset_url }}"
                                  alt="Download on the App Store"
                                  loading="lazy"
                                  width="100"
                                  height="30"
                                >
                              </a>
                              <a href="{{ card_google_play_link }}" target="_blank" rel="noopener noreferrer" aria-label="Get it on Google Play">
                                <img
                                  src="{{ 'app-download-google-play.png' | asset_url }}"
                                  alt="Get it on Google Play"
                                  loading="lazy"
                                  width="100"
                                  height="30"
                                >
                              </a>
                            </div>
                          </div>
                        {% else %}
                          {% if card_body != blank %}
                            <p class="header__primary-card-body font-caption weight-regular">{{ card_body }}</p>
                          {% endif %}

                          {% if block_type_key == 'primary_item_product' %}
                            {% assign accessories_collection = block.settings.accessories_collection %}
                            {% if accessories_collection == blank and card_product != blank and card_product.collections != blank %}
                              {% assign fallback_non_generic_collection = blank %}
                              {% for candidate_collection in card_product.collections %}
                                {% assign candidate_handle = candidate_collection.handle | downcase %}
                                {% assign candidate_title = candidate_collection.title | downcase %}
                                {% if candidate_handle contains 'accessor' or candidate_title contains 'accessor' %}
                                  {% assign accessories_collection = candidate_collection %}
                                  {% break %}
                                {% endif %}

                                {% if fallback_non_generic_collection == blank %}
                                  {% assign is_generic_collection = false %}
                                  {% if candidate_handle == 'all' or candidate_handle == 'all-products' or candidate_handle contains 'shop-all' or candidate_title contains 'shop all' %}
                                    {% assign is_generic_collection = true %}
                                  {% endif %}
                                  {% unless is_generic_collection %}
                                    {% assign fallback_non_generic_collection = candidate_collection %}
                                  {% endunless %}
                                {% endif %}
                              {% endfor %}
                              {% if accessories_collection == blank %}
                                {% if fallback_non_generic_collection != blank %}
                                  {% assign accessories_collection = fallback_non_generic_collection %}
                                {% else %}
                                  {% assign accessories_collection = card_product.collections.first %}
                                {% endif %}
                              {% endif %}
                            {% endif %}
                            {% if accessories_collection != blank %}
                              <ul class="header__primary-card-links font-caption weight-semibold" role="list">
                                <li>
                                  <a href="{{ accessories_collection.url }}">Accessories</a>
                                </li>
                              </ul>
                            {% endif %}
                          {% elsif block_type_key == 'primary_item_collection' %}
                            {% assign linked_product_1 = block.settings.related_product_1 %}
                            {% assign linked_product_2 = block.settings.related_product_2 %}
                            {% assign linked_product_3 = block.settings.related_product_3 %}
                            {% assign has_card_links = false %}
                            {% if linked_product_1 != blank or linked_product_2 != blank or linked_product_3 != blank %}
                              {% assign has_card_links = true %}
                            {% endif %}
                            {% if has_card_links %}
                              <ul class="header__primary-card-links font-caption weight-semibold" role="list">
                                {% if linked_product_1 != blank %}
                                  {% assign linked_product_1_settings = linked_product_1.metafields.custom.sbv2_product_settings.value | default: linked_product_1.metafields.custom.sbv2_product_settings %}
                                  {% assign linked_product_1_tagline = blank %}
                                  {% if linked_product_1_settings != blank %}
                                    {% assign linked_product_1_tagline = linked_product_1_settings.tagline.value | default: linked_product_1_settings.tagline %}
                                  {% endif %}
                                  <li>
                                    <a
                                      href="{{ linked_product_1.url }}"
                                      data-mobile-product-title="{{ linked_product_1.title | escape }}"
                                      data-mobile-product-description="{{ linked_product_1.description | strip_html | escape }}"
                                      data-mobile-product-tagline="{{ linked_product_1_tagline | escape }}"
                                    >
                                      {{ linked_product_1.title }}
                                    </a>
                                  </li>
                                {% endif %}
                                {% if linked_product_2 != blank %}
                                  {% assign linked_product_2_settings = linked_product_2.metafields.custom.sbv2_product_settings.value | default: linked_product_2.metafields.custom.sbv2_product_settings %}
                                  {% assign linked_product_2_tagline = blank %}
                                  {% if linked_product_2_settings != blank %}
                                    {% assign linked_product_2_tagline = linked_product_2_settings.tagline.value | default: linked_product_2_settings.tagline %}
                                  {% endif %}
                                  <li>
                                    <a
                                      href="{{ linked_product_2.url }}"
                                      data-mobile-product-title="{{ linked_product_2.title | escape }}"
                                      data-mobile-product-description="{{ linked_product_2.description | strip_html | escape }}"
                                      data-mobile-product-tagline="{{ linked_product_2_tagline | escape }}"
                                    >
                                      {{ linked_product_2.title }}
                                    </a>
                                  </li>
                                {% endif %}
                                {% if linked_product_3 != blank %}
                                  {% assign linked_product_3_settings = linked_product_3.metafields.custom.sbv2_product_settings.value | default: linked_product_3.metafields.custom.sbv2_product_settings %}
                                  {% assign linked_product_3_tagline = blank %}
                                  {% if linked_product_3_settings != blank %}
                                    {% assign linked_product_3_tagline = linked_product_3_settings.tagline.value | default: linked_product_3_settings.tagline %}
                                  {% endif %}
                                  <li>
                                    <a
                                      href="{{ linked_product_3.url }}"
                                      data-mobile-product-title="{{ linked_product_3.title | escape }}"
                                      data-mobile-product-description="{{ linked_product_3.description | strip_html | escape }}"
                                      data-mobile-product-tagline="{{ linked_product_3_tagline | escape }}"
                                    >
                                      {{ linked_product_3.title }}
                                    </a>
                                  </li>
                                {% endif %}
                              </ul>
                            {% endif %}
                          {% endif %}
                        {% endif %}
                      </article>
                    {% endfor %}
                  </div>
                  </div>
                </div>
              </div>
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </nav>

    <div class="header__icons header__icons--right">
      {% if show_country or show_language %}
        {% if show_country %}
          <dropdown-localization-component class="header__localization header__icon-link--desktop-only">
            <button
              type="button"
              class="header__localization-button font-caption2 weight-semibold"
              aria-label="Region selector"
              aria-expanded="false"
              aria-controls="HeaderLocalizationPanel-{{ section.id }}"
              data-localization-ref="button"
            >
              <span
                class="header__localization-flag"
                aria-hidden="true"
                style="background-image: url('{{ localization.country | image_url: width: 40 }}');"
              ></span>
            </button>
            <div
              id="HeaderLocalizationPanel-{{ section.id }}"
              class="header__localization-panel header__localization-panel--{{ localization_position }}"
              data-localization-ref="panel"
            >
              <div class="header__localization-panel-surface">
                <div class="header__localization-panel-inner">
                  {% render 'localization-form',
                    show_country: show_country,
                    show_language: show_language,
                    localization_style: 'dropdown',
                    form_id: section.id | append: '-dropdown'
                  %}
                </div>
              </div>
            </div>
          </dropdown-localization-component>
        {% elsif show_language %}
          <div class="header__localization header__localization--language-only header__icon-link--desktop-only">
            {% render 'localization-form',
              show_country: false,
              show_language: show_language,
              localization_style: 'dropdown',
              form_id: section.id | append: '-inline'
            %}
          </div>
        {% endif %}
      {% endif %}
      <div class="header__utility-icons" style="min-width: var(--sb-space-20);">
        <a
          class="header__icon-link header__icon-link--cart"
          href="{{ routes.cart_url }}"
          data-header-cart-link
          data-header-cart-page="{% if request.page_type == 'cart' %}true{% else %}false{% endif %}"
          aria-label="Cart"
          aria-expanded="false"
          style="align-items: center; display: inline-flex; height: var(--sb-space-20); justify-content: center; min-height: var(--sb-space-20); min-width: var(--sb-space-20); width: var(--sb-space-20);"
        >
          <span class="header__cart-count-badge font-caption weight-bold{% if cart.item_count > 9 %} is-double-digit{% endif %}" data-header-cart-count {% if cart.item_count == 0 %}hidden{% endif %}>
            {% if cart.item_count > 99 %}99+{% else %}{{ cart.item_count }}{% endif %}
          </span>
          <span class="header__icon-asset" aria-hidden="true" style="align-items: center; display: inline-flex; height: var(--sb-space-20); justify-content: center; width: var(--sb-space-20);">
            {{ 'icon-primary-navigation-cart.svg' | inline_asset_content }}
          </span>
        </a>
      </div>
    </div>
  </div>
</header>
<div class="menu-drawer-container" data-mobile-menu-drawer>
  <div class="menu-drawer" data-mobile-menu-panel>
    <nav class="menu-drawer__navigation" aria-label="Primary navigation">
      <button
        class="menu-drawer__close-button"
        type="button"
        aria-label="Close menu"
        data-mobile-menu-close
      >
        <span class="menu-drawer__close-icon" aria-hidden="true">
          {{ 'icon-cancel.svg' | inline_asset_content }}
        </span>
      </button>
      <ul class="menu-drawer__menu has-submenu" role="list">
        {% if primary_navigation != blank and primary_navigation.links.size > 0 %}
          {% for link in primary_navigation.links %}
            {% liquid
              assign drawer_link_index = forloop.index
              assign has_drawer_submenu = false

              for block in section.blocks
                if block.type == 'primary_item_product' or block.type == 'primary_item_collection' or block.type == 'primary_item_page' or block.type == 'primary_item_app'
                  assign block_menu_index = block.settings.menu_item_index | plus: 0
                  if block_menu_index == drawer_link_index
                    assign has_drawer_submenu = true
                    break
                  endif
                endif
              endfor
            %}
            <li class="menu-drawer__list-item" style="--menu-drawer-animation-index: {{ forloop.index }};">
              {% if has_drawer_submenu %}
                <details class="menu-drawer__menu-container">
                  <summary class="menu-drawer__menu-item menu-drawer__menu-item--mainlist menu-drawer__animated-element">
                    <span class="menu-drawer__menu-item-text font-callout weight-semibold">{{ link.title | escape }}</span>
                    <span class="menu-drawer__menu-item-indicator" aria-hidden="true">
                      <span class="menu-drawer__menu-item-indicator-plus">{{ 'icon-accordion-add.svg' | inline_asset_content }}</span>
                      <span class="menu-drawer__menu-item-indicator-close">{{ 'icon-accordion-close.svg' | inline_asset_content }}</span>
                    </span>
                  </summary>
                  <ul class="menu-drawer__menu menu-drawer__menu--childlist" role="list">
                    {% assign drawer_submenu_animation_index = 0 %}
                    {% for block in section.blocks %}
                      {% liquid
                        assign drawer_block_type_key = block.type

                        if drawer_block_type_key != 'primary_item_product' and drawer_block_type_key != 'primary_item_collection' and drawer_block_type_key != 'primary_item_page' and drawer_block_type_key != 'primary_item_app'
                          continue
                        endif

                        assign block_menu_index = block.settings.menu_item_index | plus: 0
                        if block_menu_index != drawer_link_index
                          continue
                        endif

                        assign drawer_card_link = blank
                        assign drawer_card_title = blank
                        assign drawer_card_body = blank
                        assign drawer_card_image_url = blank
                        assign drawer_badge_label = blank
                        assign drawer_badge_type = blank
                        assign drawer_is_app = false
                        assign drawer_star_icon_url = 'icon-review-star.svg' | asset_url
                        assign drawer_rating_display = metronome_rating_display | default: '4.8'
                        assign drawer_rating_count_display = metronome_count_display | default: '100K+'
                        assign drawer_rating_value = 4.8
                        assign drawer_app_store_link = 'https://apps.apple.com/us/app/the-metronome-by-soundbrenner/id1048954353'
                        assign drawer_google_play_link = 'https://play.google.com/store/apps/details?id=com.soundbrenner.pulse'
                        assign drawer_card_product = blank
                        assign drawer_card_collection = blank
                        assign drawer_card_page = blank
                        assign drawer_hide_primary_tile = false
                        assign drawer_accessories_collection = blank
                        assign drawer_related_product_1 = blank
                        assign drawer_related_product_2 = blank
                        assign drawer_related_product_3 = blank
                        assign drawer_related_product_1_image = blank
                        assign drawer_related_product_2_image = blank
                        assign drawer_related_product_3_image = blank
                        assign drawer_related_product_1_hide_on_mobile = false
                        assign drawer_related_product_2_hide_on_mobile = false
                        assign drawer_related_product_3_hide_on_mobile = false

                        case drawer_block_type_key
                          when 'primary_item_product'
                            assign drawer_card_product = block.settings.product
                          when 'primary_item_collection'
                            assign drawer_card_collection = block.settings.collection
                            assign drawer_hide_primary_tile = block.settings.hide_on_mobile
                            assign drawer_related_product_1 = block.settings.related_product_1
                            assign drawer_related_product_2 = block.settings.related_product_2
                            assign drawer_related_product_3 = block.settings.related_product_3
                            assign drawer_related_product_1_image = block.settings.related_product_1_image
                            assign drawer_related_product_2_image = block.settings.related_product_2_image
                            assign drawer_related_product_3_image = block.settings.related_product_3_image
                            assign drawer_related_product_1_hide_on_mobile = block.settings.related_product_1_hide | default: false
                            assign drawer_related_product_2_hide_on_mobile = block.settings.related_product_2_hide | default: false
                            assign drawer_related_product_3_hide_on_mobile = block.settings.related_product_3_hide | default: false
                          when 'primary_item_page'
                            assign drawer_card_page = block.settings.page
                          when 'primary_item_app'
                            assign drawer_is_app = true
                            assign drawer_card_page = block.settings.app_page
                            assign drawer_card_title = 'The Metronome app'
                        endcase

                        if drawer_card_product != blank
                          assign drawer_card_link = drawer_card_product.url
                          assign drawer_card_title = drawer_card_product.title
                          assign drawer_product_settings_ref = drawer_card_product.metafields.custom.sbv2_product_settings.value | default: drawer_card_product.metafields.custom.sbv2_product_settings
                          if drawer_product_settings_ref != blank
                            assign drawer_card_body = drawer_product_settings_ref.tagline.value | default: drawer_product_settings_ref.tagline
                          endif
                          if drawer_card_body == blank and drawer_card_product.description != blank
                            assign drawer_card_body = drawer_card_product.description | strip_html
                          endif

                          if drawer_card_product.tags != blank
                            for drawer_product_tag in drawer_card_product.tags
                              assign drawer_product_tag_downcase = drawer_product_tag | downcase
                              if drawer_product_tag_downcase == 'bestseller'
                                assign drawer_badge_label = 'Bestseller'
                                assign drawer_badge_type = 'bestseller'
                                break
                              endif
                              if drawer_product_tag_downcase == 'new'
                                assign drawer_badge_label = 'New'
                                assign drawer_badge_type = 'new'
                              endif
                            endfor
                          endif

                          assign drawer_accessories_collection = block.settings.accessories_collection
                          if drawer_accessories_collection == blank and drawer_card_product.collections != blank
                            assign drawer_fallback_non_generic_collection = blank
                            for drawer_candidate_collection in drawer_card_product.collections
                              assign drawer_candidate_handle = drawer_candidate_collection.handle | downcase
                              assign drawer_candidate_title = drawer_candidate_collection.title | downcase
                              if drawer_candidate_handle contains 'accessor' or drawer_candidate_title contains 'accessor'
                                assign drawer_accessories_collection = drawer_candidate_collection
                                break
                              endif

                              if drawer_fallback_non_generic_collection == blank
                                assign drawer_is_generic_collection = false
                                if drawer_candidate_handle == 'all' or drawer_candidate_handle == 'all-products' or drawer_candidate_handle contains 'shop-all' or drawer_candidate_title contains 'shop all'
                                  assign drawer_is_generic_collection = true
                                endif
                                unless drawer_is_generic_collection
                                  assign drawer_fallback_non_generic_collection = drawer_candidate_collection
                                endunless
                              endif
                            endfor
                            if drawer_accessories_collection == blank
                              if drawer_fallback_non_generic_collection != blank
                                assign drawer_accessories_collection = drawer_fallback_non_generic_collection
                              else
                                assign drawer_accessories_collection = drawer_card_product.collections.first
                              endif
                            endif
                          endif
                        elsif drawer_card_collection != blank
                          assign drawer_card_link = drawer_card_collection.url
                          assign drawer_card_title = drawer_card_collection.title
                          assign drawer_card_body = drawer_card_collection.description | strip_html
                        elsif drawer_card_page != blank
                          assign drawer_card_link = drawer_card_page.url
                          if drawer_card_title == blank
                            assign drawer_card_title = drawer_card_page.title
                          endif
                          if drawer_is_app
                            assign drawer_card_body = 'Download for iOS and Android'
                            assign parsed_drawer_rating_value = drawer_rating_display | split: ' ' | first | plus: 0
                            if parsed_drawer_rating_value > 0
                              assign drawer_rating_value = parsed_drawer_rating_value
                            endif
                          else
                            assign drawer_card_body = drawer_card_page.content | strip_html
                          endif
                        endif

                        if drawer_card_link == blank or drawer_card_title == blank
                          continue
                        endif

                        assign drawer_image = block.settings.image
                        if drawer_image != blank
                          assign drawer_card_image_url = drawer_image | image_url: width: 502
                        endif
                        assign drawer_submenu_animation_index = drawer_submenu_animation_index | plus: 1
                      %}
                      <li class="menu-drawer__submenu-item menu-drawer__submenu-animated-element" style="--menu-drawer-animation-index: {{ drawer_submenu_animation_index }};">
                        {% unless drawer_hide_primary_tile %}
                          <a class="menu-drawer__submenu-card{% if drawer_is_app %} menu-drawer__submenu-card--app{% endif %}{% if drawer_badge_label != blank %} menu-drawer__submenu-card--has-badge menu-drawer__submenu-card--{{ drawer_badge_type }}{% endif %}" href="{{ drawer_card_link }}">
                            <span class="menu-drawer__submenu-media" aria-hidden="true">
                              {% # theme-check-disable RemoteAsset %}
                              {% if drawer_card_image_url != blank %}
                                <img
                                  class="menu-drawer__submenu-image"
                                  src="{{ drawer_card_image_url }}"
                                  alt=""
                                  loading="lazy"
                                  decoding="async"
                                  width="502"
                                  height="502"
                                >
                              {% else %}
                                <img
                                  class="menu-drawer__submenu-image"
                                  src="{{ 'placeholder-primary-navigation-item.jpg' | asset_url }}"
                                  alt=""
                                  loading="lazy"
                                  decoding="async"
                                  width="502"
                                  height="502"
                                >
                              {% endif %}
                              {% # theme-check-enable RemoteAsset %}
                            </span>
                            <span class="menu-drawer__submenu-copy">
                              <span class="menu-drawer__submenu-title font-body weight-bold">{{ drawer_card_title | escape }}</span>
                              {% if drawer_is_app %}
                                <p class="menu-drawer__app-rating font-caption weight-semibold">
                                  <span class="menu-drawer__app-stars" aria-hidden="true">
                                    {% for star_index in (1..5) %}
                                      {% assign drawer_prior_stars = star_index | minus: 1 %}
                                      {% assign drawer_star_fill = 0 %}
                                      {% if drawer_rating_value >= star_index %}
                                        {% assign drawer_star_fill = 100 %}
                                      {% elsif drawer_rating_value > drawer_prior_stars %}
                                        {% assign drawer_star_fill = drawer_rating_value | minus: drawer_prior_stars | times: 100 | round %}
                                      {% endif %}
                                      <span class="menu-drawer__app-star" style="--sb-star-fill: {{ drawer_star_fill }}%; --sb-star-icon-url: url('{{ drawer_star_icon_url }}');"></span>
                                    {% endfor %}
                                  </span>
                                  <span>{{ drawer_rating_display }}</span>
                                </p>
                                <p class="menu-drawer__app-rating-count font-caption weight-regular">{{ drawer_rating_count_display }} ratings</p>
                              {% elsif drawer_card_body != blank %}
                                <span class="menu-drawer__submenu-body font-caption weight-regular">{{ drawer_card_body | truncate: 120 }}</span>
                              {% endif %}
                            </span>
                            {% if drawer_badge_label != blank %}
                              <span class="menu-drawer__submenu-badge menu-drawer__submenu-badge--{{ drawer_badge_type }} font-caption2 weight-semibold">
                                {{ drawer_badge_label }}
                              </span>
                            {% endif %}
                          </a>
                        {% endunless %}

                        {% if drawer_accessories_collection != blank %}
                          <a class="menu-drawer__submenu-secondary font-caption weight-semibold" href="{{ drawer_accessories_collection.url }}">
                            Accessories
                          </a>
                        {% endif %}

                        {% for drawer_related_index in (1..3) %}
                          {% liquid
                            assign drawer_related_product = blank
                            assign drawer_related_product_image = blank
                            assign drawer_related_product_hide_on_mobile = false
                            case drawer_related_index
                              when 1
                                assign drawer_related_product = drawer_related_product_1
                                assign drawer_related_product_image = drawer_related_product_1_image
                                assign drawer_related_product_hide_on_mobile = drawer_related_product_1_hide_on_mobile
                              when 2
                                assign drawer_related_product = drawer_related_product_2
                                assign drawer_related_product_image = drawer_related_product_2_image
                                assign drawer_related_product_hide_on_mobile = drawer_related_product_2_hide_on_mobile
                              when 3
                                assign drawer_related_product = drawer_related_product_3
                                assign drawer_related_product_image = drawer_related_product_3_image
                                assign drawer_related_product_hide_on_mobile = drawer_related_product_3_hide_on_mobile
                            endcase

                            if drawer_related_product == blank or drawer_related_product_hide_on_mobile == true
                              continue
                            endif

                            assign drawer_related_image_url = blank
                            if drawer_related_product_image != blank
                              assign drawer_related_image_url = drawer_related_product_image | image_url: width: 502
                            elsif drawer_related_product.featured_image != blank
                              assign drawer_related_image_url = drawer_related_product.featured_image | image_url: width: 502
                            endif

                            assign drawer_related_body = blank
                            assign drawer_related_settings_ref = drawer_related_product.metafields.custom.sbv2_product_settings.value | default: drawer_related_product.metafields.custom.sbv2_product_settings
                            if drawer_related_settings_ref != blank
                              assign drawer_related_body = drawer_related_settings_ref.tagline.value | default: drawer_related_settings_ref.tagline
                            endif
                            if drawer_related_body == blank and drawer_related_product.description != blank
                              assign drawer_related_body = drawer_related_product.description | strip_html
                            endif

                            assign drawer_related_badge_label = blank
                            assign drawer_related_badge_type = blank
                            if drawer_related_product.tags != blank
                              for drawer_related_tag in drawer_related_product.tags
                                assign drawer_related_tag_downcase = drawer_related_tag | downcase
                                if drawer_related_tag_downcase == 'bestseller'
                                  assign drawer_related_badge_label = 'Bestseller'
                                  assign drawer_related_badge_type = 'bestseller'
                                  break
                                endif
                                if drawer_related_tag_downcase == 'new'
                                  assign drawer_related_badge_label = 'New'
                                  assign drawer_related_badge_type = 'new'
                                endif
                              endfor
                            endif
                          %}
                          <a class="menu-drawer__submenu-card menu-drawer__submenu-card--related{% if drawer_related_badge_label != blank %} menu-drawer__submenu-card--has-badge menu-drawer__submenu-card--{{ drawer_related_badge_type }}{% endif %}" href="{{ drawer_related_product.url }}">
                            <span class="menu-drawer__submenu-media" aria-hidden="true">
                              {% # theme-check-disable RemoteAsset %}
                              {% if drawer_related_image_url != blank %}
                                <img
                                  class="menu-drawer__submenu-image"
                                  src="{{ drawer_related_image_url }}"
                                  alt=""
                                  loading="lazy"
                                  decoding="async"
                                  width="502"
                                  height="502"
                                >
                              {% else %}
                                <img
                                  class="menu-drawer__submenu-image"
                                  src="{{ 'placeholder-primary-navigation-item.jpg' | asset_url }}"
                                  alt=""
                                  loading="lazy"
                                  decoding="async"
                                  width="502"
                                  height="502"
                                >
                              {% endif %}
                              {% # theme-check-enable RemoteAsset %}
                            </span>
                            <span class="menu-drawer__submenu-copy">
                              <span class="menu-drawer__submenu-title font-body weight-bold">{{ drawer_related_product.title | escape }}</span>
                              {% if drawer_related_body != blank %}
                                <span class="menu-drawer__submenu-body font-caption weight-regular">{{ drawer_related_body | truncate: 120 }}</span>
                              {% endif %}
                            </span>
                            {% if drawer_related_badge_label != blank %}
                              <span class="menu-drawer__submenu-badge menu-drawer__submenu-badge--{{ drawer_related_badge_type }} font-caption2 weight-semibold">
                                {{ drawer_related_badge_label }}
                              </span>
                            {% endif %}
                          </a>
                        {% endfor %}

                        {% if drawer_is_app %}
                          <a class="menu-drawer__submenu-secondary menu-drawer__submenu-store font-caption weight-semibold" href="{{ drawer_app_store_link }}" target="_blank" rel="noopener noreferrer" aria-label="Download on the App Store">
                            <span>App Store</span>
                            <span class="menu-drawer__submenu-store-badge" aria-hidden="true">
                              <img
                                src="{{ 'app-download-app-store.png' | asset_url }}"
                                alt=""
                                loading="lazy"
                                width="100"
                                height="30"
                              >
                            </span>
                          </a>
                          <a class="menu-drawer__submenu-secondary menu-drawer__submenu-store font-caption weight-semibold" href="{{ drawer_google_play_link }}" target="_blank" rel="noopener noreferrer" aria-label="Get it on Google Play">
                            <span>Google Play</span>
                            <span class="menu-drawer__submenu-store-badge" aria-hidden="true">
                              <img
                                src="{{ 'app-download-google-play.png' | asset_url }}"
                                alt=""
                                loading="lazy"
                                width="100"
                                height="30"
                              >
                            </span>
                          </a>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                </details>
              {% else %}
                <a
                  class="menu-drawer__menu-item menu-drawer__menu-item--mainlist menu-drawer__animated-element"
                  href="{{ link.url }}"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  <span class="menu-drawer__menu-item-text font-callout weight-semibold">{{ link.title | escape }}</span>
                </a>
              {% endif %}
            </li>
          {% endfor %}
        {% endif %}

        {% if show_country or show_language %}
          {% liquid
            assign mobile_localization_animation_index = 1
            if primary_navigation != blank and primary_navigation.links.size > 0
              assign mobile_localization_animation_index = primary_navigation.links.size | plus: 1
            endif
          %}
          <li class="menu-drawer__list-item menu-drawer__list-item--localization" style="--menu-drawer-animation-index: {{ mobile_localization_animation_index }};">
            {% if show_language and show_country == false %}
              <div class="menu-drawer__localization menu-drawer__localization--inline menu-drawer__animated-element">
                {% render 'localization-form',
                  show_country: false,
                  show_language: true,
                  localization_style: 'drawer',
                  form_id: section.id | append: '-drawer-inline'
                %}
              </div>
            {% else %}
              <drawer-localization-component class="menu-drawer__localization">
                <button
                  type="button"
                  class="menu-drawer__menu-item menu-drawer__menu-item--mainlist menu-drawer__localization-button menu-drawer__localization-trigger menu-drawer__animated-element"
                  aria-expanded="false"
                  aria-controls="menu-drawer-localization-page-{{ section.id }}"
                  data-localization-ref="drawerOpenButton"
                >
                  <span class="menu-drawer__menu-item-text font-callout weight-semibold">
                    <span class="menu-drawer__localization-current">
                      {% if show_country %}
                        {% if show_country_flag %}
                          <span
                            class="menu-drawer__localization-current-flag"
                            aria-hidden="true"
                            style="background-image: url('{{ localization.country | image_url: width: 60 }}');"
                          ></span>
                        {% endif %}
                        <span class="menu-drawer__localization-current-code">
                          {{ localization.country.currency.iso_code }} {{ localization.country.currency.symbol }}{% if show_language %} &middot; {{ localization.language.iso_code | upcase }}{% endif %}
                        </span>
                      {% elsif show_language %}
                        <span class="menu-drawer__localization-current-code">{{ localization.language.iso_code | upcase }}</span>
                      {% endif %}
                    </span>
                  </span>
                  <span class="menu-drawer__localization-caret" aria-hidden="true">
                    {{ 'icon-chevron.svg' | inline_asset_content }}
                  </span>
                </button>
                <div
                  id="menu-drawer-localization-page-{{ section.id }}"
                  class="menu-drawer__localization-page"
                  data-localization-ref="drawerPage"
                  hidden
                >
                  <div class="menu-drawer__localization-page-header">
                    <button
                      type="button"
                      class="menu-drawer__localization-back-pill font-caption weight-regular"
                      data-localization-ref="drawerBackButton"
                      aria-label="Back"
                    >
                      <span class="menu-drawer__localization-back-icon" aria-hidden="true">
                        {{ 'icon-chevron.svg' | inline_asset_content }}
                      </span>
                      <span>Back</span>
                    </button>
                    <p class="menu-drawer__localization-page-title font-callout weight-bold">
                      Region and language
                    </p>
                  </div>
                  <div class="menu-drawer__localization-page-body">
                    {% render 'localization-form',
                      show_country: show_country,
                      show_language: show_language,
                      localization_style: 'drawer',
                      form_id: section.id | append: '-drawer'
                    %}
                  </div>
                </div>
              </drawer-localization-component>
            {% endif %}
          </li>
        {% endif %}
      </ul>
      {% liquid
        assign mobile_menu_animated_index = 0
        if primary_navigation != blank and primary_navigation.links.size > 0
          assign mobile_menu_animated_index = primary_navigation.links.size
        endif
        if show_country or show_language
          assign mobile_menu_animated_index = mobile_menu_animated_index | plus: 1
        endif
        assign mobile_menu_trustpilot_index = mobile_menu_animated_index | plus: 1
        assign mobile_menu_review_index = mobile_menu_animated_index | plus: 2
        assign mobile_menu_social_index = mobile_menu_animated_index | plus: 3
      %}
      <div class="menu-drawer__trustpilot menu-drawer__animated-element" style="--menu-drawer-animation-index: {{ mobile_menu_trustpilot_index }};">
        <a
          class="menu-drawer__trustpilot-link menu-drawer__trustpilot-link--logo"
          href="{{ trustpilot_url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Trustpilot logo link"
        >
          <span class="menu-drawer__trustpilot-logo" aria-hidden="true">
            {{ 'logo-trustpilot-multicolor.svg' | inline_asset_content }}
          </span>
        </a>
        <a
          class="menu-drawer__trustpilot-link menu-drawer__trustpilot-link--stars"
          href="{{ trustpilot_url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Trustpilot stars link"
        >
          <span class="menu-drawer__trustpilot-stars" aria-hidden="true">
            {{ 'trustpilot-stars-multicolor.svg' | inline_asset_content }}
          </span>
        </a>
        <a
          class="menu-drawer__trustpilot-link menu-drawer__trustpilot-link--text font-body weight-semibold"
          href="{{ trustpilot_url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Read Soundbrenner reviews on Trustpilot"
        >
          {{ trustpilot_rating_text }}
        </a>
      </div>

      <div class="menu-drawer__review menu-drawer__animated-element" style="--menu-drawer-animation-index: {{ mobile_menu_review_index }};" data-mobile-menu-review>
        <div class="menu-drawer__review-row">
          <span class="menu-drawer__review-name font-caption weight-semibold" data-mobile-menu-review-name>Wesley G.</span>
          <span class="menu-drawer__review-verified font-caption weight-semibold">
            <span class="menu-drawer__review-verified-icon" aria-hidden="true">
              {{ 'icon-verified-badge.svg' | inline_asset_content }}
            </span>
            <span>Verified buyer</span>
          </span>
          <span class="menu-drawer__review-stars" aria-hidden="true" style="--sb-review-star-icon-url: url('{{ 'icon-review-star.svg' | asset_url }}');">
            <span class="menu-drawer__review-star"></span>
            <span class="menu-drawer__review-star"></span>
            <span class="menu-drawer__review-star"></span>
            <span class="menu-drawer__review-star"></span>
            <span class="menu-drawer__review-star"></span>
          </span>
        </div>
        <p class="menu-drawer__review-text font-caption weight-regular" data-mobile-menu-review-text>
          I have the in-ear monitors and the Pulse. They work exactly as promised. Shipping was good and without bad surprises. Thank you Soundbrenner!
        </p>
        <p class="menu-drawer__review-date font-caption weight-regular" data-mobile-menu-review-date>8 Jan, 2026</p>
      </div>

      <div class="menu-drawer__social menu-drawer__animated-element" style="--menu-drawer-animation-index: {{ mobile_menu_social_index }};" aria-label="Social links">
        <a class="menu-drawer__social-link" href="https://www.instagram.com/soundbrenner" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          {{ 'social-media-instagram.svg' | inline_asset_content }}
        </a>
        <a class="menu-drawer__social-link" href="https://www.facebook.com/soundbrenner" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          {{ 'social-media-facebook.svg' | inline_asset_content }}
        </a>
        <a class="menu-drawer__social-link" href="https://www.tiktok.com/@soundbrenner" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
          {{ 'social-media-tiktok.svg' | inline_asset_content }}
        </a>
        <a class="menu-drawer__social-link" href="https://x.com/soundbrenner" target="_blank" rel="noopener noreferrer" aria-label="X">
          {{ 'social-media-x.svg' | inline_asset_content }}
        </a>
        <a class="menu-drawer__social-link" href="https://www.youtube.com/soundbrenner" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          {{ 'social-media-youtube.svg' | inline_asset_content }}
        </a>
      </div>
    </nav>
  </div>
  <button
    class="menu-drawer__backdrop menu-drawer__backdrop--local"
    type="button"
    aria-label="Close menu"
    data-mobile-menu-close
  ></button>
</div>
<div class="header__primary-backdrop header__primary-backdrop--top" data-header-primary-backdrop="top" aria-hidden="true"></div>
<div
  class="header__primary-backdrop header__primary-backdrop--bottom"
  data-header-primary-backdrop="bottom"
  aria-hidden="true"
></div>

<cart-drawer-component auto-open>
  <div class="header__cart-drawer" data-cart-drawer hidden>
    <button type="button" class="header__cart-drawer-backdrop" data-cart-drawer-close aria-label="Close cart"></button>
    <aside class="header__cart-drawer-panel" role="dialog" aria-modal="true" aria-label="Cart drawer" data-cart-drawer-panel cart-summary-sticky="true">
      <div class="header__cart-drawer-header">
        <div class="header__cart-drawer-header-row">
          <h3 class="header__cart-drawer-title font-title weight-bold">
            Cart
            <span class="header__cart-drawer-count font-caption2 weight-semibold" data-cart-drawer-count {% if cart.item_count == 0 %}hidden{% endif %}>
              {{ cart.item_count }}
            </span>
          </h3>
          <button type="button" class="header__cart-drawer-close" data-cart-drawer-close aria-label="Close cart">
            <span class="header__cart-drawer-close-icon" aria-hidden="true">{{ 'icon-cancel.svg' | inline_asset_content }}</span>
          </button>
        </div>
        <p class="header__cart-drawer-empty-message font-body weight-regular" data-cart-empty-message {% unless cart.empty? %}hidden{% endunless %}>
          Your cart is empty. Let's fill it with beautifully designed music gear.
        </p>
        {% render 'sb-cart-free-shipping-progress',
          available: seasonal_shipping_has_free_shipping and seasonal_shipping_is_blocked == false,
          threshold_cents: seasonal_entry_threshold_cents,
          subtotal_cents: cart.total_price,
          currency: cart.currency.iso_code,
          has_items: cart.item_count > 0,
          filled_message: true,
          extra_class: 'header__cart-drawer-free-shipping'
        %}
        <div class="header__cart-drawer-items-divider" aria-hidden="true"></div>
      </div>

      <cart-items-component
        class="sb-cart-items"
        data-context="drawer"
        data-currency="{{ localization.country.currency.iso_code | default: cart.currency.iso_code }}"
        data-placeholder-image="{{ cart_placeholder_image }}"
      >
        <div class="header__cart-drawer-content">
          {% render 'sb-cart-line-items',
            list_class: 'sb-cart-line-list',
            hidden: cart.item_count == 0,
            placeholder_image: cart_placeholder_image
          %}

          <div class="header__cart-empty" data-cart-empty {% unless cart.empty? %}hidden{% endunless %}>
            {% render 'sb-cart-empty-collections',
              container_class: 'header__cart-empty-collections',
              grid_class: 'header__cart-empty-collection-grid',
              item_class: 'header__cart-empty-collection-item',
              media_class: 'header__cart-empty-collection-media',
              image_class: 'header__cart-empty-collection-image',
              title_class: 'header__cart-empty-collection-title',
              title_font_class: 'font-caption weight-semibold',
              primary_navigation: primary_navigation,
              placeholder_image: cart_placeholder_image
            %}
            {% render 'sb-cart-empty-payments',
              container_class: 'header__cart-empty-payments',
              show_shop_all: true,
              shop_all_class: 'sb-button-radiant sb-button-radiant--large header__cart-empty-action',
              payment_list_class: 'header__cart-empty-payment-list',
              payment_item_class: 'header__cart-empty-payment-item'
            %}
          </div>
        </div>

        <div class="header__cart-drawer-summary" data-cart-summary {% if cart.empty? %}hidden{% endif %}>
          {% render 'sb-cart-summary-inner',
            summary_class: 'header__cart-drawer-summary-inner sb-cart-summary',
            show_top_divider: true,
            shipping_text: cart_summary_shipping_text,
            taxes_text: cart_summary_taxes_text,
            discount_input_id: 'HeaderCartDiscountCode-' | append: section.id,
            checkout_mode: 'link',
            checkout_button_class: '',
            clear_button_class: 'header__cart-drawer-action',
            show_clear: false,
            payment_list_class: 'header__cart-summary-payment-list',
            payment_item_class: 'header__cart-summary-payment-item'
          %}
        </div>
      </cart-items-component>
    </aside>
  </div>
</cart-drawer-component>

{% stylesheet %}
  html {
    background: var(--sb-color-neutral-100);
  }

  :root {
    --sb-header-height: 60px;
    --sb-announcement-min-height: 0px;
  }

  :root:has(.header.has-announcement) {
    --sb-announcement-min-height: 42px;
  }

  .header {
    --sb-header-height: 60px;
    --sb-announcement-min-height: 0px;
    --sb-announcement-row-gap: 6px;
    --sb-announcement-padding-block: 8px;
    --sb-announcement-emoji-size: 20px;
    --sb-announcement-emoji-offset: 36px;
    --sb-announcement-countdown-gap: 12px;
    --sb-announcement-countdown-group-gap: 6px;
    --sb-announcement-countdown-pill-size: 24px;
    --sb-announcement-countdown-pill-padding: 2px;
    --sb-menu-unroll-duration: 420ms;
    --sb-menu-unroll-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --sb-menu-surface-shadow: 0 var(--sb-space-48) var(--sb-space-48) 0 var(--sb-color-always-black-25);
    background-color: var(--sb-color-neutral-200);
    border-bottom: 1px solid var(--sb-color-neutral-600);
    left: 0;
    position: fixed;
    right: 0;
    top: 0;
    transform: translateY(0);
    transition: none;
    z-index: 50;
  }

  .header.has-announcement {
    --sb-announcement-min-height: 42px;
  }

  .header__announcement {
    align-items: center;
    background: var(--sb-announcement-background, var(--sb-gradient-default-1));
    display: flex;
    justify-content: center;
    min-height: var(--sb-announcement-min-height);
    padding: var(--sb-announcement-padding-block) var(--page-margin, 16px);
    width: 100%;
  }

  .header__announcement-content {
    align-items: center;
    display: flex;
    flex-direction: column;
    gap: var(--sb-announcement-row-gap);
    max-width: calc(100% - (var(--sb-announcement-emoji-offset) * 2));
    position: relative;
    width: fit-content;
  }

  .header__announcement-emojis {
    align-items: center;
    display: flex;
    inset: 0 calc(-1 * var(--sb-announcement-emoji-offset));
    justify-content: space-between;
    pointer-events: none;
    position: absolute;
  }

  .header__announcement-top {
    display: block;
    width: 100%;
  }

  .header__announcement-emoji {
    align-items: center;
    display: inline-flex;
    flex: 0 0 auto;
    height: var(--sb-announcement-emoji-size);
    justify-content: center;
    overflow: hidden;
    width: var(--sb-announcement-emoji-size);
  }

  .header__announcement-emoji img {
    display: block;
    height: 100%;
    width: 100%;
  }

  .header__announcement-text {
    color: var(--sb-color-always-white);
    margin: 0;
    max-width: 100%;
    min-width: 0;
    text-align: center;
    white-space: normal;
    word-break: break-word;
    text-wrap: pretty;
    text-wrap: balance;
  }

  .header__announcement-countdown {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sb-announcement-countdown-gap);
    justify-content: center;
    width: 100%;
  }

  .header__announcement-countdown[hidden] {
    display: none;
  }

  .header.is-affiliate-announcement-active .header__announcement-countdown {
    display: none;
  }

  .header__announcement-countdown-group {
    align-items: center;
    color: var(--sb-color-always-white);
    display: inline-flex;
    gap: var(--sb-announcement-countdown-group-gap);
  }

  .header__announcement-countdown-value {
    align-items: center;
    background: var(--sb-color-always-black-25);
    box-sizing: border-box;
    border-radius: 4px;
    display: inline-flex;
    font-variant-numeric: tabular-nums;
    justify-content: center;
    line-height: 1;
    min-width: var(--sb-announcement-countdown-pill-size);
    padding: var(--sb-announcement-countdown-pill-padding);
    text-align: center;
    width: var(--sb-announcement-countdown-pill-size);
  }

  .header__announcement-countdown-label {
    color: var(--sb-color-always-white);
    line-height: 1;
  }

  .header.is-hidden {
    transform: translateY(-100%);
  }

  .header__inner {
    --sb-desktop-popout-offset: calc(var(--sb-space-16) + ((var(--sb-header-height) - var(--sb-space-36)) / 2));
    align-items: center;
    background-color: var(--sb-color-neutral-200);
    display: flex;
    height: var(--sb-header-height);
    justify-content: space-between;
    margin-inline: auto;
    max-width: var(--page-width, 1240px);
    position: relative;
    width: min(
      var(--page-width, 1240px),
      calc(100% - (var(--page-margin, 16px) * 2))
    );
    z-index: 1;
  }

  .header a {
    text-decoration: none;
  }

  .header__brand {
    align-items: center;
    color: var(--sb-color-neutral-900);
    display: inline-flex;
    line-height: 0;
    position: relative;
    z-index: 1;
  }

  .header__brand:hover,
  .header__brand:focus-visible {
    color: var(--sb-color-primary-500);
  }

  .header__brand-logo {
    display: inline-flex;
    height: 36px;
    width: auto;
  }

  .header__brand-logo svg {
    display: block;
    height: 100%;
    width: auto;
  }

  .header__menu {
    align-items: center;
    display: flex;
