<script>
  (() => {
    const header = document.querySelector('.header');
    if (!header || header.dataset.headerInit === 'true') return;
    header.dataset.headerInit = 'true';

    const affiliateAnnouncementCookieName = 'sb_affiliate_announcement_state';
    const affiliatePageDiscountCode = `${header.dataset.affiliateDiscountCode || ''}`.trim();
    const affiliatePageName = `${header.dataset.affiliateName || ''}`.trim();
    const affiliateNameToken = `${header.dataset.affiliateNameToken || ''}`;
    const affiliateAnnouncementTemplate = `${header.dataset.affiliateAnnouncementTemplate || ''}`;
    const affiliateAnnouncementGradient = `${header.dataset.affiliateAnnouncementGradient || ''}`;
    const affiliateAnnouncementEmoji = `${header.dataset.affiliateAnnouncementEmoji || ''}`;
    const affiliateDurationHoursRaw = Number.parseInt(`${header.dataset.affiliateCookieDurationHours || ''}`, 10);
    const affiliateAnnouncementDurationHours = Number.isFinite(affiliateDurationHoursRaw) && affiliateDurationHoursRaw > 0
      ? affiliateDurationHoursRaw
      : 336;
    const affiliateAnnouncementDurationMs = affiliateAnnouncementDurationHours * 60 * 60 * 1000;
    const announcementTextElement = header.querySelector('.header__announcement-text');
    const announcementTextDefault = announcementTextElement ? announcementTextElement.textContent || '' : '';
    const announcementBackgroundDefault = header.style.getPropertyValue('--sb-announcement-background');
    const announcementEmojiImages = Array.from(header.querySelectorAll('.header__announcement-emoji img'));
    const announcementEmojiDefaults = announcementEmojiImages.map((imageNode) => imageNode.getAttribute('src') || '');
    let affiliateAnnouncementActive = false;
    let affiliateAnnouncementSignature = '';

    const parseJson = (value) => {
      try {
        return JSON.parse(value);
      } catch (_) {
        return null;
      }
    };

    const readCookie = (name) => {
      const cookieSource = `${document.cookie || ''}`;
      if (!cookieSource) return '';
      const cookieParts = cookieSource.split(';');
      for (const cookiePart of cookieParts) {
        const trimmedPart = cookiePart.trim();
        if (!trimmedPart.startsWith(`${name}=`)) continue;
        return trimmedPart.slice(name.length + 1);
      }
      return '';
    };

    const clearAffiliateAnnouncementState = () => {
      document.cookie = `${affiliateAnnouncementCookieName}=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT; SameSite=Lax`;
    };

    const getAffiliateAnnouncementState = () => {
      const rawCookieValue = readCookie(affiliateAnnouncementCookieName);
      if (!rawCookieValue) return null;

      const decodedCookieValue = (() => {
        try {
          return decodeURIComponent(rawCookieValue);
        } catch (_) {
          return rawCookieValue;
        }
      })();
      const parsedState = parseJson(decodedCookieValue);
      if (!parsedState || typeof parsedState !== 'object') return null;

      const discountCode = `${parsedState.discountCode || ''}`.trim();
      const affiliateName = `${parsedState.affiliateName || discountCode}`.trim();
      const expiresAt = Number.parseInt(`${parsedState.expiresAt || ''}`, 10);
      if (!discountCode || !affiliateName || !Number.isFinite(expiresAt) || expiresAt <= Date.now()) return null;

      return {
        discountCode,
        affiliateName,
        expiresAt
      };
    };

    const writeAffiliateAnnouncementState = (state) => {
      if (!state || typeof state !== 'object') {
        clearAffiliateAnnouncementState();
        return null;
      }

      const nextState = {
        discountCode: `${state.discountCode || ''}`.trim(),
        affiliateName: `${state.affiliateName || state.discountCode || ''}`.trim(),
        expiresAt: Number.parseInt(`${state.expiresAt || ''}`, 10)
      };
      if (!nextState.discountCode || !nextState.affiliateName || !Number.isFinite(nextState.expiresAt) || nextState.expiresAt <= Date.now()) {
        clearAffiliateAnnouncementState();
        return null;
      }

      const maxAgeSeconds = Math.max(1, Math.floor((nextState.expiresAt - Date.now()) / 1000));
      const serializedState = encodeURIComponent(JSON.stringify(nextState));
      document.cookie = `${affiliateAnnouncementCookieName}=${serializedState}; path=/; max-age=${maxAgeSeconds}; SameSite=Lax`;
      return nextState;
    };

    const replaceToken = (input, token, replacement) => {
      const source = `${input || ''}`;
      const target = `${token || ''}`;
      if (!target) return source;
      return source.split(target).join(`${replacement || ''}`);
    };

    const setAnnouncementText = (text) => {
      if (!announcementTextElement) return;
      const normalizedText = `${text || ''}`;
      const lines = normalizedText.split('\n');
      announcementTextElement.textContent = '';
      lines.forEach((line, index) => {
        if (index > 0) announcementTextElement.appendChild(document.createElement('br'));
        announcementTextElement.appendChild(document.createTextNode(line));
      });
    };

    const getAffiliateAnnouncementText = (state) => {
      if (!state) return announcementTextDefault;
      const sourceText = affiliateAnnouncementTemplate.trim();
      if (!sourceText) return announcementTextDefault;
      const announcementText = replaceToken(sourceText, affiliateNameToken, state.affiliateName);
      return announcementText.trim() || announcementTextDefault;
    };

    const applyAffiliateAnnouncement = (state) => {
      const isActive = Boolean(state && announcementTextElement);
      const nextSignature = isActive ? `${state.discountCode}:${state.affiliateName}` : '';
      if (affiliateAnnouncementActive === isActive && affiliateAnnouncementSignature === nextSignature) return;

      affiliateAnnouncementActive = isActive;
      affiliateAnnouncementSignature = nextSignature;

      if (isActive) {
        if (affiliateAnnouncementGradient) {
          header.style.setProperty('--sb-announcement-background', affiliateAnnouncementGradient);
        }
        announcementEmojiImages.forEach((imageNode) => {
          if (!affiliateAnnouncementEmoji) return;
          imageNode.setAttribute('src', affiliateAnnouncementEmoji);
        });
        setAnnouncementText(getAffiliateAnnouncementText(state));
        header.classList.add('is-affiliate-announcement-active');
        return;
      }

      header.classList.remove('is-affiliate-announcement-active');
      if (announcementBackgroundDefault) {
        header.style.setProperty('--sb-announcement-background', announcementBackgroundDefault);
      } else {
        header.style.removeProperty('--sb-announcement-background');
      }
      announcementEmojiImages.forEach((imageNode, index) => {
        const defaultSource = announcementEmojiDefaults[index] || '';
        if (!defaultSource) return;
        imageNode.setAttribute('src', defaultSource);
      });
      setAnnouncementText(announcementTextDefault);
    };

    const syncAffiliateAnnouncementState = () => {
      const state = getAffiliateAnnouncementState();
      if (!state) {
        clearAffiliateAnnouncementState();
        applyAffiliateAnnouncement(null);
        return null;
      }

      applyAffiliateAnnouncement(state);
      return state;
    };

    if (affiliatePageDiscountCode) {
      writeAffiliateAnnouncementState({
        discountCode: affiliatePageDiscountCode,
        affiliateName: affiliatePageName || affiliatePageDiscountCode,
        expiresAt: Date.now() + affiliateAnnouncementDurationMs
      });
    }

    syncAffiliateAnnouncementState();

    window.setInterval(() => {
      syncAffiliateAnnouncementState();
    }, 1000);

    const mobileMenuDrawer = document.querySelector('[data-mobile-menu-drawer]');
    const mobileMenuToggle = header.querySelector('[data-mobile-menu-toggle]');
    const mobileMenuCloseControls = mobileMenuDrawer
      ? mobileMenuDrawer.querySelectorAll('[data-mobile-menu-close]')
      : [];
    const mobileMenuReview = mobileMenuDrawer
      ? mobileMenuDrawer.querySelector('[data-mobile-menu-review]')
      : null;
    const mobileMenuReviewName = mobileMenuReview
      ? mobileMenuReview.querySelector('[data-mobile-menu-review-name]')
      : null;
    const mobileMenuReviewText = mobileMenuReview
      ? mobileMenuReview.querySelector('[data-mobile-menu-review-text]')
      : null;
    const mobileMenuReviewDate = mobileMenuReview
      ? mobileMenuReview.querySelector('[data-mobile-menu-review-date]')
      : null;
    const mobileMenuTrustpilot = mobileMenuDrawer
      ? mobileMenuDrawer.querySelector('.menu-drawer__trustpilot')
      : null;
    let mobileMenuCloseTimer = null;
    const mobileMenuPreloadedSources = new Set();
    const primaryMenuPreloadedSources = new Set();
    const mobileMenuReviewStorageKey = 'sb-mobile-menu-review-index';
    const mobileMenuReviews = [
      {
        day: 8,
        name: 'Wesley G.',
        text: "I have the in-ear monitors and the Pulse. They work exactly as promised. Shipping was good and without bad surprises. Thank you Soundbrenner!"
      },
      {
        day: 4,
        name: 'Rob M.',
        text: "I had questions about my purchase, and Ethan has been super attentive offering excellent explanations and suggestions. Services matters as much as the product you buy, and I'm impressed."
      },
      {
        day: 15,
        name: 'Lee K.',
        text: 'My initial order was delayed but the staff were super responsive to my emails and sorted it out without problem. Issues happen from time to time but I appreciate that they care about their customers and service.'
      },
      {
        day: 2,
        name: 'Samuel A.',
        text: 'Amazing customer service, great and quick service overall. I am really happy I purchased this product and I will be looking forward to future purchases.'
      },
      {
        day: 21,
        name: 'Nate L.',
        text: "Soundbrenner's customer service has been top notch. They helped me with a return for a bad adapter and made it right. Will gladly buy again from SB."
      },
      {
        day: 9,
        name: 'Christos T.',
        text: 'Incredible customer service experience: prompt and deliberate responses, and understanding of my needs. I am very pleased with how they handled my return process.'
      },
      {
        day: 12,
        name: 'Paul S.',
        text: 'Easy to shop for, shipping was fast, and the package presentation was much higher end than I expected.'
      },
      {
        day: 27,
        name: 'Mark C.',
        text: "This company is a breath of fresh air to deal with! I did have a problem with part of my order but it was resolved so quickly it really wasn't a problem. I genuinely look forward to using this company again."
      },
      {
        day: 18,
        name: 'Curtis E.',
        text: "One of the best customer support experiences I've ever had. I had one minor issue and they went above and beyond to correct it and emailed back within an hour. I don't see myself or my son buying from anyone else again."
      },
      {
        day: 5,
        name: 'Jerry W.',
        text: 'Easy checkout and fast shipping. These folks know how to treat a customer with respect and appreciation.'
      },
      {
        day: 24,
        name: 'Cymil M.',
        text: 'Shopping was seamless and easy. Customer service is very responsive and always presents options for whatever concern you may have. Five star.'
      }
    ];
    let pageScrollLockY = 0;
    let pageScrollLockMode = null;
    const isDesktopViewport = () => window.matchMedia('(min-width: 990px)').matches;
    const isMobileMenuOpen = () => Boolean(mobileMenuDrawer && mobileMenuDrawer.classList.contains('menu-open'));
    const headerInnerElement = header.querySelector('.header__inner');
    const desktopMenu = header.querySelector('.header__menu');
    const desktopMenuItems = desktopMenu ? Array.from(desktopMenu.querySelectorAll('.header__menu-item')) : [];
    const desktopBrand = header.querySelector('.header__brand');
    const desktopUtilityIcons = header.querySelector('.header__utility-icons');
    const navWrapSideGap = 12;
    const navWrapMinItemWidth = 96;
    const navWrapMaxItemWidth = 160;
    let navLayoutRaf = null;
    let navLayoutObserver = null;

    const clearDesktopNavLayoutClasses = () => {
      header.classList.remove('is-nav-wrap');
      header.classList.remove('is-nav-compact');
      if (desktopMenu) desktopMenu.style.removeProperty('--sb-nav-wrap-max-item-width');
    };

    const getDesktopNavRects = () => {
      if (!desktopMenu || !desktopBrand || !desktopUtilityIcons) return null;
      return {
        menuRect: desktopMenu.getBoundingClientRect(),
        brandRect: desktopBrand.getBoundingClientRect(),
        utilityRect: desktopUtilityIcons.getBoundingClientRect()
      };
    };

    const hasDesktopNavOverlap = () => {
      const rects = getDesktopNavRects();
      if (!rects) return false;
      return (
        rects.menuRect.left < (rects.brandRect.right + navWrapSideGap)
        || rects.menuRect.right > (rects.utilityRect.left - navWrapSideGap)
      );
    };

    const calculateNavWrapItemWidth = () => {
      if (!desktopMenu || desktopMenuItems.length === 0) return null;
      const rects = getDesktopNavRects();
      if (!rects) return null;

      const availableWidth = rects.utilityRect.left - rects.brandRect.right - (navWrapSideGap * 2);
      const menuStyles = window.getComputedStyle(desktopMenu);
      const menuGap = parseFloat(menuStyles.columnGap || menuStyles.gap || '0') || 0;
      const totalGap = menuGap * Math.max(0, desktopMenuItems.length - 1);
      const rawItemWidth = (availableWidth - totalGap) / desktopMenuItems.length;
      if (!Number.isFinite(rawItemWidth)) return null;

      return Math.max(navWrapMinItemWidth, Math.min(navWrapMaxItemWidth, Math.floor(rawItemWidth)));
    };

    const applyDesktopNavLayout = () => {
      if (!isDesktopViewport() || !desktopMenu || desktopMenuItems.length === 0) {
        clearDesktopNavLayoutClasses();
        return;
      }

      clearDesktopNavLayoutClasses();

      if (!hasDesktopNavOverlap()) return;

      const wrapItemWidth = calculateNavWrapItemWidth();
      if (wrapItemWidth && wrapItemWidth > 0) {
        desktopMenu.style.setProperty('--sb-nav-wrap-max-item-width', `${wrapItemWidth}px`);
      }
      header.classList.add('is-nav-wrap');

      if (!hasDesktopNavOverlap()) return;

      header.classList.remove('is-nav-wrap');
      if (desktopMenu) desktopMenu.style.removeProperty('--sb-nav-wrap-max-item-width');
      header.classList.add('is-nav-compact');
    };

    const scheduleDesktopNavLayout = () => {
      if (navLayoutRaf) window.cancelAnimationFrame(navLayoutRaf);
      navLayoutRaf = window.requestAnimationFrame(() => {
        navLayoutRaf = null;
        applyDesktopNavLayout();
      });
    };

    window.addEventListener('resize', scheduleDesktopNavLayout, { passive: true });
    window.requestAnimationFrame(scheduleDesktopNavLayout);

    if (document.fonts && typeof document.fonts.ready === 'object') {
      document.fonts.ready.then(() => {
        scheduleDesktopNavLayout();
      });
    }

    if (window.ResizeObserver && headerInnerElement) {
      navLayoutObserver = new ResizeObserver(() => {
        scheduleDesktopNavLayout();
      });
      navLayoutObserver.observe(headerInnerElement);
      if (desktopBrand) navLayoutObserver.observe(desktopBrand);
      if (desktopUtilityIcons) navLayoutObserver.observe(desktopUtilityIcons);
      if (desktopMenu) navLayoutObserver.observe(desktopMenu);
    }

    const closeAllMobileAccordions = () => {
      if (!mobileMenuDrawer) return;
      mobileMenuDrawer.querySelectorAll('.menu-drawer__menu-container[open]').forEach((accordion) => {
        accordion.removeAttribute('open');
      });
      mobileMenuDrawer.querySelectorAll('drawer-localization-component').forEach((component) => {
        if (typeof component.closeDrawerPage === 'function') {
          component.closeDrawerPage({ immediate: true });
          return;
        }
        component.classList.remove('menu-open');
        const menuDrawerElement = component.closest('.menu-drawer');
        if (menuDrawerElement) menuDrawerElement.classList.remove('menu-drawer--has-submenu-opened');
        const panel = component.querySelector('[data-localization-ref="drawerPage"]');
        if (panel) panel.hidden = true;
      });
    };
    const clearMobileMenuCloseTimer = () => {
      if (!mobileMenuCloseTimer) return;
      window.clearTimeout(mobileMenuCloseTimer);
      mobileMenuCloseTimer = null;
    };
    const shouldSkipDeferredImagePreload = () => {
      const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      if (!connection) return false;
      if (connection.saveData) return true;
      const effectiveType = `${connection.effectiveType || ''}`.toLowerCase();
      return effectiveType.includes('2g');
    };
    const preloadImageSource = (source, sourceCache) => {
      if (!source || sourceCache.has(source)) return;
      sourceCache.add(source);
      const preloadImage = new Image();
      preloadImage.decoding = 'async';
      preloadImage.src = source;
    };
    const preloadMobileMenuImageSource = (source) => {
      preloadImageSource(source, mobileMenuPreloadedSources);
    };
    const preloadMobileMenuImages = () => {
      if (!mobileMenuDrawer || isDesktopViewport() || shouldSkipDeferredImagePreload()) return;
      const imageNodes = mobileMenuDrawer.querySelectorAll('.menu-drawer__submenu-image');
      imageNodes.forEach((imageNode) => {
        const source = imageNode.getAttribute('src');
        preloadMobileMenuImageSource(source);
      });
    };
    const scheduleMobileMenuPreload = () => {
      if (typeof window.requestIdleCallback === 'function') {
        window.requestIdleCallback(() => {
          preloadMobileMenuImages();
        }, { timeout: 1200 });
        return;
      }

      window.setTimeout(() => {
        preloadMobileMenuImages();
      }, 180);
    };
