{% liquid
  assign opt_out_title = page.title | default: '' | strip
  assign opt_out_title_words = opt_out_title | split: ' '
  assign opt_out_title_first_word = opt_out_title_words | first | strip
  assign opt_out_title_remaining = opt_out_title | remove_first: opt_out_title_first_word | strip
%}

<section class="sb-data-sharing-opt-out" data-sb-reveal>
  <div class="sb-data-sharing-opt-out__title" data-sb-reveal-item>
    <h1 class="font-title weight-bold">
      <span>{{ opt_out_title_first_word }}</span>{% if opt_out_title_remaining != blank %} <span class="sb-data-sharing-opt-out__title-smallcaps">{{ opt_out_title_remaining }}</span>{% endif %}
    </h1>
  </div>

  <div class="sb-data-sharing-opt-out__content rte font-body weight-regular sb-flow-24" data-sb-reveal-item>
    {{ page.content }}
  </div>

  {% unless page.content contains 'pc--optOutFormContainer' or page.content contains 'pc--opt-out-form-container' %}
    <div id="pc--optOutFormContainer" data-sb-reveal-item></div>
  {% endunless %}
</section>

{% stylesheet %}
  .sb-data-sharing-opt-out__title {
    color: var(--sb-color-neutral-900);
  }

  .sb-data-sharing-opt-out__title h1 {
    margin: 0;
  }

  .sb-data-sharing-opt-out__title-smallcaps {
    font-variant: small-caps;
    font-variant-caps: all-small-caps;
    font-feature-settings: 'smcp' 1, 'c2sc' 1;
    font-size: 0.88em;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .sb-data-sharing-opt-out__content {
    color: var(--sb-color-neutral-900);
    margin-top: var(--sb-space-24);
  }

  .sb-data-sharing-opt-out #pc--optOutFormContainer {
    margin-top: var(--sb-space-24);
  }

  .sb-data-sharing-opt-out #pc--opt-out-form-container {
    position: relative;
    width: 100%;
  }

  .sb-data-sharing-opt-out #hcaptcha {
    position: absolute !important;
    inline-size: 0 !important;
    block-size: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    pointer-events: none;
  }

  .sb-data-sharing-opt-out #pc--opt-out-form,
  .sb-data-sharing-opt-out .pc--opt-out-form-container {
    align-items: flex-start;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 400px;
    text-align: left;
    width: 100%;
  }

  .sb-data-sharing-opt-out #optout,
  .sb-data-sharing-opt-out #pc--opt-out-not-applicable,
  .sb-data-sharing-opt-out .pc--opt-out-form-message {
    color: var(--sb-color-neutral-900);
    margin: 0;
  }

  .sb-data-sharing-opt-out .pc--show-email-field label {
    align-items: center;
    color: var(--sb-color-neutral-900);
    display: flex;
    font-family: var(--font-primary--family);
    font-size: var(--font-size-body);
    font-weight: 400;
    gap: 12px;
    margin: 0;
    line-height: 1.3;
    cursor: text;
    -webkit-user-select: text;
    user-select: text;
  }

  .sb-data-sharing-opt-out .sb-data-sharing-opt-out__checkbox-label-text {
    display: block;
    line-height: 1.3;
    min-width: 0;
  }

  .sb-data-sharing-opt-out .pc--show-email-field {
    margin-top: var(--sb-space-24);
    margin-bottom: 4px;
  }

  .sb-data-sharing-opt-out #pc--show-email-field {
    -webkit-appearance: none;
    appearance: none;
    background-color: transparent;
    background-image: none;
    background-position: center;
    background-repeat: no-repeat;
    background-size: 20px 20px;
    border: 0;
    border-radius: 0;
    box-sizing: border-box;
    display: block;
    block-size: 20px;
    inline-size: 20px;
    margin: 0;
    padding: 0;
    cursor: pointer;
    flex: 0 0 auto;
  }

  .sb-data-sharing-opt-out #pc--show-email-field:checked {
    background-image: none;
    background-color: transparent;
  }

  .sb-data-sharing-opt-out #pc--show-email-field:focus-visible {
    outline: 2px solid var(--sb-color-primary-500);
    outline-offset: 2px;
  }

  .sb-data-sharing-opt-out #pc--opt-out-form-field-email label {
    display: none !important;
  }

  .sb-data-sharing-opt-out #pc--opt-out-email_input {
    background: var(--sb-color-always-white) !important;
    border: 0 !important;
    border-radius: 999px !important;
    box-shadow: 0 0 10px 0 var(--sb-color-always-black-12);
    box-sizing: border-box;
    color: var(--sb-color-always-black) !important;
    font-family: var(--font-primary--family) !important;
    font-size: var(--font-size-form-input) !important;
    font-weight: 400 !important;
    height: var(--sb-space-48);
    line-height: var(--sb-space-48);
    max-width: 400px;
    padding-inline: var(--sb-space-20);
    width: min(100%, 400px);
    -webkit-appearance: none !important;
    appearance: none !important;
  }

  .sb-data-sharing-opt-out #pc--opt-out-email_input::placeholder {
    color: var(--sb-color-neutral-800);
    opacity: 1;
  }

  .sb-data-sharing-opt-out #pc--opt-out-email_input:focus,
  .sb-data-sharing-opt-out #pc--opt-out-email_input:focus-visible {
    outline: none !important;
    box-shadow: 0 0 10px 0 var(--sb-color-always-black-12) !important;
  }

  .sb-data-sharing-opt-out #pc--opt-out-button.sb-button-radiant {
    max-width: 400px !important;
    width: min(100%, 400px) !important;
  }

  @media (max-width: 989px) {
    .sb-data-sharing-opt-out #pc--opt-out-form,
    .sb-data-sharing-opt-out .pc--opt-out-form-container {
      align-items: flex-start;
      text-align: left;
    }

    .sb-data-sharing-opt-out .pc--show-email-field {
      width: 100%;
    }

    .sb-data-sharing-opt-out .pc--show-email-field label {
      align-items: start;
      column-gap: 12px;
      display: grid;
      grid-template-columns: 20px minmax(0, 1fr);
      justify-content: flex-start;
      max-width: 100%;
      white-space: normal;
      width: 100%;
    }

    .sb-data-sharing-opt-out .pc--show-email-field #pc--show-email-field {
      align-self: center;
      margin-top: 0;
    }

    .sb-data-sharing-opt-out #pc--opt-out-button.sb-button-radiant {
      align-self: flex-start !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
    }
  }

  .sb-data-sharing-opt-out #pc--opt-out-button .sb-button-radiant__label {
    align-items: center;
    display: inline-flex;
    justify-content: center;
    letter-spacing: 0 !important;
    line-height: 1 !important;
    text-transform: none !important;
  }

  .sb-data-sharing-opt-out .pc--opt-out-form-message--success {
    align-items: center;
    color: var(--sb-color-primary-500) !important;
    display: inline-flex !important;
    font-family: var(--font-primary--family) !important;
    font-size: var(--font-size-body) !important;
    font-weight: 700 !important;
    gap: 12px !important;
    justify-content: flex-start;
    margin-top: 0 !important;
    text-align: left !important;
  }

  .sb-data-sharing-opt-out #pc--opt-out-error.pc--opt-out-form-message {
    align-items: center;
    color: var(--sb-color-red-500) !important;
    display: inline-flex !important;
    font-family: var(--font-primary--family) !important;
    font-size: var(--font-size-body) !important;
    font-weight: 700 !important;
    gap: 12px !important;
    justify-content: flex-start;
    line-height: 1.3 !important;
    margin-top: 0 !important;
    text-align: left !important;
  }

  .sb-data-sharing-opt-out #pc--opt-out-success {
    display: none !important;
  }

  .sb-data-sharing-opt-out .pc--opt-out-form-message--success .icon-success {
    display: none !important;
    margin: 0 !important;
    width: 0 !important;
  }

  .sb-data-sharing-opt-out #pc--opt-out-error .icon-error {
    display: none !important;
    margin: 0 !important;
    width: 0 !important;
  }

  .sb-data-sharing-opt-out__success-icon {
    color: var(--sb-color-primary-500);
    display: inline-flex;
    flex: 0 0 auto;
    height: 20px;
    min-width: 20px;
    width: 20px;
    line-height: 0;
    order: -1;
  }

  .sb-data-sharing-opt-out__success-icon svg {
    display: block;
    height: 100%;
    margin-right: 0 !important;
    width: 100%;
  }

  .sb-data-sharing-opt-out__success-icon svg path:not([fill='none']),
  .sb-data-sharing-opt-out__success-icon svg circle:not([fill='none']),
  .sb-data-sharing-opt-out__success-icon svg rect:not([fill='none']) {
    fill: currentColor;
  }

  .sb-data-sharing-opt-out__error-icon {
    color: var(--sb-color-red-500);
    display: inline-flex;
    flex: 0 0 auto;
    height: 20px;
    min-width: 20px;
    width: 20px;
    line-height: 0;
    order: -1;
  }

  .sb-data-sharing-opt-out__error-icon svg {
    display: block;
    height: 100%;
    margin-right: 0 !important;
    width: 100%;
  }

  .sb-data-sharing-opt-out__error-icon svg path:not([fill='none']),
  .sb-data-sharing-opt-out__error-icon svg circle:not([fill='none']),
  .sb-data-sharing-opt-out__error-icon svg rect:not([fill='none']) {
    fill: currentColor;
  }
{% endstylesheet %}

<script>
  (() => {
    const root = document.querySelector('.sb-data-sharing-opt-out');
    if (!root) return;
    const arrowSvg = {{ 'arrow-reduced-padding.svg' | inline_asset_content | json }};
    const checkSvg = {{ 'icon-check.svg' | inline_asset_content | json }};
    const errorSvg = {{ 'icon-error.svg' | inline_asset_content | json }};
    const defaultOptOutLabel = {{ 'sb.data_sharing.opt_out' | t | json }};
    const checkboxOffSvg = {{ 'icon-data-sharing-opt-out-checkbox-off.svg' | inline_asset_content | json }};
    const checkboxOnSvg = {{ 'icon-data-sharing-opt-out-checkbox-on.svg' | inline_asset_content | json }};
    const checkboxFillColor = window.getComputedStyle(document.documentElement)
      .getPropertyValue('--sb-color-primary-500')
      .trim() || 'white';
    const checkboxOffSvgTinted = checkboxOffSvg.replaceAll('fill="white"', `fill="${checkboxFillColor}"`);
    const checkboxOnSvgTinted = checkboxOnSvg.replaceAll('fill="white"', `fill="${checkboxFillColor}"`);
    const toInlineSvgDataUrl = (svgContent) => `url("data:image/svg+xml;charset=utf-8,${encodeURIComponent(svgContent)}")`;
    const checkboxOffBackground = toInlineSvgDataUrl(checkboxOffSvgTinted);
    const checkboxOnBackground = toInlineSvgDataUrl(checkboxOnSvgTinted);
    const applyCheckboxVisualState = (checkboxNode) => {
      if (!checkboxNode) return;
      if (checkboxNode.checked) {
        checkboxNode.style.backgroundImage = `${checkboxOnBackground}, linear-gradient(var(--sb-color-always-white), var(--sb-color-always-white))`;
        checkboxNode.style.backgroundSize = '20px 20px, 16px 16px';
        checkboxNode.style.backgroundPosition = 'center center, center center';
        checkboxNode.style.backgroundRepeat = 'no-repeat, no-repeat';
      } else {
        checkboxNode.style.backgroundImage = checkboxOffBackground;
        checkboxNode.style.backgroundSize = '20px 20px';
        checkboxNode.style.backgroundPosition = 'center center';
        checkboxNode.style.backgroundRepeat = 'no-repeat';
      }
      checkboxNode.style.backgroundColor = 'transparent';
    };
    let applyScheduled = false;
    const isNarrowViewport = () => window.matchMedia('(max-width: 989px)').matches;
    const setImportantStyle = (node, property, value) => {
      if (!node) return;
      node.style.setProperty(property, value, 'important');
    };
    const clearInlineStyle = (node, property) => {
      if (!node) return;
      node.style.removeProperty(property);
    };

    const applyOptOutOverrides = () => {
      applyScheduled = false;
      const button = root.querySelector('#pc--opt-out-button');
      const emailInput = root.querySelector('#pc--opt-out-email_input');
      const primarySuccessMessage = root.querySelector('#pc--opt-out-message.pc--opt-out-form-message--success');
      const secondarySuccessMessage = root.querySelector('#pc--opt-out-success.pc--opt-out-form-message--success');
      const errorMessage = root.querySelector('#pc--opt-out-error.pc--opt-out-form-message');
      if (primarySuccessMessage && secondarySuccessMessage && secondarySuccessMessage.style.display !== 'none') {
        secondarySuccessMessage.style.display = 'none';
      }

      [primarySuccessMessage, secondarySuccessMessage].forEach((messageNode) => {
        if (!messageNode) return;
        const isVisible = window.getComputedStyle(messageNode).display !== 'none';
        if (isVisible) {
          messageNode.querySelectorAll('.icon-success').forEach((node) => node.remove());
          if (!messageNode.querySelector('.sb-data-sharing-opt-out__success-icon')) {
            const iconNode = document.createElement('span');
            iconNode.className = 'sb-data-sharing-opt-out__success-icon';
            iconNode.setAttribute('aria-hidden', 'true');
            iconNode.innerHTML = checkSvg;
            messageNode.append(iconNode);
          }
        } else {
          messageNode.querySelectorAll('.sb-data-sharing-opt-out__success-icon').forEach((node) => node.remove());
        }
      });

      if (errorMessage) {
        const isErrorVisible = window.getComputedStyle(errorMessage).display !== 'none';
        if (isErrorVisible) {
          errorMessage.querySelectorAll('.icon-error').forEach((node) => node.remove());
          if (!errorMessage.querySelector('.sb-data-sharing-opt-out__error-icon')) {
            const errorIconNode = document.createElement('span');
            errorIconNode.className = 'sb-data-sharing-opt-out__error-icon';
            errorIconNode.setAttribute('aria-hidden', 'true');
            errorIconNode.innerHTML = errorSvg;
            errorMessage.prepend(errorIconNode);
          }
        } else {
          errorMessage.querySelectorAll('.sb-data-sharing-opt-out__error-icon').forEach((node) => node.remove());
        }
      }

      if (!button) return;

      button.classList.add('sb-button-radiant', 'sb-button-radiant--large', 'sb-button-radiant--trailing-icon');

      if (emailInput) {
        if (!emailInput.getAttribute('placeholder')) {
          emailInput.setAttribute('placeholder', 'Email');
        }
      }

      const accountOptOutCheckbox = root.querySelector('#pc--show-email-field');
      const accountOptOutLabel = accountOptOutCheckbox ? accountOptOutCheckbox.closest('label') : null;
      let accountOptOutLabelText = null;
      if (accountOptOutCheckbox) {
        applyCheckboxVisualState(accountOptOutCheckbox);
      }
      if (accountOptOutCheckbox && accountOptOutLabel) {
        accountOptOutLabelText = accountOptOutLabel.querySelector('.sb-data-sharing-opt-out__checkbox-label-text');
        if (!accountOptOutLabelText) {
          const extractedText = Array.from(accountOptOutLabel.childNodes)
            .filter((node) => node !== accountOptOutCheckbox)
            .map((node) => node.textContent || '')
            .join(' ')
            .replace(/\s+/g, ' ')
            .trim();
          Array.from(accountOptOutLabel.childNodes).forEach((node) => {
            if (node !== accountOptOutCheckbox) node.remove();
          });
          accountOptOutLabelText = document.createElement('span');
          accountOptOutLabelText.className = 'sb-data-sharing-opt-out__checkbox-label-text';
          accountOptOutLabelText.textContent = extractedText;
          accountOptOutLabel.append(accountOptOutLabelText);
        }

        if (isNarrowViewport()) {
          setImportantStyle(accountOptOutLabel, 'display', 'grid');
          setImportantStyle(accountOptOutLabel, 'grid-template-columns', '20px minmax(0, 1fr)');
          setImportantStyle(accountOptOutLabel, 'column-gap', '12px');
          setImportantStyle(accountOptOutLabel, 'align-items', 'start');
          setImportantStyle(accountOptOutLabel, 'justify-content', 'flex-start');
          setImportantStyle(accountOptOutLabel, 'width', '100%');
          setImportantStyle(accountOptOutLabel, 'max-width', '100%');

          setImportantStyle(accountOptOutCheckbox, 'grid-column', '1');
          setImportantStyle(accountOptOutCheckbox, 'grid-row', '1');
          setImportantStyle(accountOptOutCheckbox, 'align-self', 'center');
          setImportantStyle(accountOptOutCheckbox, 'margin-top', '0');

          setImportantStyle(accountOptOutLabelText, 'grid-column', '2');
          setImportantStyle(accountOptOutLabelText, 'grid-row', '1');
          setImportantStyle(accountOptOutLabelText, 'display', 'block');
          setImportantStyle(accountOptOutLabelText, 'line-height', '1.3');
          setImportantStyle(accountOptOutLabelText, 'min-width', '0');
        } else {
          [
            'display',
            'grid-template-columns',
            'column-gap',
            'align-items',
            'justify-content',
            'width',
            'max-width'
          ].forEach((prop) => clearInlineStyle(accountOptOutLabel, prop));
          ['grid-column', 'grid-row', 'align-self', 'margin-top'].forEach((prop) => clearInlineStyle(accountOptOutCheckbox, prop));
          if (accountOptOutLabelText) {
            ['grid-column', 'grid-row', 'display', 'line-height', 'min-width'].forEach((prop) =>
              clearInlineStyle(accountOptOutLabelText, prop)
            );
          }
        }
      }
      if (accountOptOutCheckbox && accountOptOutLabel && !accountOptOutLabel.dataset.sbCheckboxClickGuardBound) {
        accountOptOutLabel.dataset.sbCheckboxClickGuardBound = 'true';
        accountOptOutLabel.addEventListener('click', (event) => {
          if (event.target !== accountOptOutCheckbox) {
            event.preventDefault();
          }
        });
      }
      if (accountOptOutCheckbox && !accountOptOutCheckbox.dataset.sbCheckboxIconBound) {
        accountOptOutCheckbox.dataset.sbCheckboxIconBound = 'true';
        accountOptOutCheckbox.addEventListener('change', () => {
          applyCheckboxVisualState(accountOptOutCheckbox);
        });
      }

      const hasLabel = button.querySelector('.sb-button-radiant__label');
      if (!hasLabel) {
        const buttonLabelText = (button.textContent || '').trim() || defaultOptOutLabel;
        button.textContent = '';

        const labelNode = document.createElement('span');
        labelNode.className = 'sb-button-radiant__label';
        labelNode.textContent = buttonLabelText;

        const iconNode = document.createElement('span');
        iconNode.className = 'sb-button-radiant__icon';
        iconNode.setAttribute('aria-hidden', 'true');
        iconNode.innerHTML = arrowSvg;

        button.append(labelNode, iconNode);
      }
    };

    const scheduleApply = () => {
      if (applyScheduled) return;
      applyScheduled = true;
      if (typeof window.requestAnimationFrame === 'function') {
        window.requestAnimationFrame(applyOptOutOverrides);
      } else {
        window.setTimeout(applyOptOutOverrides, 16);
      }
    };

    const observer = new MutationObserver(scheduleApply);
    observer.observe(root, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ['class', 'style']
    });

    applyOptOutOverrides();
    window.addEventListener('resize', scheduleApply, { passive: true });
    window.setTimeout(scheduleApply, 300);
    window.setTimeout(scheduleApply, 1200);
  })();
</script>

{% schema %}
{
  "name": "Data sharing opt out",
  "settings": []
}
{% endschema %}
