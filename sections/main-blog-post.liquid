{% liquid
  assign default_blog_url = routes.root_url | append: 'blogs/articles'
  assign blog_url = blog.url | default: default_blog_url
  assign active_tag_handle = ''
  if current_tags != blank
    assign active_tag_handle = current_tags.first | handleize
  endif

  assign has_product_tag_filters = false
  assign has_instrument_tag_filters = false

  assign article_category_text = blank
  assign article_fallback_tag = blank
  for tag in article.tags
    assign normalized_tag = tag | downcase
    if normalized_tag contains 'by_product'
      assign parsed_category = tag | remove_first: 'By_product: ' | remove_first: 'by_product: ' | remove_first: 'By_product - ' | remove_first: 'by_product - ' | remove_first: 'By_product-' | remove_first: 'by_product-' | remove_first: 'By_product ' | remove_first: 'by_product ' | remove_first: 'By_product' | remove_first: 'by_product' | strip
      if parsed_category != blank
        assign article_category_text = parsed_category
        break
      endif
    elsif normalized_tag contains 'by_instrument'
      assign parsed_category = tag | remove_first: 'By_instrument: ' | remove_first: 'by_instrument: ' | remove_first: 'By_instrument - ' | remove_first: 'by_instrument - ' | remove_first: 'By_instrument-' | remove_first: 'by_instrument-' | remove_first: 'By_instrument ' | remove_first: 'by_instrument ' | remove_first: 'By_instrument' | remove_first: 'by_instrument' | strip
      if parsed_category != blank
        assign article_category_text = parsed_category
        break
      endif
    elsif article_fallback_tag == blank
      assign article_fallback_tag = tag
    endif
  endfor
  if article_category_text == blank and article_fallback_tag != blank
    assign article_category_text = article_fallback_tag
  endif
  if article_category_text == blank
    assign article_category_text = blog.title
  endif

  assign article_plain_text = article.content | strip_html | replace: '&nbsp;', ' ' | replace: '&#160;', ' ' | strip
  assign article_word_count = article_plain_text | split: ' ' | size
  assign article_read_duration_minutes = article_word_count | plus: 219 | divided_by: 220
  if article_read_duration_minutes < 1
    assign article_read_duration_minutes = 1
  endif
  assign article_read_duration_text = article_read_duration_minutes | append: ''
  assign article_excerpt_text = article.excerpt | strip_html | strip
  if article_excerpt_text == blank
    assign article_excerpt_text = article_plain_text | truncatewords: 36
  endif

  assign seasonal_sale_name = settings.seasonal_sale_name | strip
  assign sale_name_token = '{{ Sale name }}'
  assign sitewide_discount_depth_token = '{{ Sitewide discount depth }}'
  assign shipping_country_token = '{{ Shipping country }}'
  assign free_shipping_threshold_token = '{{ Free shipping threshold }}'
  assign sitewide_seasonal_discount_depth = settings.sitewide_seasonal_discount_depth | default: 48 | strip
  assign sidebar_shipping_country_name = localization.country.name | default: localization.country.iso_code | default: 'your country'
  assign sidebar_shipping_country_iso = localization.country.iso_code | upcase | strip
  assign sidebar_shipping_country_handle = sidebar_shipping_country_iso | downcase
  assign sidebar_shipping_is_blocked = false
  assign sidebar_shipping_has_free_shipping = false
  assign sidebar_free_shipping_threshold_display = ''
  assign sidebar_shipping_entry = shop.metaobjects['database_localized_shipping_info'][sidebar_shipping_country_handle]
  if sidebar_shipping_entry != blank and sidebar_shipping_country_iso != blank
    assign sidebar_entry_ship_to = sidebar_shipping_entry.ship_to_it.value | default: sidebar_shipping_entry.ship_to_it | append: '' | downcase
    assign sidebar_entry_has_free_shipping = sidebar_shipping_entry.free_shipping_available.value | default: sidebar_shipping_entry.free_shipping_available | append: '' | downcase
    assign sidebar_entry_threshold = sidebar_shipping_entry.free_shipping_threshold_in_local_currency.value | default: sidebar_shipping_entry.free_shipping_threshold_in_local_currency

    if sidebar_entry_ship_to == 'false' or sidebar_entry_ship_to == '0' or sidebar_entry_ship_to == 'no'
      assign sidebar_shipping_is_blocked = true
    endif
    if sidebar_entry_has_free_shipping == 'true' or sidebar_entry_has_free_shipping == '1' or sidebar_entry_has_free_shipping == 'yes'
      assign sidebar_shipping_has_free_shipping = true
    endif
    if sidebar_entry_threshold != blank
      assign sidebar_entry_threshold_cents = sidebar_entry_threshold | times: 100
      assign sidebar_free_shipping_threshold_display = sidebar_entry_threshold_cents | money_without_trailing_zeros
    endif
  endif

  assign sidebar_promo_title = settings.seasonal_hero_headline | strip
  assign sidebar_promo_text_free_shipping = settings.seasonal_hero_subheadline_free_shipping | strip
  assign sidebar_promo_text_no_free_shipping = settings.seasonal_hero_subheadline_no_free_shipping | strip
  assign sidebar_promo_text_blocked = settings.seasonal_hero_subheadline_blocked | strip
  if sidebar_shipping_is_blocked
    assign sidebar_promo_text = sidebar_promo_text_blocked
  elsif sidebar_shipping_has_free_shipping
    assign sidebar_promo_text = sidebar_promo_text_free_shipping
  else
    assign sidebar_promo_text = sidebar_promo_text_no_free_shipping
  endif
  assign sidebar_promo_button_label = settings.seasonal_hero_button_label | strip
  assign sidebar_promo_button_link = settings.seasonal_hero_button_link

  assign sidebar_promo_title = sidebar_promo_title | replace: sale_name_token, seasonal_sale_name
  assign sidebar_promo_text = sidebar_promo_text | replace: sale_name_token, seasonal_sale_name
  assign sidebar_promo_text = sidebar_promo_text | replace: sitewide_discount_depth_token, sitewide_seasonal_discount_depth
  assign sidebar_promo_text = sidebar_promo_text | replace: shipping_country_token, sidebar_shipping_country_name
  assign sidebar_promo_text = sidebar_promo_text | replace: free_shipping_threshold_token, sidebar_free_shipping_threshold_display
  assign sidebar_promo_button_label = sidebar_promo_button_label | replace: sale_name_token, seasonal_sale_name
%}

{% liquid
  assign read_next_count = 0
%}
{% capture read_next_cards_markup %}
  {% for related_article in blog.articles %}
    {% if related_article.id == article.id %}
      {% continue %}
    {% endif %}
    {% if read_next_count >= 3 %}
      {% break %}
    {% endif %}
    {%
      render 'sb-blog-overview-article-card',
      article: related_article,
      blog_title: blog.title,
      card_class: 'sb-blog-overview-card--archive'
    %}
    {% assign read_next_count = read_next_count | plus: 1 %}
  {% endfor %}
{% endcapture %}

{% capture product_tag_filter_options %}
  {% for tag in blog.all_tags %}
    {% liquid
      assign tag_value = tag | strip
      assign tag_value_handle = tag_value | handleize
      assign tag_value_downcase = tag_value | downcase
      assign tag_prefix = tag_value_downcase | slice: 0, 10
      assign option_label = ''

      if tag_prefix == 'by_product'
        assign option_label = tag_value | slice: 10, tag_value.size
        assign leading_char = option_label | slice: 0, 1
        if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
          assign option_label = option_label | slice: 1, option_label.size
        endif
        assign option_label = option_label | strip
        if option_label == blank
          assign option_label = tag_value
        endif
      endif
    %}

    {% if option_label != blank %}
      {% liquid
        assign has_product_tag_filters = true
        assign option_is_active = false
        if active_tag_handle == tag_value_handle
          assign option_is_active = true
        endif
      %}
      <a
        class="sb-blog-post__sticky-filter-option font-caption weight-semibold{% if option_is_active %} is-active{% endif %}"
        href="{{ blog_url }}/tagged/{{ tag_value_handle }}"
      >
        {{ option_label | escape }}
      </a>
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture instrument_tag_filter_options %}
  {% for tag in blog.all_tags %}
    {% liquid
      assign tag_value = tag | strip
      assign tag_value_handle = tag_value | handleize
      assign tag_value_downcase = tag_value | downcase
      assign tag_prefix = tag_value_downcase | slice: 0, 13
      assign option_label = ''

      if tag_prefix == 'by_instrument'
        assign option_label = tag_value | slice: 13, tag_value.size
        assign leading_char = option_label | slice: 0, 1
        if leading_char == '_' or leading_char == '-' or leading_char == ':' or leading_char == '|'
          assign option_label = option_label | slice: 1, option_label.size
        endif
        assign option_label = option_label | strip
        if option_label == blank
          assign option_label = tag_value
        endif
      endif
    %}

    {% if option_label != blank %}
      {% liquid
        assign has_instrument_tag_filters = true
        assign option_is_active = false
        if active_tag_handle == tag_value_handle
          assign option_is_active = true
        endif
      %}
      <a
        class="sb-blog-post__sticky-filter-option font-caption weight-semibold{% if option_is_active %} is-active{% endif %}"
        href="{{ blog_url }}/tagged/{{ tag_value_handle }}"
      >
        {{ option_label | escape }}
      </a>
    {% endif %}
  {% endfor %}
{% endcapture %}

{% liquid
  assign mobile_categories_trigger_label = 'Categories'
  if active_tag_handle == 'company-news'
    assign mobile_categories_trigger_label = 'Company news'
  elsif active_tag_handle == 'music-insights'
    assign mobile_categories_trigger_label = 'Music insights'
  elsif active_tag_handle == 'product-insights' or active_tag_handle == 'product-tips'
    assign mobile_categories_trigger_label = 'Product tips'
  elsif active_tag_handle == 'gift-guides'
    assign mobile_categories_trigger_label = 'Gift guides'
  endif
%}

<section
  class="sb-blog-post"
  style="
    --sb-supplementary-sticky-top-gap-desktop: {{ section.settings.supplementary_sticky_top_gap_desktop | default: 16 }}px;
    --sb-supplementary-sticky-top-gap-mobile: {{ section.settings.supplementary_sticky_top_gap_mobile | default: 16 }}px;
    --sb-supplementary-sticky-inline-margin-desktop: {{ section.settings.supplementary_sticky_inline_margin_desktop | default: 60 }}px;
    --sb-supplementary-sticky-inline-margin-mobile: {{ section.settings.supplementary_sticky_inline_margin_mobile | default: 16 }}px;
    --sb-supplementary-sticky-nav-padding-y-desktop: {{ section.settings.supplementary_sticky_nav_padding_y_desktop | default: 12 }}px;
    --sb-supplementary-sticky-nav-padding-y-mobile: {{ section.settings.supplementary_sticky_nav_padding_y_mobile | default: 12 }}px;
  "
>
  <div class="sb-blog-post__inner">
    <div
      class="sb-blog-post__sticky-nav-wrap sb-blog-post__sticky-nav-wrap--desktop"
      aria-label="Sticky blog navigation"
      data-sb-blog-post-sticky-nav-wrap
      data-sb-sticky-top-navigation
    >
      <div class="sb-blog-post__sticky-nav" data-sb-blog-post-sticky-nav>
        <div class="sb-blog-post__sticky-nav-left" aria-label="Blog category filters">
          <a class="sb-blog-post__sticky-filter font-caption" href="{{ blog_url }}">All</a>
          <a class="sb-blog-post__sticky-filter font-caption" href="{{ blog_url }}/tagged/company-news">Company news</a>
          <a class="sb-blog-post__sticky-filter font-caption" href="{{ blog_url }}/tagged/music-insights">Music insights</a>
          <a class="sb-blog-post__sticky-filter font-caption" href="{{ blog_url }}/tagged/product-tips">Product tips</a>
          <a class="sb-blog-post__sticky-filter font-caption" href="{{ blog_url }}/tagged/gift-guides">Gift guides</a>

          {% if has_product_tag_filters %}
            <div class="sb-blog-post__sticky-dropdown" data-sb-blog-post-filter-dropdown>
              <button
                type="button"
                class="sb-blog-post__sticky-filter sb-blog-post__sticky-filter--dropdown font-caption"
                aria-expanded="false"
                aria-controls="SbBlogPostByProductPanel-{{ section.id }}"
                data-sb-blog-post-filter-trigger
              >
                <span>By product</span>
                <span class="sb-blog-post__sticky-filter-caret" aria-hidden="true">
                  {{ 'icon-chevron.svg' | inline_asset_content }}
                </span>
              </button>
              <div
                id="SbBlogPostByProductPanel-{{ section.id }}"
                class="sb-blog-post__sticky-filter-panel"
                data-sb-blog-post-filter-panel
              >
                <div class="sb-blog-post__sticky-filter-panel-surface">
                  <div class="sb-blog-post__sticky-filter-panel-inner">
                    {{ product_tag_filter_options }}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}

          {% if has_instrument_tag_filters %}
            <div class="sb-blog-post__sticky-dropdown" data-sb-blog-post-filter-dropdown>
              <button
                type="button"
                class="sb-blog-post__sticky-filter sb-blog-post__sticky-filter--dropdown font-caption"
                aria-expanded="false"
                aria-controls="SbBlogPostByInstrumentPanel-{{ section.id }}"
                data-sb-blog-post-filter-trigger
              >
                <span>By instrument</span>
                <span class="sb-blog-post__sticky-filter-caret" aria-hidden="true">
                  {{ 'icon-chevron.svg' | inline_asset_content }}
                </span>
              </button>
              <div
                id="SbBlogPostByInstrumentPanel-{{ section.id }}"
                class="sb-blog-post__sticky-filter-panel"
                data-sb-blog-post-filter-panel
              >
                <div class="sb-blog-post__sticky-filter-panel-surface">
                  <div class="sb-blog-post__sticky-filter-panel-inner">
                    {{ instrument_tag_filter_options }}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        </div>
        {%
          render 'radiant-button',
          link: routes.all_products_collection_url,
          label: 'Explore our shop',
          size: 'medium',
          extra_class: 'sb-blog-post__sticky-nav-shop-button font-caption weight-bold'
        %}
      </div>
    </div>
    <div
      class="sb-blog-post__sticky-nav-wrap sb-blog-post__sticky-nav-wrap--mobile"
      aria-label="Sticky blog navigation"
      data-sb-blog-post-sticky-nav-wrap
      data-sb-sticky-top-navigation
    >
      <div class="sb-blog-post__sticky-nav sb-blog-post__sticky-nav--mobile" data-sb-blog-post-sticky-nav>
        <div class="sb-blog-post__sticky-dropdown" data-sb-blog-post-filter-dropdown>
          <button
            type="button"
            class="sb-blog-post__sticky-filter sb-blog-post__sticky-filter--dropdown sb-blog-post__sticky-filter--mobile font-caption{% if active_tag_handle != blank %} is-active{% endif %}"
            aria-expanded="false"
            aria-controls="SbBlogPostCategoriesPanel-{{ section.id }}"
            data-sb-blog-post-filter-trigger
          >
            <span class="sb-blog-post__sticky-filter-label sb-blog-post__sticky-filter-label--mobile">{{ mobile_categories_trigger_label | escape }}</span>
            <span class="sb-blog-post__sticky-filter-caret" aria-hidden="true">
              {{ 'icon-chevron.svg' | inline_asset_content }}
            </span>
          </button>
          <div
            id="SbBlogPostCategoriesPanel-{{ section.id }}"
            class="sb-blog-post__sticky-filter-panel sb-blog-post__sticky-filter-panel--mobile"
            data-sb-blog-post-filter-panel
          >
            <div class="sb-blog-post__sticky-filter-panel-surface">
              <div class="sb-blog-post__sticky-filter-panel-inner sb-blog-post__sticky-filter-panel-inner--mobile">
                <div class="sb-blog-post__sticky-filter-panel-header">
                  <button
                    type="button"
                    class="sb-blog-post__sticky-filter-close"
                    data-sb-blog-post-filter-close
                    aria-label="Close categories"
                  >
                    <span class="sb-blog-post__sticky-filter-close-icon" aria-hidden="true">
                      {{ 'icon-cancel.svg' | inline_asset_content }}
                    </span>
                  </button>
                  <p class="sb-blog-post__sticky-filter-panel-title font-callout weight-bold">Categories</p>
                </div>
                <div class="sb-blog-post__sticky-filter-panel-list">
                  <a
                    class="sb-blog-post__sticky-filter-option font-caption{% if active_tag_handle == blank %} is-active{% endif %}"
                    href="{{ blog_url }}"
                  >
                    All
                  </a>
                  <a
                    class="sb-blog-post__sticky-filter-option font-caption{% if active_tag_handle == 'company-news' %} is-active{% endif %}"
                    href="{{ blog_url }}/tagged/company-news"
                  >
                    Company news
                  </a>
                  <a
                    class="sb-blog-post__sticky-filter-option font-caption{% if active_tag_handle == 'music-insights' %} is-active{% endif %}"
                    href="{{ blog_url }}/tagged/music-insights"
                  >
                    Music insights
                  </a>
                  <a
                    class="sb-blog-post__sticky-filter-option font-caption{% if active_tag_handle == 'product-insights' or active_tag_handle == 'product-tips' %} is-active{% endif %}"
                    href="{{ blog_url }}/tagged/product-tips"
                  >
                    Product tips
                  </a>
                  <a
                    class="sb-blog-post__sticky-filter-option font-caption{% if active_tag_handle == 'gift-guides' %} is-active{% endif %}"
                    href="{{ blog_url }}/tagged/gift-guides"
                  >
                    Gift guides
                  </a>

                  {% if has_product_tag_filters %}
                    <span class="sb-blog-post__sticky-filter-option sb-blog-post__sticky-filter-option--group font-caption">
                      By product
                    </span>
                    <div class="sb-blog-post__sticky-filter-option-children">
                      {{ product_tag_filter_options }}
                    </div>
                  {% endif %}

                  {% if has_instrument_tag_filters %}
                    <span class="sb-blog-post__sticky-filter-option sb-blog-post__sticky-filter-option--group font-caption">
                      By instrument
                    </span>
                    <div class="sb-blog-post__sticky-filter-option-children">
                      {{ instrument_tag_filter_options }}
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        </div>
        {%
          render 'radiant-button',
          link: routes.all_products_collection_url,
          label: 'Explore our shop',
          size: 'medium',
          extra_class: 'sb-blog-post__sticky-nav-shop-button sb-blog-post__sticky-nav-shop-button--mobile font-caption weight-bold'
        %}
      </div>
    </div>
    <div class="sb-blog-post__sticky-backdrop" data-sb-blog-post-filter-backdrop aria-hidden="true"></div>

    {% capture sidebar_promo_markup %}
      {% if sidebar_promo_title != blank or sidebar_promo_text != blank or sidebar_promo_button_label != blank %}
        <section class="sb-blog-sidebar-box sb-blog-sidebar-box--promo" aria-label="{{ sidebar_promo_title | default: 'Sidebar promo' }}">
          {% if sidebar_promo_title != blank %}
            <h3 class="sb-blog-sidebar-box__promo-title font-callout weight-bold">{{ sidebar_promo_title }}</h3>
          {% endif %}

          {% if sidebar_promo_text != blank %}
            <p class="sb-blog-sidebar-box__promo-text font-body weight-regular">{{ sidebar_promo_text }}</p>
          {% endif %}

          {% if sidebar_promo_button_label != blank and sidebar_promo_button_link != blank %}
            <a class="sb-blog-sidebar-box__promo-button font-caption weight-bold" href="{{ sidebar_promo_button_link }}">
              {{ sidebar_promo_button_label }}
            </a>
          {% elsif sidebar_promo_button_label != blank %}
            <span class="sb-blog-sidebar-box__promo-button font-caption weight-bold">
              {{ sidebar_promo_button_label }}
            </span>
          {% endif %}
        </section>
      {% endif %}
    {% endcapture %}

    <div class="sb-blog-post__layout">
      <article class="sb-blog-post__main">
        <header class="sb-blog-post__header">
          <p class="sb-blog-post__meta-item font-caption weight-regular">{{ article_category_text }}</p>
          <p class="sb-blog-post__meta-item font-caption weight-regular">
            {{ article.published_at | date: format: 'abbreviated_date' }}
          </p>
          {% if article_read_duration_text != blank %}
            <p class="sb-blog-post__meta-item sb-blog-post__meta-item--read-time font-caption weight-regular">
              {% if article_read_duration_text contains 'min' %}
                {{ article_read_duration_text }}
              {% else %}
                {{ article_read_duration_text }} min read
              {% endif %}
            </p>
          {% endif %}
          <h1 class="sb-blog-post__title font-title weight-bold">{{ article.title }}</h1>
          {% if article_excerpt_text != blank %}
            <p class="sb-blog-post__excerpt font-body weight-semibold">{{ article_excerpt_text }}</p>
          {% endif %}
        </header>

        {% if article.image != blank %}
          <figure class="sb-blog-post__media">
            {{
              article.image
              | image_url: width: 1600
              | image_tag:
                widths: '400,800,1200,1600',
                sizes: '(max-width: 989px) calc(100vw - 32px), 800px',
                class: 'sb-blog-post__image',
                loading: 'eager',
                alt: article.title
            }}
          </figure>
          {% if sidebar_promo_markup != blank %}
            <div class="sb-blog-post__mobile-promo" aria-label="{{ sidebar_promo_title | default: 'Sidebar promo' }}">
              {{ sidebar_promo_markup }}
            </div>
          {% endif %}
        {% endif %}

        <div class="sb-blog-post__content rte">
          {{ article.content }}
        </div>

        <div class="sb-blog-post__postscript">
          <div class="sb-blog-post__postscript-divider" aria-hidden="true"></div>
          <p class="sb-blog-post__postscript-author font-body weight-bold">by Team Soundbrenner</p>

          {% if section.settings.about_box_content != blank %}
            <section class="sb-blog-post__about-box rte font-body weight-regular" aria-label="About Soundbrenner">
              {% render 'localized-richtext-links', content: section.settings.about_box_content %}
            </section>
          {% endif %}

          {% if read_next_count > 0 %}
            <section class="sb-blog-post__read-next" aria-label="Read this next">
              <h2 class="sb-blog-post__read-next-title font-title weight-bold">Read this next</h2>
              <div class="sb-blog-post__read-next-list">
                {{ read_next_cards_markup }}
              </div>
            </section>
          {% endif %}
        </div>

        {% if blog.comments_enabled? %}
          <section class="sb-blog-post__comments" id="comments">
            <h2 class="sb-blog-post__comments-title font-callout weight-semibold">
              {{ 'blog.article_comments' | t }}
            </h2>

            {% paginate article.comments by 10 %}
              <div class="sb-blog-post__comment-list">
                {% for comment in article.comments %}
                  <article class="sb-blog-post__comment">
                    <p class="sb-blog-post__comment-content font-caption weight-regular">{{ comment.content }}</p>
                    <p class="sb-blog-post__comment-meta font-caption2 weight-regular">
                      {{ comment.author }} · {{ comment.created_at | date: format: 'abbreviated_date' }}
                    </p>
                  </article>
                {% endfor %}
              </div>
              {% if paginate.pages > 1 %}
                <nav class="sb-blog-post__pagination font-caption weight-regular" aria-label="Comment pagination">
                  {{ paginate | default_pagination }}
                </nav>
              {% endif %}
            {% endpaginate %}
          </section>
        {% endif %}
      </article>

      {% if sidebar_promo_markup != blank %}
        <aside class="sb-blog-post__sidebar sb-blog-post__sidebar--desktop" aria-label="{{ sidebar_promo_title | default: 'Sidebar promo' }}">
          <div class="sb-blog-post__sidebar-stack" data-sb-blog-post-sticky-stack>
            <div class="sb-blog-post__sidebar-phase sb-blog-post__sidebar-phase--1" data-sb-blog-post-sidebar-phase-1>
              <div class="sb-blog-post__sidebar-card-wrap" data-sb-blog-post-sidebar-sticky-card>
                {{ sidebar_promo_markup }}
              </div>
            </div>
          </div>
        </aside>
      {% endif %}
    </div>
  </div>
</section>

<script type="application/ld+json">
  {{ article | structured_data }}
</script>

{% stylesheet %}
  .shopify-section:has(> .sb-blog-post) {
    margin-top: 0 !important;
  }

  .sb-blog-post {
    --sb-blog-post-first-offset: calc(var(--sb-sticky-top-stack-bottom, 0px) + var(--sb-space-96));
    --sb-blog-post-sidebar-start-offset: 0px;
    --sb-menu-unroll-duration: 420ms;
    --sb-menu-unroll-ease: cubic-bezier(0.22, 1, 0.36, 1);
    --sb-menu-surface-shadow: 0 48px 48px 0 var(--sb-color-always-black-25);
    padding: 0;
  }

  .sb-blog-post__inner {
    margin: 0 auto;
