    .sb-blog-post__sticky-filter-panel-inner--mobile {
      gap: 0;
      height: 100%;
      overflow-y: auto;
      padding: calc(20px + env(safe-area-inset-top, 0px)) 20px calc(20px + env(safe-area-inset-bottom, 0px));
      width: 100%;
    }

    .sb-blog-post__sticky-filter-panel-header {
      align-items: flex-start;
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-bottom: 20px;
    }

    .sb-blog-post__sticky-filter-close {
      align-items: center;
      background: transparent;
      border: 0;
      color: var(--sb-color-neutral-900);
      cursor: pointer;
      display: inline-flex;
      flex: 0 0 auto;
      height: 20px;
      justify-content: center;
      padding: 0;
      position: relative;
      width: 20px;
    }

    .sb-blog-post__sticky-filter-close-icon {
      color: inherit;
      display: inline-flex;
      height: 16px;
      transition: color 140ms ease;
      width: 16px;
    }

    .sb-blog-post__sticky-filter-close:hover .sb-blog-post__sticky-filter-close-icon,
    .sb-blog-post__sticky-filter-close:focus-visible .sb-blog-post__sticky-filter-close-icon {
      color: var(--sb-color-primary-500);
    }

    .sb-blog-post__sticky-filter-close-icon svg {
      display: block;
      height: 100%;
      width: 100%;
    }

    .sb-blog-post__sticky-filter-close-icon svg path:not([fill='none']),
    .sb-blog-post__sticky-filter-close-icon svg circle:not([fill='none']),
    .sb-blog-post__sticky-filter-close-icon svg rect:not([fill='none']) {
      fill: currentColor !important;
    }

    .sb-blog-post__sticky-filter-panel-title {
      color: var(--sb-color-neutral-900);
      margin: 0;
    }

    .sb-blog-post__sticky-filter-panel-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      width: 100%;
    }

    .sb-blog-post__sticky-filter-panel-list .sb-blog-post__sticky-filter-option {
      width: 100%;
    }

    .sb-blog-post__sticky-filter-option--group {
      cursor: default;
      pointer-events: none;
    }

    .sb-blog-post__sticky-filter-option--group:hover,
    .sb-blog-post__sticky-filter-option--group:focus-visible {
      background: var(--sb-color-neutral-400);
      color: var(--sb-color-neutral-900);
    }

    .sb-blog-post__sticky-filter-option--group.is-active {
      background: var(--sb-color-primary-500);
      color: var(--sb-color-always-white);
    }

    .sb-blog-post__sticky-filter-option-children {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin-left: 16px;
      width: calc(100% - 16px);
    }

    .sb-blog-post__sticky-backdrop {
      -webkit-backdrop-filter: brightness(0.75);
      backdrop-filter: brightness(0.75);
      background: var(--sb-color-always-black-25);
      z-index: 109;
    }

    .sb-blog-post__layout {
      display: block;
    }

    .sb-blog-post__sidebar--desktop {
      display: none;
    }

    .sb-blog-post__mobile-promo {
      display: block;
      margin-top: 30px;
    }

    .sb-blog-post__read-next .sb-blog-overview-card--archive {
      background: var(--sb-color-neutral-200);
      border-bottom: 0;
      border-radius: 24px;
      display: flex;
      overflow: hidden;
      padding: 0;
    }

    .sb-blog-post__read-next .sb-blog-overview-card--archive + .sb-blog-overview-card--archive {
      margin-top: 30px;
    }

    .sb-blog-post__read-next .sb-blog-overview-card--archive .sb-blog-overview-card__media {
      border-radius: 0;
    }

    .sb-blog-post__read-next .sb-blog-overview-card--archive .sb-blog-overview-card__content {
      padding: 24px;
    }
  }

  @media (max-width: 749px) {
    .sb-blog-post__sticky-nav-wrap--mobile {
      --sb-supplementary-sticky-inline-margin: var(--sb-supplementary-sticky-inline-margin-mobile);
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const root = document.querySelector('.sb-blog-post');
    if (!root) return;

    const stickyNavWraps = Array.from(root.querySelectorAll('[data-sb-blog-post-sticky-nav-wrap]'));
    const sidebarStacks = Array.from(root.querySelectorAll('[data-sb-blog-post-sticky-stack]'));
    const articleMain = root.querySelector('.sb-blog-post__main');
    const articleInner = root.querySelector('.sb-blog-post__inner');
    const articleContent = root.querySelector('.sb-blog-post__content');
    const filterDropdowns = Array.from(root.querySelectorAll('[data-sb-blog-post-filter-dropdown]'));
    const filterCloseButtons = Array.from(root.querySelectorAll('[data-sb-blog-post-filter-close]'));
    const filterBackdrop = root.querySelector('[data-sb-blog-post-filter-backdrop]');

    const closeFilterDropdown = (dropdown, { returnFocus = false } = {}) => {
      if (!dropdown || dropdown.getAttribute('data-open') !== 'true') return;
      const trigger = dropdown.querySelector('[data-sb-blog-post-filter-trigger]');
      const panel = dropdown.querySelector('[data-sb-blog-post-filter-panel]');
      if (!trigger || !panel) return;

      trigger.setAttribute('aria-expanded', 'false');
      dropdown.removeAttribute('data-open');
      panel.classList.add('is-closing');
      panel.classList.remove('is-active');
      updateBackdropState();

      let closeSettled = false;
      const finalizeClose = (event) => {
        if (event && event.target !== panel) return;
        if (event && event.propertyName !== 'grid-template-rows') return;
        if (closeSettled || dropdown.getAttribute('data-open') === 'true') return;
        closeSettled = true;
        panel.removeEventListener('transitionend', finalizeClose);
        panel.classList.remove('is-closing');
        if (returnFocus) trigger.focus();
      };

      panel.addEventListener('transitionend', finalizeClose);
      window.setTimeout(finalizeClose, 620);
    };

    const closeAllFilterDropdowns = ({ except = null } = {}) => {
      filterDropdowns.forEach((dropdown) => {
        if (dropdown === except) return;
        closeFilterDropdown(dropdown);
      });
    };

    const updateBackdropState = () => {
      const hasOpenDropdown = filterDropdowns.some((dropdown) => dropdown.getAttribute('data-open') === 'true');
      if (filterBackdrop) {
        filterBackdrop.classList.toggle('is-active', hasOpenDropdown);
      }
      document.documentElement.classList.toggle('is-blog-post-filter-open', hasOpenDropdown);
      if (document.body) {
        document.body.classList.toggle('is-blog-post-filter-open', hasOpenDropdown);
      }
    };

    const openFilterDropdown = (dropdown) => {
      if (!dropdown || dropdown.getAttribute('data-open') === 'true') return;
      const trigger = dropdown.querySelector('[data-sb-blog-post-filter-trigger]');
      const panel = dropdown.querySelector('[data-sb-blog-post-filter-panel]');
      if (!trigger || !panel) return;

      closeAllFilterDropdowns({ except: dropdown });
      trigger.setAttribute('aria-expanded', 'true');
      dropdown.setAttribute('data-open', 'true');
      panel.classList.remove('is-closing');
      panel.classList.add('is-active');
      updateBackdropState();
    };

    if (filterDropdowns.length) {
      filterDropdowns.forEach((dropdown) => {
        const trigger = dropdown.querySelector('[data-sb-blog-post-filter-trigger]');
        const panel = dropdown.querySelector('[data-sb-blog-post-filter-panel]');
        if (!trigger || !panel) return;

        dropdown.removeAttribute('data-open');
        panel.classList.remove('is-active');
        panel.classList.remove('is-closing');
        trigger.setAttribute('aria-expanded', 'false');

        trigger.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          if (dropdown.getAttribute('data-open') === 'true') {
            closeFilterDropdown(dropdown);
            return;
          }
          openFilterDropdown(dropdown);
        });
      });

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Node)) return;
        if (filterDropdowns.some((dropdown) => dropdown.contains(target))) return;
        closeAllFilterDropdowns();
      });

      document.addEventListener('keyup', (event) => {
        if (event.key !== 'Escape') return;
        const openDropdown = filterDropdowns.find((dropdown) => dropdown.getAttribute('data-open') === 'true');
        if (!openDropdown) return;
        closeFilterDropdown(openDropdown, { returnFocus: true });
      });

      if (filterBackdrop) {
        filterBackdrop.addEventListener('click', () => {
          closeAllFilterDropdowns();
          updateBackdropState();
        });
      }

      window.addEventListener('resize', () => {
        closeAllFilterDropdowns();
        updateBackdropState();
      });

      updateBackdropState();
    }

    if (filterCloseButtons.length) {
      filterCloseButtons.forEach((button) => {
        button.addEventListener('click', (event) => {
          event.preventDefault();
          const dropdown = button.closest('[data-sb-blog-post-filter-dropdown]');
          closeFilterDropdown(dropdown);
          updateBackdropState();
        });
      });
    }

    const isDesktop = () => window.matchMedia('(min-width: 990px)').matches;
    const parseSpaceVar = (name, fallback) => {
      const rawValue = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      const parsed = Number.parseFloat(rawValue);
      return Number.isFinite(parsed) ? parsed : fallback;
    };

    const getTopStackBottom = () => {
      if (window.SBStickyStack && typeof window.SBStickyStack.getState === 'function') {
        const stickyState = window.SBStickyStack.getState();
        if (Number.isFinite(stickyState?.topStackBottom)) {
          return Math.max(stickyState.topStackBottom, 0);
        }
      }
      return parseSpaceVar('--sb-sticky-top-stack-bottom', 0);
    };

    const syncFirstContentOffset = () => {
      const headingOffset = parseSpaceVar('--sb-space-96', 96);
      const currentScrollTop = window.scrollY || window.pageYOffset || 0;
      const innerTop = (articleInner || root).getBoundingClientRect().top + currentScrollTop;
      const topStackBottom = getTopStackBottom();
      const nextOffset = Math.max(Math.round(topStackBottom + headingOffset - innerTop), headingOffset);
      const nextOffsetValue = `${nextOffset}px`;
      const currentOffsetValue = root.style.getPropertyValue('--sb-blog-post-first-offset');
      if (currentOffsetValue !== nextOffsetValue) {
        root.style.setProperty('--sb-blog-post-first-offset', nextOffsetValue);
      }
    };

    const applySidebarLayout = () => {
      const isMobileViewport = window.matchMedia('(max-width: 989px)').matches;

      sidebarStacks.forEach((stack) => {
        const phaseOne = stack.querySelector('[data-sb-blog-post-sidebar-phase-1]');
        if (!phaseOne) return;
        phaseOne.style.height = '';

        if (isMobileViewport) return;
        phaseOne.style.height = '100%';
      });
    };

    const syncSidebarStartOffset = () => {
      if (!isDesktop() || !articleMain || !articleContent) {
        root.style.setProperty('--sb-blog-post-sidebar-start-offset', '0px');
        return;
      }

      const mainRect = articleMain.getBoundingClientRect();
      const contentRect = articleContent.getBoundingClientRect();
      const startOffset = Math.max(0, Math.round(contentRect.top - mainRect.top));
      root.style.setProperty('--sb-blog-post-sidebar-start-offset', `${startOffset}px`);
    };

    let frameRequested = false;
    const requestLayoutUpdate = () => {
      if (frameRequested) return;
      frameRequested = true;
      window.requestAnimationFrame(() => {
        frameRequested = false;
        syncSidebarStartOffset();
        applySidebarLayout();
        syncFirstContentOffset();
      });
    };

    window.addEventListener('resize', requestLayoutUpdate);
    window.addEventListener('load', requestLayoutUpdate);
    document.addEventListener('sb:cart-drawer:state-change', requestLayoutUpdate);
    document.addEventListener('sb:sticky-stack:change', requestLayoutUpdate);

    if ('ResizeObserver' in window) {
      const observer = new ResizeObserver(requestLayoutUpdate);
      observer.observe(document.body);
      stickyNavWraps.forEach((wrap) => {
        observer.observe(wrap);
        const nav = wrap.querySelector('[data-sb-blog-post-sticky-nav]');
        if (nav) observer.observe(nav);
      });
      sidebarStacks.forEach((stack) => observer.observe(stack));
    }

    requestLayoutUpdate();
  })();
{% endjavascript %}

